---
import Container from "./Container.astro";

const nav = [
  { href: "/", label: "Home" },
  { href: "/how-it-works", label: "How It Works" },
  { href: "/blog", label: "Insights" },
  { href: "/sourcing", label: "Sourcing" },
  { href: "/capabilities", label: "Capabilities" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const pathname = Astro.url?.pathname || "/";
const isActive = (href) => (href === "/" ? pathname === "/" : pathname.startsWith(href));
---

<style>
  .topbar{
    position:sticky; top:0; z-index:50;
    background: rgba(18, 34, 74, .82);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255,255,255,.06);
  }

  .nav{
    height:80px;
    display:flex; align-items:center; justify-content:space-between; gap:14px;
  }

  .brand{
    display:flex; align-items:center; gap:12px;
    font-weight:900; letter-spacing:.4px;
  }

  .brand img{
    height:108px;
    filter: brightness(0) invert(1);
    width:auto;
    display:block;
  }

  .menu{
    display:flex; align-items:center; gap:18px;
    color:rgba(210,220,245,.85);
    font-weight:650;
  }
  .menu a{ padding:8px 10px; border-radius:10px; }
  .menu a:hover{ color:#fff; background:rgba(255,255,255,.06); }

  .menu a.active{
    color:#fff;
    background: rgba(47,91,255,.18);
    border:1px solid rgba(47,91,255,.32);
  }

  .right{
    display:flex; align-items:center; gap:10px;
  }

  .hamburger{
    display:none;
    align-items:center;
    gap:10px;
    background: rgba(255,255,255,.06);
    border:1px solid rgba(255,255,255,.10);
    color:#fff;
    padding:10px 12px;
    border-radius:14px;
    cursor:pointer;
    font-weight:900;
  }
  .hamburger:hover{ background: rgba(255,255,255,.10); }

  .hamburgerText{
    font-size:14px;
    letter-spacing:.2px;
    opacity:.95;
  }

  .backdrop{
    position:fixed; inset:0;
    background: rgba(0,0,0,.45);
    z-index:60;
  }

  .drawer{
    position:fixed; top:0; right:0;
    height:100vh;
    width:min(86vw, 360px);
    background:#0b1630;
    z-index:70;
    box-shadow: -12px 0 30px rgba(0,0,0,.35);
    transform: translateX(100%);
    transition: transform .22s ease;
    padding:14px 14px 18px;
    border-left:1px solid rgba(255,255,255,.08);
  }
  .drawer.open{ transform: translateX(0); }

  .drawerHead{
    display:flex;
    align-items:center;
    justify-content:flex-end;
    padding:6px 4px 10px;
  }

  .closeBtn{
    background: rgba(255,255,255,.10);
    color:#fff;
    border:0;
    border-radius:10px;
    padding:8px 10px;
    cursor:pointer;
  }

  .drawerNav{
    display:flex;
    flex-direction:column;
    margin-top:6px;
  }

  .drawerNav a{
    padding:12px 10px;
    border-radius:12px;
    color: rgba(255,255,255,.92);
    font-weight:700;
  }
  .drawerNav a:hover{ background: rgba(255,255,255,.06); }

  .drawerNav a.active{
    background: rgba(47,91,255,.18);
    border:1px solid rgba(47,91,255,.32);
  }

  .drawerCta{
    margin-top:12px;
  }

  .cta{
    display:inline-flex; align-items:center; justify-content:center; gap:8px;
    padding:10px 14px;
    border-radius:12px;
    background:#2F5BFF;
    color:#fff;
    font-weight:900;
    border:1px solid rgba(255,255,255,.12);
    white-space:nowrap;
  }
  .cta:hover{
    transform: translateY(-1px);
    transition:.15s;
    filter: brightness(1.06);
  }

  .drawerCta a{
    display:block;
    width:100%;
    text-align:center;
  }

  @media (max-width: 980px){
    .menu{ display:none; }
    .hamburger{ display:inline-flex; }
    .brand img{ height:72px; }
  }
</style>

<div class="topbar">
  <Container>
    <div class="nav">
      <a class="brand" href="/">
        <img src="/images/logo.png" alt="CertiSpares" />
      </a>

      <nav class="menu" aria-label="Primary navigation">
        {nav.map((i) => (
          <a href={i.href} class={isActive(i.href) ? "active" : ""}>
            {i.label}
          </a>
        ))}
      </nav>

      <div class="right">
        <button
          class="hamburger"
          type="button"
          aria-label="Open menu"
          aria-controls="mobileDrawer"
          aria-expanded="false"
          id="menuBtn"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 6h16M4 12h16M4 18h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="hamburgerText">Menu</span>
        </button>
      </div>
    </div>
  </Container>
</div>

<div id="menuBackdrop" class="backdrop" hidden></div>

<aside id="mobileDrawer" class="drawer" hidden>
  <div class="drawerHead">
    <button class="closeBtn" type="button" aria-label="Close menu" id="menuCloseBtn">&times;</button>
  </div>

  <nav class="drawerNav" aria-label="Mobile navigation">
    {nav.map((i) => (
      <a href={i.href} class={isActive(i.href) ? "active" : ""}>
        {i.label}
      </a>
    ))}
  </nav>

  <div class="drawerCta">
    <a class="cta" href="/contact">Get a Sourcing Quote</a>
  </div>
</aside>

<script is:inline>
  const btn = document.getElementById('menuBtn');
  const drawer = document.getElementById('mobileDrawer');
  const backdrop = document.getElementById('menuBackdrop');
  const closeBtn = document.getElementById('menuCloseBtn');

  function openMenu(){
    if (!btn || !drawer || !backdrop) return;
    drawer.hidden = false;
    backdrop.hidden = false;
    requestAnimationFrame(() => drawer.classList.add('open'));
    btn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu(){
    if (!btn || !drawer || !backdrop) return;
    drawer.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    setTimeout(() => {
      drawer.hidden = true;
      backdrop.hidden = true;
    }, 220);
  }

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    expanded ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  drawer?.addEventListener('click', (e) => {
    const a = e.target.closest('a');
    if (a) closeMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') closeMenu();
  });
</script>
