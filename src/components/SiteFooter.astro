---
const year = new Date().getFullYear();
const CONTACT_EMAIL = "murphy@certispares.com";
const WHATSAPP_E164 = "8615633022618";
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_E164}?text=Hello%20CertiSpares%2C%20I%20would%20like%20to%20discuss%20truck%20parts%20sourcing.`;
const FACEBOOK_URL = "https://www.facebook.com/profile.php?id=61585722976089";
const footerLinks = [
  {
    href: "/",
    label: "Home",
    desc: "China truck parts sourcing overview",
  },
  {
    href: "/product",
    label: "Product",
    desc: "Engine and gearbox platform catalog",
  },
  {
    href: "/sourcing",
    label: "Sourcing Categories",
    desc: "Truck spare parts and category coverage",
  },
  {
    href: "/capabilities",
    label: "Capabilities",
    desc: "Supplier comparison, QC, and export support",
  },
  {
    href: "/how-it-works",
    label: "How It Works",
    desc: "Truck parts sourcing workflow from RFQ to shipment",
  },
  {
    href: "/contact",
    label: "Contact",
    desc: "Request a truck parts quote",
  },
];
---

<style>
  .footerWrap{
    border-top:1px solid var(--site-line);
    margin-top:10px;
    background:var(--site-bg);
  }
  .footer{
    padding:26px 0;
    color:var(--site-muted);
    display:flex;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:18px;
  }
  .footerMeta{
    display:grid;
    gap:8px;
    max-width:520px;
  }
  .footerTitle{
    color:rgba(234,240,255,.94);
    font-weight:800;
  }
  .footerSocial{
    display:flex;
    gap:5px;
    margin-top:6px;
    padding:5px 7px;
    border-radius:14px;
    border:1px solid var(--site-line);
    background:rgba(255,255,255,.04);
    width:max-content;
  }
  .socialIcon{
    width:26px;
    height:26px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    border-radius:999px;
    border:1px solid transparent;
    background:rgba(255,255,255,.02);
    color:rgba(234,240,255,.94);
    transition:transform .15s ease, background .15s ease, border-color .15s ease;
  }
  .socialIcon:hover{
    transform:translateY(-1px);
    background:rgba(255,255,255,.08);
    border-color:rgba(255,255,255,.16);
  }
  .socialIcon svg{
    width:12px;
    height:12px;
    display:block;
  }
  .footerNav{
    display:grid;
    grid-template-columns:repeat(2, minmax(220px, 1fr));
    gap:10px 12px;
    max-width:560px;
  }
  .footerNav a{
    display:block;
    padding:10px 12px;
    border-radius:12px;
    border:1px solid var(--site-line);
    background:rgba(255,255,255,.03);
  }
  .footerNav a:hover{
    color:var(--site-text);
    background:rgba(255,255,255,.06);
  }
  .footerNav strong{
    display:block;
    color:rgba(234,240,255,.94);
    font-size:14px;
    margin-bottom:4px;
  }
  .footerNav span{
    display:block;
    font-size:12px;
    line-height:1.5;
  }
  @media (max-width: 980px){
    .footerNav{
      grid-template-columns:1fr;
      max-width:none;
    }
  }
</style>

<div class="footerWrap">
  <div class="container">
    <footer class="footer">
      <div class="footerMeta">
        <div class="footerTitle">CertiSpares</div>
        <div>China truck parts sourcing and commercial vehicle spare parts support for importers, distributors, and fleet-related buyers.</div>
        <div class="footerSocial" aria-label="Footer social links">
          <a class="socialIcon" href={FACEBOOK_URL} aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.3-1.6 1.7-1.6H16.7V4.8c-.3 0-1.3-.1-2.5-.1-2.5 0-4.1 1.5-4.1 4.4V11H7.4v3h2.7v8h3.4Z"/>
            </svg>
          </a>
          <a class="socialIcon" href={WHATSAPP_URL} aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M20 11.9A8 8 0 0 0 6.3 6.3 7.9 7.9 0 0 0 4 11.9c0 1.4.4 2.8 1.1 4L4 20l4.2-1.1c1.1.6 2.4 1 3.8 1A8 8 0 0 0 20 11.9Zm-8 6.7c-1.2 0-2.4-.3-3.5-1l-.2-.1-2.5.7.7-2.4-.2-.3A6.7 6.7 0 1 1 12 18.6Zm3.7-5c-.2-.1-1.3-.6-1.4-.6-.2-.1-.3-.1-.5.1l-.4.6c-.1.2-.3.2-.5.1-.7-.3-1.3-.8-1.8-1.3-.4-.5-.8-1-.9-1.2-.1-.2 0-.3.1-.4l.3-.4.2-.3c.1-.1 0-.3 0-.4l-.6-1.4c-.1-.2-.2-.2-.4-.2h-.3c-.2 0-.4.1-.6.3-.2.2-.8.8-.8 1.9s.8 2.2.9 2.4c.1.1 1.6 2.5 4 3.4.6.2 1 .4 1.4.5.6.2 1.2.2 1.6.1.5-.1 1.3-.5 1.5-1 .2-.5.2-1 .1-1.1-.1-.1-.2-.2-.4-.3Z"/>
            </svg>
          </a>
          <a class="socialIcon" href={`mailto:${CONTACT_EMAIL}`} aria-label="Email">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Zm0 2v.4l8 5.2 8-5.2V8H4Zm16 8V10.8l-7.5 4.9a1 1 0 0 1-1 0L4 10.8V16h16Z"/>
            </svg>
          </a>
        </div>
        <div>&copy; {year} CertiSpares. All rights reserved.</div>
      </div>
      <nav class="footerNav" aria-label="Footer navigation">
        {footerLinks.map((item) => (
          <a href={item.href}>
            <strong>{item.label}</strong>
            <span>{item.desc}</span>
          </a>
        ))}
      </nav>
    </footer>
  </div>
</div>
