---
import BaseLayout from "../layouts/BaseLayout.astro";

const steps = [
  {
    n: "1",
    t: "Send RFQ",
    p: "OEM/part numbers / brand / model / photos. Tell us target market and quantity.",
  },
  {
    n: "2",
    t: "Supplier comparison",
    p: "We source multiple factories and submit options with lead time & risk notes.",
  },
  {
    n: "3",
    t: "QC checkpoints",
    p: "Sampling + packaging/label check, photo/video evidence before shipment.",
  },
  {
    n: "4",
    t: "Export execution",
    p: "PI/CI/PL review, document accuracy, tracking and updates.",
  },
];

const needFromYou = [
  { t: "Parts info", p: "OEM/part numbers or photos (photos are OK)." },
  { t: "Vehicle coverage", p: "Brand/model/year if available (helps avoid mismatch)." },
  { t: "Quantity", p: "Target order quantity or consolidation plan." },
  { t: "Destination", p: "Country/port and preferred Incoterms if you have." },
  { t: "Packaging", p: "Carton marks, label/barcode, private label needs." },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "How to source truck parts from China",
    description:
      "RFQ intake, supplier comparison, QC checkpoints, and export execution for heavy duty and commercial vehicle buyers sourcing truck parts from China.",
    step: steps.map((step) => ({
      "@type": "HowToStep",
      name: step.t,
      text: step.p,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://certispares.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "How It Works",
        item: "https://certispares.com/how-it-works/",
      },
    ],
  },
];
---

<BaseLayout
  title="How to Source Truck Parts from China | CertiSpares Workflow"
  description="See how to source truck parts from China with CertiSpares: RFQ intake, supplier comparison, QC checkpoints, packing verification, and export execution for heavy duty aftermarket buyers."
  keywords={["how to source truck parts from China", "truck parts sourcing workflow", "import truck parts from China", "OEM part number RFQ", "truck parts export process"]}
  canonical="/how-it-works/"
  ogImage="/images/shipping-documents-export-paperwork.jpg"
  jsonLd={jsonLd}
>
  <style>
    :root{
      --bg:#eef3f7;
      --text:#1d2a36;
      --muted:#5f6d86;
      --line:rgba(29,42,54,.10);
      --brand:#3957E9;
      --brand2:#3957E9;
    }

    :global(main){
      background:linear-gradient(180deg, #f5f8fc 0%, #eef3f7 100%);
    }

    :global(.topbar){
      background:#111F43 !important;
      background-color:#111F43 !important;
      opacity:1 !important;
      backdrop-filter:none !important;
      -webkit-backdrop-filter:none !important;
      border-bottom:1px solid #111F43 !important;
      box-shadow:none !important;
    }

    :global(.menu){
      color:#fff;
    }

    :global(.menu a){
      color:#fff;
    }

    :global(.menu a:hover){
      color:#fff;
    }

    :global(.menu a.active){
      color:#fff;
      background:rgba(57,87,233,.18);
      border-color:rgba(57,87,233,.32);
    }

    :global(.drawerNav a.active){
      color:#fff;
      background:rgba(57,87,233,.18);
      border-color:rgba(57,87,233,.32);
    }

    :global(.cta){
      background:#3957E9;
      color:#fff;
    }

    /* ===== HERO (Insights-style) ===== */
    .hero{
      position:relative;
      padding:46px 0 20px;
      border-bottom:1px solid var(--line);
      overflow:hidden;
      isolation:isolate;
      background:#0b1020;
    }

    .heroBg{
      position:absolute;
      inset:0;
      z-index:-2;
      background:
        url("/images/shipping-documents-export-paperwork.jpg") center/cover no-repeat;
      /* 鍏抽敭锛氭祬娴呮ā绯?+ 绋嶅井鍘嬩竴涓嬪姣?楗卞拰锛岃鏍囬鏇寸ǔ */
      filter: blur(2.0px) saturate(.95) contrast(.95) brightness(.92);
      transform: scale(1.03); /* 闃叉 blur 闇茶竟 */
    }

    /* 閬僵锛氫繚璇佺櫧鑹叉爣棰樺彲璇?*/
    .overlay{
      position:absolute;
      inset:0;
      z-index:-1;
      background:
        linear-gradient(180deg, rgba(11,16,32,.28) 0%, rgba(11,16,32,.86) 72%, rgba(11,16,32,1) 100%),
        radial-gradient(900px 420px at 25% 20%, rgba(57,87,233,.22), transparent 60%);
    }

    .kicker{letter-spacing:.12em;text-transform:uppercase;font-size:.8rem;opacity:.82;margin:0 0 .75rem;color:rgba(255,255,255,.82)}
    .title{margin:0 0 .8rem;font-size:40px;letter-spacing:-.4px;line-height:1.12;color:#fff}
    .sub{margin:0;max-width:78ch;color:rgba(225,233,255,.86);line-height:1.75}

    /* ===== BODY (keep your existing layout) ===== */
    .sectionTitle{ font-size:22px; margin:0 0 10px; letter-spacing:-.2px; color:#1d2a36; }
    .sectionDesc{ margin:0 0 16px; color:var(--muted); line-height:1.7; max-width:980px; }

    .grid2{ display:grid; grid-template-columns: repeat(2, 1fr); gap:14px; }
    .grid3{ display:grid; grid-template-columns: repeat(3, 1fr); gap:14px; }

    .step{
      display:flex; gap:12px; align-items:flex-start;
      padding:16px;
      border-radius:18px;
      background:#fff;
      border:1px solid rgba(29,42,54,.10);
      box-shadow:0 14px 32px rgba(24,39,56,.05);
    }
    .num{
      width:34px; height:34px; border-radius:12px;
      display:flex; align-items:center; justify-content:center;
      font-weight:950;
      background:rgba(74,84,98,.08);
      border:1px solid rgba(74,84,98,.18);
      color:#4A5462;
      flex:0 0 34px;
      margin-top:2px;
    }
    .st{ font-weight:950; margin-bottom:6px; color:#1d2a36; }
    .sp{ margin:0; color:var(--muted); line-height:1.7; }

    .ctaBlock{
      margin-top:12px;
      background:linear-gradient(135deg, rgba(57,87,233,.10), rgba(255,255,255,.92));
      border:1px solid rgba(57,87,233,.16);
      border-radius:20px;
      padding:18px;
      display:flex; justify-content:space-between; align-items:center; gap:14px;
      box-shadow:0 16px 40px rgba(24,39,56,.05);
    }
    .ctaBlock .left b{ display:block; margin-bottom:6px; color:#1d2a36; }
    .ctaBlock .left p{ margin:0; color:var(--muted); line-height:1.7; max-width:760px; }

    .ctaBlock .btn.primary{
      color:#fff;
      background:#3957E9;
    }

    .ctaBlock .btn:not(.primary){
      color:#fff;
      background:#3957E9;
      border-color:#3957E9;
    }

    .mini{
      margin-top:12px;
      padding:14px;
      border-radius:16px;
      background:#fff;
      border:1px solid rgba(29,42,54,.10);
      box-shadow:0 14px 32px rgba(24,39,56,.05);
      color:var(--muted);
      line-height:1.7;
    }
    .mini b{ color:#1d2a36; }

    .card{
      background:#fff;
      border:1px solid rgba(29,42,54,.10);
      box-shadow:0 14px 32px rgba(24,39,56,.05);
    }

    .card b{
      color:#1d2a36;
    }

    .card p{
      color:var(--muted);
    }

    .grid3 .card a,
    .grid2 .card a,
    .mini a,
    .section a:not(.btn):not(.postMore):not(.viewAll){
      color:#1d2a36;
    }

    :global(.footerWrap){
      background:transparent;
      border-top:1px solid rgba(29,42,54,.10);
    }

    :global(.footerTitle),
    :global(.footerNav strong){
      color:#1d2a36;
    }

    :global(.footer),
    :global(.footerNav span){
      color:var(--muted);
    }

    :global(.footerNav a){
      background:#fff;
      border-color:rgba(29,42,54,.10);
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 980px){
      .title{font-size:34px}
      .grid2{ grid-template-columns:1fr; }
      .grid3{ grid-template-columns:1fr; }
      .ctaBlock{ flex-direction:column; align-items:flex-start; }
    }

    @media (max-width: 720px){
      .heroBg{
        filter: blur(2px) saturate(.95) contrast(.95) brightness(.92);
        transform: scale(1.04);
      }
    }
  </style>

  <header class="hero">
    <div class="heroBg" aria-hidden="true"></div>
    <div class="overlay" aria-hidden="true"></div>

    <div class="container">
      <p class="kicker">CertiSpares / Process</p>
      <h1 class="title">How to source truck parts from China</h1>
      <p class="sub">
        A clear, repeatable workflow for heavy duty truck parts and commercial vehicle spare parts:
        RFQ -> sourcing and comparison -> QC checkpoints -> export execution.
        Built for buyers who need predictable lead time and fewer disputes.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Workflow</h2>
      <p class="sectionDesc">
        We keep the process simple: clear inputs, evidence before shipment, and consistent documentation.
      </p>

      <div class="grid2">
        {steps.map((s) => (
          <div class="step">
            <div class="num">{s.n}</div>
            <div>
              <div class="st">{s.t}</div>
              <p class="sp">{s.p}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="ctaBlock">
        <div class="left">
          <b>Ready to share your RFQ?</b>
          <p>
            Send OEM/part numbers (or photos), quantities, destination port, and packaging requirements.
            We'll reply with options and lead time.
          </p>
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a class="btn primary" href="/contact">Get a Sourcing Quote</a>
          <a class="btn" href="/capabilities">See Capabilities</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">What we need from you</h2>
      <p class="sectionDesc">
        The more complete the input, the faster the sourcing cycle and the lower the mismatch risk.
      </p>

      <div class="grid3">
        {needFromYou.map((x) => (
          <div class="card">
            <b>{x.t}</b>
            <p>{x.p}</p>
          </div>
        ))}
      </div>

      <div class="mini">
        <b>Tip:</b> If you only have photos, an old supplier sheet, or OEM and part numbers, send them anyway.
        For repeat orders, we can standardize your RFQ template and packaging marks.
      </div>
    </div>
  </section>
</BaseLayout>
