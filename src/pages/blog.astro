---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogArchive from "../components/BlogArchive.astro";
import { getCollection } from "astro:content";
import { getTagSummaries, mapBlogPosts } from "../lib/blogArchive";

const rawPosts = await getCollection("blog");
const posts = mapBlogPosts(rawPosts);
const tagSummaries = getTagSummaries(posts);

const featuredPosts = posts.filter((post) => post.featured).slice(0, 3);
const clusters = tagSummaries
  .map((tag) => ({
    tag: tag.label,
    items: posts.filter((post) => post.tagSlug === tag.slug).slice(0, 3),
  }))
  .filter((cluster) => cluster.items.length > 0);

const currentTag = Astro.url.searchParams.get("tag") ?? "";
const currentPageRaw = Number.parseInt(Astro.url.searchParams.get("page") ?? "1", 10);
const currentPage = Number.isFinite(currentPageRaw) && currentPageRaw > 0 ? currentPageRaw : 1;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Truck Parts Sourcing Insights",
    description:
      "A knowledge hub covering truck parts sourcing in China, quality control, supplier selection, and commercial vehicle aftermarket trends for B2B buyers.",
    url: "https://certispares.com/blog/",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://certispares.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Insights",
        item: "https://certispares.com/blog/",
      },
    ],
  },
];
---

<BaseLayout
  title="Truck Parts Sourcing Insights | CertiSpares"
  description="Commercial vehicle sourcing insights for B2B buyers and sourcing managers, covering truck parts sourcing in China, quality control, supplier selection, and aftermarket trends."
  keywords={["truck parts sourcing blog", "commercial vehicle parts insights", "China sourcing blog", "truck parts quality control"]}
  canonical="/blog/"
  ogImage="/images/insights-hero-collage.png"
  jsonLd={jsonLd}
>
  <style>
    :root{
      --bg:#eef3f7;
      --text:#1d2a36;
      --muted:#5f6d86;
      --line:rgba(29,42,54,.10);
      --brand:#3957E9;
    }

    :global(main){
      background:linear-gradient(180deg, #f5f8fc 0%, #eef3f7 100%);
    }

    :global(.topbar){
      background:#111F43 !important;
      background-color:#111F43 !important;
      opacity:1 !important;
      backdrop-filter:none !important;
      -webkit-backdrop-filter:none !important;
      border-bottom:1px solid #111F43 !important;
      box-shadow:none !important;
    }

    :global(.menu),
    :global(.menu a),
    :global(.menu a:hover){
      color:#fff;
    }

    :global(.menu a.active),
    :global(.drawerNav a.active){
      color:#fff;
      background:rgba(57,87,233,.18);
      border-color:rgba(57,87,233,.32);
    }

    :global(.cta){
      background:#3957E9;
      color:#fff;
    }

    .hero{
      position:relative;
      padding:46px 0 20px;
      border-bottom:1px solid var(--line);
      overflow:hidden;
      isolation:isolate;
      background:#0b1020;
    }

    .heroBg{
      position:absolute;
      inset:0;
      z-index:-2;
      background:url("/images/insights-hero-collage.png") center/cover no-repeat;
      filter:blur(2px) saturate(.95) contrast(.95) brightness(.92);
      transform:scale(1.03);
    }

    .overlay{
      position:absolute;
      inset:0;
      z-index:-1;
      background:
        linear-gradient(180deg, rgba(11,16,32,.28) 0%, rgba(11,16,32,.86) 72%, rgba(11,16,32,1) 100%),
        radial-gradient(900px 420px at 25% 20%, rgba(57,87,233,.22), transparent 60%);
    }

    .kicker{
      margin:0 0 .75rem;
      color:#fff;
      font-size:.8rem;
      letter-spacing:.12em;
      text-transform:uppercase;
      opacity:.82;
    }

    .title{
      margin:0 0 .8rem;
      color:#fff;
      font-size:40px;
      line-height:1.12;
      letter-spacing:-.4px;
    }

    .sub{
      margin:0;
      max-width:72ch;
      color:rgba(225,233,255,.86);
      line-height:1.75;
    }

    .wrap{
      padding:22px 0 10px;
    }

    .featured{
      padding:14px 0 10px;
      border-bottom:1px solid rgba(29,42,54,.10);
      margin-bottom:6px;
    }

    .sectionTitle{
      display:flex;
      align-items:baseline;
      justify-content:space-between;
      gap:10px;
      margin:0 0 10px;
    }

    .sectionTitle h2{
      margin:0;
      font-size:1.05rem;
      letter-spacing:.02em;
      color:#1d2a36;
    }

    .sectionTitle p{
      margin:0;
      color:var(--muted);
      font-size:.9rem;
      white-space:nowrap;
    }

    .featuredGrid,
    .clusterGrid{
      display:grid;
      grid-template-columns:repeat(12, 1fr);
      gap:12px;
      padding:8px 0 14px;
    }

    .featuredCard,
    .clusterCard{
      border:1px solid rgba(29,42,54,.10);
      border-radius:18px;
      background:#fff;
      box-shadow:0 14px 32px rgba(24,39,56,.05);
    }

    .featuredCard{
      grid-column:span 4;
      display:block;
      padding:16px;
      text-decoration:none;
      transition:transform .12s ease, border-color .12s ease;
    }

    .featuredCard:hover{
      transform:translateY(-2px);
      border-color:rgba(29,42,54,.16);
    }

    .featuredCard h3{
      margin:.6rem 0 .45rem;
      font-size:1.08rem;
      line-height:1.35;
      color:#1d2a36;
      display:-webkit-box;
      -webkit-box-orient:vertical;
      -webkit-line-clamp:2;
      overflow:hidden;
    }

    .clusters{
      padding:14px 0 6px;
      border-bottom:1px solid rgba(29,42,54,.10);
      margin-bottom:6px;
    }

    .clusterCard{
      grid-column:span 4;
      padding:14px;
    }

    .clusterCardHeader{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      margin-bottom:10px;
    }

    .tag,
    .clusterTag{
      display:inline-flex;
      padding:.18rem .55rem;
      border-radius:999px;
      border:1px solid rgba(74,84,98,.16);
      background:rgba(74,84,98,.08);
      color:#4A5462;
      font-size:.78rem;
    }

    .meta{
      display:flex;
      flex-wrap:wrap;
      gap:.45rem;
      align-items:center;
      color:var(--muted);
      font-size:.82rem;
    }

    .dot{
      opacity:.6;
    }

    .excerpt{
      margin:0;
      color:var(--muted);
      line-height:1.6;
      display:-webkit-box;
      -webkit-box-orient:vertical;
      -webkit-line-clamp:3;
      overflow:hidden;
    }

    .clusterMiniList{
      display:flex;
      flex-direction:column;
      gap:8px;
    }

    .miniLink{
      display:-webkit-box;
      -webkit-box-orient:vertical;
      -webkit-line-clamp:2;
      overflow:hidden;
      color:#1d2a36;
      font-size:.92rem;
      font-weight:900;
      line-height:1.35;
      text-decoration:none;
      opacity:.92;
    }

    .miniMeta{
      margin-top:2px;
      color:var(--muted);
      font-size:.78rem;
    }

    .archiveSection{
      padding-top:2px;
    }

    :global(.footerWrap){
      background:transparent;
      border-top:1px solid rgba(29,42,54,.10);
    }

    :global(.footerTitle),
    :global(.footerNav strong){
      color:#1d2a36;
    }

    :global(.footer),
    :global(.footerNav span){
      color:var(--muted);
    }

    :global(.footerNav a){
      background:#fff;
      border-color:rgba(29,42,54,.10);
    }

    @media (max-width: 980px){
      .title{
        font-size:34px;
      }

      .featuredCard,
      .clusterCard{
        grid-column:span 12;
      }
    }

    @media (max-width: 720px){
      .heroBg{
        transform:scale(1.04);
      }
    }
  </style>

  <header class="hero">
    <div class="heroBg" aria-hidden="true"></div>
    <div class="overlay" aria-hidden="true"></div>

    <div class="container">
      <p class="kicker">CertiSpares / Insights</p>
      <h1 class="title">A Knowledge Hub for Commercial Vehicle Sourcing</h1>
      <p class="sub">
        Analysis and practical guidance for B2B buyers and sourcing managers covering truck parts sourcing in China,
        quality control, supplier selection, and commercial vehicle aftermarket trends.
      </p>
    </div>
  </header>

  <section class="container wrap">
    {featuredPosts.length > 0 && (
      <section class="featured">
        <div class="sectionTitle">
          <h2>Featured Guides</h2>
          <p>Key sourcing topics</p>
        </div>

        <div class="featuredGrid">
          {featuredPosts.map((post) => (
            <a class="featuredCard" href={post.href}>
              <div class="meta">
                <span class="tag">{post.tag}</span>
                <span class="dot">&middot;</span>
                <span>{post.date}</span>
                <span class="dot">&middot;</span>
                <span>{post.readTime}</span>
              </div>
              <h3>{post.title}</h3>
              <p class="excerpt">{post.excerpt}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="clusters">
      <div class="sectionTitle">
        <h2>Topics</h2>
        <p>Browse by sourcing theme</p>
      </div>

      <div class="clusterGrid">
        {clusters.slice(0, 6).map((cluster) => (
          <div class="clusterCard">
            <div class="clusterCardHeader">
              <span class="clusterTag">{cluster.tag}</span>
            </div>

            <div class="clusterMiniList">
              {cluster.items.map((item) => (
                <div>
                  <a class="miniLink" href={item.href}>{item.title}</a>
                  <div class="miniMeta">{item.date} &middot; {item.readTime}</div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="archiveSection">
      <BlogArchive
        posts={posts}
        tagSummaries={tagSummaries}
        requestedTag={currentTag}
        requestedPage={currentPage}
        basePath="/blog/"
      />
    </section>
  </section>
</BaseLayout>
