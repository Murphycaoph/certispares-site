---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getImageDimensions } from "../lib/imageDimensions";

const strategyCards = [
  {
    title: "Container consolidation lowers logistics cost",
    desc: "CertiSpares can combine products from multiple approved suppliers into one container, helping buyers spread freight and export overhead across a broader and more practical order mix.",
    image: "/images/sourcing/advantage-warehouse-shelves.jpg",
    points: [
      "Lower landed cost than treating each factory order as a separate shipment",
      "Better container utilization without forcing excess volume into one SKU family",
      "One coordinated loading and document path across mixed supplier cargo",
    ],
  },
  {
    title: "Balanced multi-SKU sourcing improves turnover",
    desc: "Instead of overcommitting to a narrow product line, buyers can source the mix they actually need across multiple SKUs and build a healthier inventory structure with the same budget.",
    image: "/images/sourcing/advantage-inventory-worker.jpg",
    points: [
      "More stock depth in the right fast- and medium-moving lines",
      "Cleaner replenishment logic based on demand rather than container pressure",
      "Better cash-flow efficiency and stronger reorder probability",
    ],
  },
];

const problemCards = [
  {
    title: "One supplier rarely fills the right container alone",
    desc: "Many buyers do not have enough demand in a single product line to fill a container efficiently without distorting the order.",
    image: "/images/sourcing/traditional-buying-friction.jpg",
  },
  {
    title: "Buying just to fill space can create slow stock",
    desc: "When the container target drives the order, buyers often take too much of a few SKUs and create inventory that moves slower than planned.",
    image: "/images/sourcing/friction-container-yard.jpg",
  },
  {
    title: "Slow-moving stock ties up working capital",
    desc: "Overstocked items absorb freight, storage, and cash that could otherwise support faster-moving replenishment and repeat orders.",
    image: "/images/sourcing/friction-port-topview.jpg",
  },
];

const comparisonCards = [
  {
    title: "Buying vertically from one supplier at a time",
    image: "/images/sourcing/compare-container-ship.jpg",
    bullets: [
      "Container planning depends on one product range alone",
      "Buyers may increase quantities mainly to reach shipping efficiency",
      "A narrow SKU mix can leave stock unbalanced after arrival",
      "Cash is tied more heavily to a few lines and slower sell-through risk rises",
    ],
  },
  {
    title: "Buying through a coordinated multi-SKU model",
    image: "/images/sourcing/compare-warehouse-team.jpg",
    bullets: [
      "Multiple needed SKUs can be built into one container across suppliers",
      "Order volume follows market demand more closely instead of filling space",
      "Inventory arrives in a more balanced structure for sales and replenishment",
      "Stable quality and supply consistency support cleaner repeat-order cycles",
    ],
  },
];

const outcomeCards = [
  {
    t: "Lower landed cost",
    p: "Freight efficiency improves when multiple supplier orders move as one managed shipment.",
  },
  {
    t: "Better inventory structure",
    p: "Budget can be distributed across the SKUs buyers truly need instead of overloading a few items.",
  },
  {
    t: "Faster stock turnover",
    p: "Balanced purchasing makes it easier for inventory to move in line with actual market demand.",
  },
  {
    t: "Better cash-flow efficiency",
    p: "Capital is less likely to be trapped in slow-moving stock created only for shipping convenience.",
  },
  {
    t: "Stronger reorder logic",
    p: "A healthier stock mix makes repeat ordering more practical when quality and supply remain stable.",
  },
  {
    t: "Practical supply-chain coordination",
    p: "Supplier comparison, QC, packing review, and export follow-up keep the model operationally controlled.",
  },
];

const benchmarkCards = [
  {
    label: "Indicative freight benchmark",
    metric: "50% to 100%",
    headline: "container loading can roughly halve implied freight cost per CBM",
    note: "Based on an April 2026 public-lane benchmark model using 20GP capacity normalization.",
  },
  {
    label: "Illustrative turnover model",
    metric: "1.5x to 3.0x",
    headline: "inventory turnover improvement under a balanced multi-SKU sourcing model",
    note: "Illustrative distributor model comparing concentrated buying with a balanced replenishment mix.",
  },
  {
    label: "Days inventory outstanding",
    metric: "243 to 122",
    headline: "inventory days in the same illustrative model",
    note: "Shows how reducing slow-moving overstock can improve capital rotation and reorder timing.",
  },
  {
    label: "GMROI effect",
    metric: "0.5x to 1.0x",
    headline: "gross margin return on inventory in the same model",
    note: "Illustrates how healthier SKU balance can make the same inventory budget more productive.",
  },
];

const categories = [
  {
    title: "RFQ-Driven Sourcing",
    tag: "Step 1-2",
    desc:
      "Buyers send RFQs with OE numbers, vehicle models, part lists, photos, quantities, and destination details. We structure the request before supplier outreach starts.",
    bullets: ["RFQ intake and clarification", "Part lists, OE numbers, and vehicle data", "Built for importers, distributors, and wholesalers"],
    href: "/contact",
    img: "/images/Brake-System.png",
  },
  {
    title: "Product & Technical Matching",
    tag: "Step 3",
    desc:
      "Before quotation, part matching is checked against OE references, EPC logic, vehicle platform information, and available technical details to reduce mismatch risk.",
    bullets: ["OE and part-number review", "EPC and vehicle-platform matching", "Fitment checked before pricing"],
    href: "/contact",
    img: "/images/Suspension.png",
  },
  {
    title: "Supplier Sourcing",
    tag: "Step 4",
    desc:
      "We identify suitable suppliers by product category, production relevance, and execution fit, with heavy-duty truck parts as a deeper strength while also supporting light- and medium-duty platforms.",
    bullets: ["Factories selected by category fit", "Heavy-duty depth with broader truck coverage", "Focus on execution capability, not just catalog match"],
    href: "/contact",
    img: "/images/Engine-Parts.png",
  },
].map((item) => ({
  ...item,
  ...getImageDimensions(item.img),
}));

const processCards = [
  {
    t: "Supplier Comparison",
    p: "Supplier options are compared on price, MOQ, lead time, technical fit, and execution reliability instead of simply forwarding whichever quote arrives first.",
  },
  {
    t: "Quotation Consolidation",
    p: "Multiple supplier quotations can be aligned into one clearer response with unified currency, Incoterms, validity, and item structure for easier review.",
  },
  {
    t: "Order Coordination",
    p: "After order confirmation, production follow-up, QC checkpoints, and document review are tracked so the buyer can see how the RFQ moves into execution.",
  },
];

const popularBrandQueries = [
  "Heavy-duty truck parts",
  "Light-duty truck parts",
  "Medium-duty truck parts",
  "OE number RFQ",
  "Supplier comparison",
  "Quotation consolidation",
];

const faq = [
  {
    q: "Do you provide a full product catalogue?",
    a: "The process is RFQ-first because technical matching and supplier comparison are more important than showing a broad catalogue. Send OE numbers, vehicle data, part lists, or photos and we will structure the request.",
  },
  {
    q: "Can you help us optimize a mixed-SKU container instead of quoting one line only?",
    a: "Yes. This is one of the main commercial advantages of the model. We can review the SKU mix, supplier options, and shipment structure so the order supports both lower landed cost and a healthier inventory position.",
  },
  {
    q: "Can you handle private label packaging?",
    a: "Yes. Share carton marks, label or barcode format, and any packaging requirements. These details can be checked during packing review before shipment.",
  },
  {
    q: "What information helps you quote faster?",
    a: "OE or part numbers, vehicle brand and model, quantities, destination, target Incoterms, and any technical or packaging notes help the RFQ move faster and with fewer clarifications.",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Commercial Vehicle Parts Sourcing from China",
    description:
      "Commercial vehicle sourcing support for aftermarket buyers, combining supplier comparison, container consolidation, balanced multi-SKU planning, and delivery coordination.",
    url: "https://certispares.com/sourcing/",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.a,
      },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://certispares.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Sourcing",
        item: "https://certispares.com/sourcing/",
      },
    ],
  },
];
---

<BaseLayout
  title="Commercial Vehicle Parts Sourcing | Lower Shipping Cost and Better Inventory Turnover"
  description="Commercial vehicle aftermarket sourcing from China for B2B buyers, combining multi-supplier container consolidation, balanced multi-SKU sourcing, supplier comparison, and execution control."
  keywords={["truck spare parts", "heavy duty truck parts", "container consolidation", "inventory turnover sourcing", "commercial vehicle spare parts"]}
  canonical="/sourcing/"
  ogImage="/images/Brake-System.png"
  jsonLd={jsonLd}
>
  <style>
    :root{
      --bg:#eef3f7;
      --text:#1d2a36;
      --muted:#5f6d86;
      --line:rgba(29,42,54,.10);
      --brand:#3957E9;
      --brand2:#3957E9;
    }

    :global(main){ background:transparent; }

    :global(.topbar){
      background:#111F43 !important;
      background-color:#111F43 !important;
      opacity:1 !important;
      backdrop-filter:none !important;
      -webkit-backdrop-filter:none !important;
      border-bottom:1px solid #111F43 !important;
      box-shadow:none !important;
    }

    :global(.menu),
    :global(.menu a),
    :global(.menu a:hover){
      color:#fff;
    }

    :global(.menu a.active),
    :global(.drawerNav a.active){
      color:#fff;
      background:rgba(57,87,233,.18);
      border-color:rgba(57,87,233,.32);
    }

    :global(.cta){
      background:#3957E9;
      color:#fff;
    }

    .sectionTitle{ font-size:22px; margin:0 0 10px; letter-spacing:-.2px; color:#1d2a36; }
    .sectionDesc{ margin:0 0 16px; color:var(--muted); line-height:1.75; max-width:980px; }
    .sectionHead{
      display:flex;
      align-items:baseline;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:10px;
    }
    .sectionHead .sectionTitle{ margin:0; }
    .sectionJump{
      color:#3957E9;
      font-size:14px;
      font-weight:700;
      text-decoration:none;
      white-space:nowrap;
    }
    .sectionJump:hover{
      text-decoration:underline;
      text-underline-offset:3px;
    }

    .pageHero{
      position:relative;
      overflow:hidden;
      border-bottom:1px solid var(--line);
      background:
        linear-gradient(180deg, rgba(11,16,32,.34) 0%, rgba(11,16,32,.82) 72%, rgba(11,16,32,1) 100%),
        radial-gradient(900px 420px at 25% 20%, rgba(57,87,233,.22), transparent 60%),
        #0b1020;
    }

    .pageHero::before{
      content:"";
      position:absolute; inset:-120px -120px -120px -120px;
      pointer-events:none;
      background:
        radial-gradient(900px 420px at 18% 10%, rgba(47,91,255,.12), transparent 60%),
        radial-gradient(900px 420px at 78% 18%, rgba(47,91,255,.08), transparent 62%),
        linear-gradient(to right, rgba(255,255,255,.045) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255,255,255,.035) 1px, transparent 1px);
      background-size:auto, auto, 64px 64px, 64px 64px;
      opacity:.22;
      filter:blur(.2px);
    }

    .heroInner{
      position:relative;
      padding-top:2px;
      padding-bottom:22px;
    }

    .contentSection{
      background:linear-gradient(180deg, #f5f8fc 0%, #eef3f7 100%);
    }

    .kicker{
      letter-spacing:.12em;
      text-transform:uppercase;
      font-size:.8rem;
      opacity:.82;
      margin:0 0 .75rem;
      color:#fff;
    }

    .title{
      margin:0 0 .8rem;
      font-size:40px;
      letter-spacing:-.4px;
      line-height:1.12;
      color:#fff;
    }

    .sub{
      margin:0;
      max-width:78ch;
      color:rgba(225,233,255,.86);
      line-height:1.75;
    }

    .pillRow{ display:flex; gap:10px; flex-wrap:wrap; margin-top:12px; }
    .pill{
      background:rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.14);
      border-radius:999px;
      padding:8px 12px;
      color:#fff;
      font-weight:800;
      font-size:12px;
    }

    .chipRow{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:14px;
    }

    .chip{
      padding:8px 12px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:rgba(255,255,255,.08);
      font-size:12px;
      font-weight:800;
      color:#fff;
    }

    .grid3{ display:grid; grid-template-columns: repeat(3, 1fr); gap:14px; }
    .grid2{ display:grid; grid-template-columns: repeat(2, 1fr); gap:14px; }
    .benchmarkGrid{ display:grid; grid-template-columns: repeat(2, 1fr); gap:14px; }

    .card,
    .infoCard{
      background:#fff;
      border:1px solid rgba(29,42,54,.10);
      border-radius:18px;
      padding:18px;
      box-shadow:0 14px 32px rgba(24,39,56,.05);
    }

    .card b,
    .infoCard b{
      display:block;
      margin-bottom:8px;
      color:#1d2a36;
    }

    .card p,
    .infoCard p{
      margin:0;
      color:var(--muted);
      line-height:1.7;
    }

    .benchmarkCard{
      display:flex;
      flex-direction:column;
      gap:10px;
    }

    .benchmarkLabel{
      font-size:12px;
      line-height:1;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
      color:#5f6d86;
    }

    .benchmarkMetric{
      font-size:34px;
      line-height:1;
      letter-spacing:-.04em;
      font-weight:900;
      color:#1d2a36;
    }

    .benchmarkHeadline{
      margin:0;
      color:#1d2a36;
      font-size:16px;
      line-height:1.6;
      font-weight:700;
    }

    .benchmarkNote{
      margin:0;
      color:var(--muted);
      font-size:13px;
      line-height:1.65;
    }

    .visualCard{
      position:relative;
      overflow:hidden;
      min-height:280px;
      border:1px solid rgba(255,255,255,.10);
      box-shadow:0 16px 36px rgba(17,31,67,.10);
      background:#0f172a;
    }

    .visualCard::before{
      content:"";
      position:absolute;
      inset:0;
      background-image:var(--card-bg);
      background-position:center;
      background-size:cover;
      background-repeat:no-repeat;
      transform:scale(1.03);
      z-index:0;
    }

    .visualCard::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg, rgba(8,14,30,.22) 0%, rgba(8,14,30,.72) 58%, rgba(8,14,30,.92) 100%),
        radial-gradient(900px 420px at 20% 16%, rgba(57,87,233,.22), transparent 60%);
      z-index:1;
    }

    .visualCard > *{
      position:relative;
      z-index:2;
    }

    .visualCard b,
    .visualCard p,
    .visualCard .bulletItem,
    .visualCard .sectionLabel{
      color:#fff;
    }

    .visualCard p{
      color:rgba(234,240,255,.86);
    }

    .visualCard .bulletItem{
      color:rgba(234,240,255,.88);
    }

    .visualCard .dot{
      background:rgba(255,255,255,.86);
    }

    .visualCard .sectionLabel{
      display:inline-flex;
      align-items:center;
      margin-bottom:12px;
      padding:6px 10px;
      border-radius:999px;
      background:rgba(17,26,51,.52);
      border:1px solid rgba(255,255,255,.12);
      font-size:12px;
      font-weight:900;
      letter-spacing:.04em;
      text-transform:uppercase;
    }

    .advantageCard{
      display:flex;
      flex-direction:column;
      gap:12px;
    }

    .bulletList,
    .catList{
      margin:0;
      padding:0;
      list-style:none;
      display:grid;
      gap:8px;
    }

    .bulletItem,
    .catLi{
      display:flex;
      gap:10px;
      align-items:flex-start;
      color:var(--muted);
      line-height:1.6;
    }

    .compareWrap{
      border-radius:18px;
      padding:18px;
      background:linear-gradient(135deg, rgba(57,87,233,.08), rgba(255,255,255,.96));
      border:1px solid rgba(57,87,233,.16);
      box-shadow:0 16px 40px rgba(24,39,56,.05);
    }

    .catGrid{
      margin-top:12px;
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap:14px;
    }

    .catCard{
      position:relative;
      border-radius:18px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.02);
      min-height:308px;
      display:flex;
      flex-direction:column;
      justify-content:flex-end;
      isolation:isolate;
    }

    .catCard img{
      position:absolute; inset:0;
      width:100%; height:100%;
      object-fit:cover;
      display:block;
      filter:saturate(1.02) contrast(1.02) brightness(.99);
      transform:scale(1.02);
      z-index:-2;
    }

    .catShade{
      position:absolute; inset:0;
      z-index:-1;
      background:
        linear-gradient(to top, rgba(6,16,42,.94), rgba(6,16,42,.28) 58%, rgba(6,16,42,.10)),
        radial-gradient(900px 420px at 25% 20%, rgba(57,87,233,.16), transparent 60%);
    }

    .catInner{ padding:16px; }

    .catTag{
      display:inline-flex;
      align-items:center;
      gap:8px;
      font-size:12px;
      font-weight:900;
      color:#fff;
      margin-bottom:10px;
      padding:6px 10px;
      border-radius:999px;
      background:rgba(17,26,51,.62);
      border:1px solid rgba(255,255,255,.10);
      backdrop-filter: blur(6px);
    }

    .catTitle{
      margin:0 0 8px;
      font-size:16px;
      font-weight:950;
      letter-spacing:-.15px;
      color:#fff;
    }

    .catDesc{
      margin:0 0 12px;
      font-size:12px;
      line-height:1.65;
      color:rgba(255,255,255,.88);
      max-width:520px;
    }

    .dot{
      width:10px;
      height:10px;
      border-radius:999px;
      margin-top:6px;
      background:#4A5462;
      flex:0 0 10px;
    }

    .catCtaRow{ margin-top:12px; display:flex; gap:10px; flex-wrap:wrap; }
    .catCtaRow .btn.primary,
    .ctaBlock .btn.primary{
      color:#fff;
      background:#3957E9;
    }

    .catCtaRow .btn:not(.primary){
      color:#fff;
      background:#3957E9;
      border-color:#3957E9;
    }

    .catLi{
      color:rgba(255,255,255,.9);
    }

    .catLi .dot{
      background:rgba(255,255,255,.88);
    }

    .faq{
      background:#fff;
      border:1px solid rgba(29,42,54,.10);
      border-radius:18px;
      padding:18px;
      box-shadow:0 14px 32px rgba(24,39,56,.05);
    }

    .faqItem{ padding:12px 0; border-top:1px solid rgba(29,42,54,.10); }
    .faqItem:first-child{ border-top:0; padding-top:0; }
    .faqQ{ margin:0 0 6px; font-weight:950; letter-spacing:-.1px; color:#1d2a36; }
    .faqA{ margin:0; color:var(--muted); line-height:1.7; }

    .ctaBlock{
      margin-top:14px;
      border-radius:18px;
      padding:18px;
      background:linear-gradient(135deg, rgba(57,87,233,.10), rgba(255,255,255,.92));
      border:1px solid rgba(57,87,233,.16);
      display:flex; justify-content:space-between; align-items:center; gap:14px;
      box-shadow:0 16px 40px rgba(24,39,56,.05);
    }

    .ctaBlock .left b{ display:block; margin-bottom:6px; color:#1d2a36; }
    .ctaBlock .left p{ margin:0; color:var(--muted); line-height:1.75; max-width:760px; }

    :global(.footerWrap){
      background:transparent;
      border-top:1px solid var(--site-line);
    }

    :global(.footerTitle),
    :global(.footerNav strong){
      color:rgba(234,240,255,.94);
    }

    :global(.footer),
    :global(.footerNav span){
      color:var(--site-muted);
    }

    :global(.footerNav a){
      background:rgba(255,255,255,.03);
      border-color:var(--site-line);
    }

    @media (max-width: 980px){
      .grid3{ grid-template-columns:1fr; }
      .grid2{ grid-template-columns:1fr; }
      .benchmarkGrid{ grid-template-columns:1fr; }
      .catGrid{ grid-template-columns:1fr; }
      .ctaBlock{ flex-direction:column; align-items:flex-start; }
      .catCard{ min-height:300px; }
      .heroInner{ padding-top:18px; padding-bottom:18px; }
    }
  </style>

  <header class="pageHero">
    <div class="container heroInner">
      <p class="kicker">CertiSpares / Sourcing Strategy</p>
      <h1 class="title">Commercial Vehicle Parts Sourcing from China</h1>
      <p class="sub">
        For buyers managing multiple SKUs, the stronger sourcing model is often the one that combines supplier coordination, balanced order planning, and container consolidation. That helps reduce landed cost, improve inventory turnover, and support healthier reorder cycles.
      </p>

      <div class="pillRow">
        <div class="pill">Multi-supplier container consolidation</div>
        <div class="pill">Balanced multi-SKU sourcing</div>
        <div class="pill">Lower landed cost</div>
        <div class="pill">Better inventory structure</div>
        <div class="pill">Repeat-order efficiency</div>
      </div>
      <div class="chipRow" aria-label="Popular sourcing themes">
        {popularBrandQueries.map((query) => (
          <span class="chip">{query}</span>
        ))}
      </div>
    </div>
  </header>

  <section class="contentSection">
    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">Why the Traditional Buying Pattern Creates Friction</h2>
        <p class="sectionDesc">
          Many aftermarket buyers do not need one full container of a single product line at one time. But if they buy vertically from only one supplier, they often face a difficult trade-off between shipping efficiency and healthy inventory levels.
        </p>

        <div class="grid3">
          {problemCards.map((item) => (
            <div class="card visualCard" style={`--card-bg: url('${item.image}')`}>
              <span class="sectionLabel">Buying friction</span>
              <b>{item.title}</b>
              <p>{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">The Two Strategic Advantages</h2>
        <p class="sectionDesc">
          The commercial advantage comes from how the order is built before shipment: the supplier mix, the SKU mix, and the loading plan all affect cost, turnover, and the quality of the next reorder cycle.
        </p>

        <div class="grid2">
          {strategyCards.map((item) => (
            <div class="card visualCard advantageCard" style={`--card-bg: url('${item.image}')`}>
              <span class="sectionLabel">Strategic advantage</span>
              <div>
                <b>{item.title}</b>
                <p>{item.desc}</p>
              </div>

              <ul class="bulletList">
                {item.points.map((point) => (
                  <li class="bulletItem"><span class="dot"></span><span>{point}</span></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="sectionHead">
          <h2 class="sectionTitle">Benchmark Snapshot</h2>
          <a class="sectionJump" href="/blog/how-container-consolidation-improves-cost-and-inventory-turnover">Read the full analysis &rarr;</a>
        </div>
        <p class="sectionDesc">
          The strategy is supported by two benchmark views: an indicative freight model based on public April 2026 lane references, and an illustrative distributor model comparing concentrated buying with balanced multi-SKU replenishment.
        </p>

        <div class="benchmarkGrid">
          {benchmarkCards.map((item) => (
            <div class="infoCard benchmarkCard">
              <div class="benchmarkLabel">{item.label}</div>
              <div class="benchmarkMetric">{item.metric}</div>
              <p class="benchmarkHeadline">{item.headline}</p>
              <p class="benchmarkNote">{item.note}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="compareWrap">
          <h2 class="sectionTitle">Single-Line Buying vs. Balanced Container Logic</h2>
          <p class="sectionDesc">
            The difference is practical. When container planning follows real SKU demand instead of one supplier's volume, buyers can protect both freight efficiency and stock movement.
          </p>

          <div class="grid2">
            {comparisonCards.map((item) => (
              <div class="card visualCard advantageCard" style={`--card-bg: url('${item.image}')`}>
                <span class="sectionLabel">Sourcing logic</span>
                <div>
                  <b>{item.title}</b>
                </div>

                <ul class="bulletList">
                  {item.bullets.map((bullet) => (
                    <li class="bulletItem"><span class="dot"></span><span>{bullet}</span></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">What Buyers Gain with the Same Budget</h2>
        <p class="sectionDesc">
          The goal is not simply to move cargo. The goal is to turn the same purchasing budget into a more productive inventory position and a stronger follow-up order pattern.
        </p>

        <div class="grid3">
          {outcomeCards.map((item) => (
            <div class="infoCard">
              <b>{item.t}</b>
              <p>{item.p}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">How the Sourcing Process Works in Practice</h2>
        <p class="sectionDesc">
          The strategy only performs when execution is disciplined. RFQ clarification, technical matching, supplier comparison, QC, and shipment coordination are what turn the sourcing logic into a workable commercial result.
        </p>

        <div class="catGrid">
          {categories.map((c) => (
            <div class="catCard">
              <img
                src={c.img}
                alt={c.title}
                loading="lazy"
                decoding="async"
                width={c.width}
                height={c.height}
              />
              <div class="catShade"></div>

              <div class="catInner">
                <div class="catTag">{c.tag}</div>
                <h3 class="catTitle">{c.title}</h3>
                <p class="catDesc">{c.desc}</p>

                <ul class="catList">
                  {c.bullets.map((b) => (
                    <li class="catLi"><span class="dot"></span><span>{b}</span></li>
                  ))}
                </ul>

                <div class="catCtaRow">
                  <a class="btn primary" href={c.href}>Send RFQ</a>
                  <a class="btn" href="/how-it-works">See workflow</a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">Execution Control After Supplier Selection</h2>
        <p class="sectionDesc">
          After supplier sourcing, the next stages are quotation alignment, order coordination, and shipment control, so the commercial logic is carried through into execution.
        </p>

        <div class="grid3">
          {processCards.map((item) => (
            <div class="infoCard">
              <b>{item.t}</b>
              <p>{item.p}</p>
            </div>
          ))}
        </div>

        <div class="ctaBlock">
          <div class="left">
            <b>Need a sourcing plan built around container efficiency and stock turnover?</b>
            <p>
              Send your RFQ with SKU list, OE or part numbers, quantities, destination, and packaging requirements. We can review the sourcing scope and reply with a practical plan for supplier comparison, consolidation, and balanced order planning.
            </p>
          </div>
          <div class="right">
            <a class="btn primary" href="/contact">Contact &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">FAQ</h2>
        <p class="sectionDesc">Quick answers for buyers who want a clearer view of how the sourcing model is handled.</p>

        <div class="faq">
          {faq.map((x) => (
            <div class="faqItem">
              <p class="faqQ">{x.q}</p>
              <p class="faqA">{x.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
