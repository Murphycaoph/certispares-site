---
import BaseLayout from "../layouts/BaseLayout.astro";

const categories = [
  {
    title: "Brake & Wheel-End Parts",
    tag: "Core category",
    desc:
      "Brake pads, brake drums, discs, chambers, slack adjusters, hubs, bearings, and repair kits organized for heavy duty truck spare parts sourcing.",
    bullets: ["Brake drums and brake pads", "Packaging and labeling checks", "Consolidation-friendly"],
    href: "/contact",
    img: "/images/Brake-System.png",
  },
  {
    title: "Suspension & Steering Parts",
    tag: "Core category",
    desc:
      "Leaf springs, torque rods, stabilizer bars, bushings, shock absorbers, and steering-related parts focused on durability and fitment clarity.",
    bullets: ["Leaf springs and torque rods", "QC checkpoints", "Photo and video evidence"],
    href: "/contact",
    img: "/images/Suspension.png",
  },
  {
    title: "Engine & Service Parts",
    tag: "Core category",
    desc:
      "Filters, belts, gaskets, water pumps, turbo-related parts, electrical items, and common service parts supported with export documentation clarity.",
    bullets: ["Filters and water pumps", "PI/CI/PL review", "Shipment coordination"],
    href: "/contact",
    img: "/images/Engine-Parts.png",
  },
];

const searchIntentCards = [
  {
    t: "Brand + parts searches",
    p: "Overseas buyers often search by truck brand first, such as Sinotruk HOWO parts, SHACMAN parts, Foton parts, Dongfeng truck parts, FAW truck parts, and JAC parts.",
  },
  {
    t: "Category + application searches",
    p: "Common query patterns include brake drums, brake pads, slack adjusters, leaf springs, torque rods, wheel-end parts, filters, and water pumps.",
  },
  {
    t: "OEM and part-number RFQs",
    p: "A large share of serious buyer searches start with OEM numbers, old supplier part numbers, or photo-led RFQs when the English part name is unclear.",
  },
];

const popularBrandQueries = [
  "Sinotruk HOWO parts",
  "Shacman parts",
  "Foton truck parts",
  "Dongfeng truck parts",
  "FAW truck parts",
  "JAC truck parts",
];

const valueCards = [
  {
    t: "We are not a factory",
    p: "We organize supplier networks and verification steps. Production remains with qualified manufacturers.",
  },
  {
    t: "Audit-style risk control",
    p: "We compare suppliers, lock key specs, and reduce mismatch risk with structured checks and evidence.",
  },
  {
    t: "Built for consolidation",
    p: "Combine multiple categories into one shipment with a clear packing list, labels, and carton marks.",
  },
];

const faq = [
  {
    q: "Do you provide a full product catalogue?",
    a: "We keep category coverage clear, but we operate RFQ-first for accuracy. Send OEM/brand/model/photos and quantity; we respond with verified options.",
  },
  {
    q: "Can you handle private label packaging?",
    a: "Yes. Share carton marks, label/barcode format, and any requirements. We verify packaging and labels before shipment.",
  },
  {
    q: "What information helps you quote faster?",
    a: "OEM/part numbers (or photos), vehicle brand/model/year if available, target quantity, destination/port, and your preferred Incoterms.",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Truck Spare Parts Categories from China",
    description:
      "Truck spare parts categories from China, including brake, wheel-end, suspension, steering, engine, and service parts for heavy duty and commercial vehicle buyers.",
    url: "https://certispares.com/sourcing/",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.a,
      },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://certispares.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Sourcing",
        item: "https://certispares.com/sourcing/",
      },
    ],
  },
];
---

<BaseLayout
  title="Truck Spare Parts Categories | Heavy Duty & Commercial Vehicle Parts"
  description="Truck spare parts categories from China for heavy duty and commercial vehicle aftermarket buyers, including brake, wheel-end, suspension, steering, engine, and service parts with QC and export support."
  keywords={["truck spare parts", "heavy duty truck parts", "aftermarket truck parts from China", "Sinotruk parts supplier", "Shacman parts supplier", "commercial vehicle spare parts"]}
  canonical="/sourcing/"
  ogImage="/images/Brake-System.png"
  jsonLd={jsonLd}
>
  <style>
    :root{
      --bg:#eef3f7;
      --text:#1d2a36;
      --muted:#5f6d86;
      --line:rgba(29,42,54,.10);
      --brand:#3957E9;
      --brand2:#3957E9;
    }

    :global(main){
      background:transparent;
    }

    :global(.topbar){
      background:#111F43 !important;
      background-color:#111F43 !important;
      opacity:1 !important;
      backdrop-filter:none !important;
      -webkit-backdrop-filter:none !important;
      border-bottom:1px solid #111F43 !important;
      box-shadow:none !important;
    }

    :global(.menu){
      color:#fff;
    }

    :global(.menu a){
      color:#fff;
    }

    :global(.menu a:hover){
      color:#fff;
    }

    :global(.menu a.active){
      color:#fff;
      background:rgba(57,87,233,.18);
      border-color:rgba(57,87,233,.32);
    }

    :global(.drawerNav a.active){
      color:#fff;
      background:rgba(57,87,233,.18);
      border-color:rgba(57,87,233,.32);
    }

    :global(.cta){
      background:#3957E9;
      color:#fff;
    }

    .sectionTitle{ font-size:22px; margin:0 0 10px; letter-spacing:-.2px; color:#1d2a36; }
    .sectionDesc{ margin:0 0 16px; color:var(--muted); line-height:1.7; max-width:980px; }

    /* --- HERO tightening + subtle blueprint/grid background --- */
    .pageHero{
      position:relative;
      overflow:hidden;
      border-bottom:1px solid var(--line);
      background:
        linear-gradient(180deg, rgba(11,16,32,.34) 0%, rgba(11,16,32,.82) 72%, rgba(11,16,32,1) 100%),
        radial-gradient(900px 420px at 25% 20%, rgba(57,87,233,.22), transparent 60%),
        #0b1020;
    }
    .pageHero::before{
      content:"";
      position:absolute; inset:-120px -120px -120px -120px;
      pointer-events:none;
      /* very subtle "industrial blueprint" vibe (no images, just gradients) */
      background:
        radial-gradient(900px 420px at 18% 10%, rgba(47,91,255,.12), transparent 60%),
        radial-gradient(900px 420px at 78% 18%, rgba(47,91,255,.08), transparent 62%),
        /* faint grid */
        linear-gradient(to right, rgba(255,255,255,.045) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255,255,255,.035) 1px, transparent 1px);
      background-size:
        auto,
        auto,
        64px 64px,
        64px 64px;
      opacity:.22;
      filter: blur(.2px);
    }

    .heroInner{
      position:relative;
      padding-top: 2px;  /* tighter */
      padding-bottom: 22px; /* tighter */
    }

    .contentSection{
      background:linear-gradient(180deg, #f5f8fc 0%, #eef3f7 100%);
    }

    .kicker{
      letter-spacing:.12em;
      text-transform:uppercase;
      font-size:.8rem;
      opacity:.82;
      margin:0 0 .75rem;
      color:#fff;
    }

    .title{
      margin:0 0 .8rem;
      font-size:40px;
      letter-spacing:-.4px;
      line-height:1.12;
      color:#fff;
    }

    .sub{
      margin:0;
      max-width:78ch;
      color:rgba(225,233,255,.86);
      line-height:1.75;
    }

    .pillRow{ display:flex; gap:10px; flex-wrap:wrap; margin-top:12px; } /* tighter */
    .pill{
      background:rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.14);
      border-radius:999px;
      padding:8px 12px;
      color:#fff;
      font-weight:800;
      font-size:12px;
    }
    .chipRow{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:14px;
    }
    .chip{
      padding:8px 12px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:rgba(255,255,255,.08);
      font-size:12px;
      font-weight:800;
      color:#fff;
    }

    /* --- Section divider label (solves 鈥渆mpty background鈥?feeling without repeating Core category) --- */
    .grid3{ display:grid; grid-template-columns: repeat(3, 1fr); gap:14px; }

    /* Category cards */
    .catGrid{
      margin-top:12px; /* tighter */
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap:14px;
    }

    .catCard{
      position:relative;
      border-radius:18px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.02);
      min-height: 308px; /* slightly shorter */
      display:flex;
      flex-direction:column;
      justify-content:flex-end;
      isolation:isolate;
    }
    .catCard img{
      position:absolute; inset:0;
      width:100%; height:100%;
      object-fit:cover;
      display:block;
      filter:saturate(1.02) contrast(1.02) brightness(.99);
      transform: scale(1.02);
      z-index:-2;
    }
    .catShade{
      position:absolute; inset:0;
      z-index:-1;
      background:
        linear-gradient(to top, rgba(6,16,42,.94), rgba(6,16,42,.28) 58%, rgba(6,16,42,.10)),
        radial-gradient(900px 420px at 25% 20%, rgba(57,87,233,.16), transparent 60%);
    }

    .catInner{ padding:16px; }

    .catTag{
      display:inline-flex;
      align-items:center;
      gap:8px;
      font-size:12px;
      font-weight:900;
      color:#fff;
      margin-bottom:10px;
      padding:6px 10px;
      border-radius:999px;
      background:rgba(17,26,51,.62);
      border:1px solid rgba(255,255,255,.10);
      backdrop-filter: blur(6px);
    }
    .catTitle{
      margin:0 0 8px;
      font-size:16px;
      font-weight:950;
      letter-spacing:-.15px;
      color:rgba(234,240,255,.98);
    }
    .catDesc{
      margin:0 0 12px;
      font-size:12px;
      line-height:1.65;
      color:rgba(234,240,255,.82);
      max-width: 520px;
    }
    .catList{
      margin:0;
      padding:0;
      list-style:none;
      display:grid;
      gap:8px;
    }
    .catLi{
      display:flex;
      gap:10px;
      align-items:flex-start;
      color:rgba(234,240,255,.86);
      font-size:12px;
      line-height:1.5;
    }
    .dot{
      width:10px; height:10px; border-radius:999px; margin-top:6px;
      background:#4A5462;
      flex:0 0 10px;
    }

    .catCtaRow{ margin-top:12px; display:flex; gap:10px; flex-wrap:wrap; }
    .catCtaRow a{ text-decoration:none; }
    .catCtaRow .btn.primary{
      color:#fff;
      background:#3957E9;
    }
    .catCtaRow .btn:not(.primary){
      color:#fff;
      background:#3957E9;
      border-color:#3957E9;
    }

    .infoCard{
      background:#fff;
      border:1px solid rgba(29,42,54,.10);
      border-radius:18px;
      padding:18px;
      box-shadow:0 14px 32px rgba(24,39,56,.05);
    }
    .infoCard b{ display:block; margin-bottom:8px; color:#1d2a36; }
    .infoCard p{ margin:0; color:var(--muted); line-height:1.7; }

    .faq{
      background:#fff;
      border:1px solid rgba(29,42,54,.10);
      border-radius:18px;
      padding:18px;
      box-shadow:0 14px 32px rgba(24,39,56,.05);
    }
    .faqItem{ padding:12px 0; border-top:1px solid rgba(29,42,54,.10); }
    .faqItem:first-child{ border-top:0; padding-top:0; }
    .faqQ{ margin:0 0 6px; font-weight:950; letter-spacing:-.1px; color:#1d2a36; }
    .faqA{ margin:0; color:var(--muted); line-height:1.7; }

    .ctaBlock{
      margin-top:14px;
      border-radius:18px;
      padding:18px;
      background:linear-gradient(135deg, rgba(57,87,233,.10), rgba(255,255,255,.92));
      border:1px solid rgba(57,87,233,.16);
      display:flex; justify-content:space-between; align-items:center; gap:14px;
      box-shadow:0 16px 40px rgba(24,39,56,.05);
    }
    .ctaBlock .left b{ display:block; margin-bottom:6px; color:#1d2a36; }
    .ctaBlock .left p{ margin:0; color:var(--muted); line-height:1.7; max-width:760px; }
    .ctaBlock .btn.primary{
      color:#fff;
      background:#3957E9;
    }

    :global(.footerWrap){
      background:linear-gradient(180deg, #f5f8fc 0%, #eef3f7 100%);
      border-top:1px solid rgba(29,42,54,.10);
    }

    :global(.footerTitle),
    :global(.footerNav strong){
      color:#1d2a36;
    }

    :global(.footer),
    :global(.footerNav span){
      color:var(--muted);
    }

    :global(.footerNav a){
      background:#fff;
      border-color:rgba(29,42,54,.10);
    }

    @media (max-width: 980px){
      .catGrid{ grid-template-columns:1fr; }
      .grid3{ grid-template-columns:1fr; }
      .ctaBlock{ flex-direction:column; align-items:flex-start; }
      .catCard{ min-height: 300px; }
      .heroInner{ padding-top: 18px; padding-bottom: 18px; }
    }
  </style>

  <header class="pageHero">
    <div class="container heroInner">
      <p class="kicker">CertiSpares / Sourcing</p>
      <h1 class="title">Truck Spare Parts Categories from China</h1>
      <p class="sub">
        We consolidate heavy duty truck parts and commercial vehicle spare parts across core categories designed for
        predictable delivery, clear documentation, and audit-style risk control.
      </p>

      <div class="pillRow">
        <div class="pill">Heavy duty truck parts</div>
        <div class="pill">Truck spare parts</div>
        <div class="pill">Supplier comparison</div>
        <div class="pill">QC checkpoints</div>
        <div class="pill">Packaging & labeling</div>
        <div class="pill">Export paperwork</div>
      </div>
      <div class="chipRow" aria-label="Popular brand searches">
        {popularBrandQueries.map((query) => (
          <span class="chip">{query}</span>
        ))}
      </div>

    </div>
  </header>

  <section class="contentSection">
    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">Browse by category</h2>
        <p class="sectionDesc">
          Core truck spare parts categories arranged for RFQ clarity, supplier comparison, and consolidation planning.
        </p>

        <div class="catGrid">
          {categories.map((c) => (
            <div class="catCard">
              <img src={c.img} alt={c.title} loading="lazy" />
              <div class="catShade"></div>

              <div class="catInner">
                <div class="catTag">{c.tag}</div>
                <h3 class="catTitle">{c.title}</h3>
                <p class="catDesc">{c.desc}</p>

                <ul class="catList">
                  {c.bullets.map((b) => (
                    <li class="catLi"><span class="dot"></span><span>{b}</span></li>
                  ))}
                </ul>

                <div class="catCtaRow">
                  <a class="btn primary" href={c.href}>Request Quote</a>
                  <a class="btn" href="/capabilities">See how we control risk</a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">How buyers usually search</h2>
        <p class="sectionDesc">
          In overseas B2B search, buyers usually enter brand-led, category-led, or OEM-number-led queries rather than
          only broad phrases like commercial vehicle parts.
        </p>

        <div class="grid3">
          {searchIntentCards.map((item) => (
            <div class="infoCard">
              <b>{item.t}</b>
              <p>{item.p}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">What this page means</h2>
        <p class="sectionDesc">
          These category pages stay intentionally simple: clear coverage + structured execution.
          If you need specific items, send an RFQ and we'll respond with verified options.
        </p>

        <div class="grid3">
          {valueCards.map((x) => (
            <div class="infoCard">
              <b>{x.t}</b>
              <p>{x.p}</p>
            </div>
          ))}
        </div>

        <div class="ctaBlock">
          <div class="left">
            <b>Have an RFQ?</b>
            <p>
              Send OEM/brand/model or photos, target quantity, destination/port, and packaging needs.
              We'll reply with supplier options, lead time, and risk notes.
            </p>
          </div>
          <div class="right">
            <a class="btn primary" href="/contact">Contact &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">FAQ</h2>
        <p class="sectionDesc">Quick answers for buyers who want clarity before sending an RFQ.</p>

        <div class="faq">
          {faq.map((x) => (
            <div class="faqItem">
              <p class="faqQ">{x.q}</p>
              <p class="faqA">{x.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </section>
</BaseLayout>


