---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const SITE_URL = "https://certispares.com";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((p) => ({
    params: { slug: p.slug },
  }));
}

const allPosts = await getCollection("blog");
allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const post = allPosts.find((p) => p.slug === Astro.params.slug);

if (!post) {
  throw new Error(`Post not found for slug: ${Astro.params.slug}`);
}

const estimateReadTime = (text = "") => {
  const words = text.trim().split(/\s+/).filter(Boolean).length;
  const mins = Math.max(1, Math.round(words / 220));
  return `${mins} min read`;
};

const { Content } = await post.render();

const toAbsoluteUrl = (value) => new URL(value, SITE_URL).toString();

const title = post.data.title;
const description =
  post.data.meta_description ||
  post.data.excerpt ||
  "CertiSpares Insights";

const tag = post.data.tag || "Insights";
const date = post.data.date;
const updatedDate = post.data.updatedDate || date;
const readTime =
  post.data.readTime || estimateReadTime(post.body || "");

const keywords =
  post.data.keywords?.filter(Boolean) || [
    title,
    tag,
    "China truck parts sourcing",
    "commercial vehicle parts",
    "CertiSpares",
  ];
const canonical = `/blog/${post.slug}/`;
const ogImage = post.data.ogImage || "/images/insights-hero-collage.png";
const ogImageUrl = toAbsoluteUrl(ogImage);

const relatedPosts = allPosts
  .filter((candidate) => candidate.slug !== post.slug)
  .sort((a, b) => {
    const aSameTag = (a.data.tag || "Insights") === tag ? 1 : 0;
    const bSameTag = (b.data.tag || "Insights") === tag ? 1 : 0;
    if (aSameTag !== bSameTag) return bSameTag - aSameTag;
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  })
  .slice(0, 3);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: title,
    description,
    datePublished: date,
    dateModified: updatedDate,
    image: [ogImageUrl],
    keywords,
    author: {
      "@type": "Organization",
      name: "CertiSpares",
    },
    publisher: {
      "@type": "Organization",
      name: "CertiSpares",
      logo: {
        "@type": "ImageObject",
        url: `${SITE_URL}/images/logo.webp`,
      },
    },
    mainEntityOfPage: `${SITE_URL}/blog/${post.slug}/`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: SITE_URL,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Insights",
        item: `${SITE_URL}/blog/`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: title,
        item: `${SITE_URL}/blog/${post.slug}/`,
      },
    ],
  },
];
---

<BaseLayout
  title={`${title} | CertiSpares`}
  description={description}
  keywords={keywords}
  canonical={canonical}
  ogImage={ogImage}
  jsonLd={jsonLd}
>

  <style>
    :root{
      --article-surface:#ffffff;
      --article-surface-soft:#f7fafe;
      --article-page-bg:#f3f7fb;
      --article-page-bg-end:#edf2f7;
      --article-line:rgba(29,42,54,.10);
      --article-shadow:0 14px 36px rgba(17,31,67,.06);
    }

    .contentSection{
      background:linear-gradient(180deg, #f4f8fc 0%, #eef3f7 100%);
      border-top:1px solid rgba(255,255,255,.08);
    }

    :global(.topbar){
      background:#111F43 !important;
      background-color:#111F43 !important;
      opacity:1 !important;
      backdrop-filter:none !important;
      -webkit-backdrop-filter:none !important;
      border-bottom:1px solid #111F43 !important;
      box-shadow:none !important;
    }

    :global(.menu),
    :global(.menu a),
    :global(.menu a:hover){
      color:#fff;
    }

    :global(.menu a.active),
    :global(.drawerNav a.active){
      color:#fff;
      background:rgba(57,87,233,.18);
      border-color:rgba(57,87,233,.32);
    }

    :global(.cta){
      background:#3957E9;
      color:#fff;
    }

    .hero{
      padding:38px 0 18px;
      border-bottom:1px solid rgba(255,255,255,.08);
      background:#0b1020;
    }

    .kicker{
      letter-spacing:.12em;
      text-transform:uppercase;
      font-size:.8rem;
      opacity:.82;
      margin:0 0 .65rem;
    }

    .title{
      margin:0 0 .7rem;
      font-size:38px;
      letter-spacing:-.35px;
      line-height:1.12;
    }

    .meta{
      display:flex;
      flex-wrap:wrap;
      gap:.55rem;
      align-items:center;
      font-size:.9rem;
      opacity:.92;
    }

    .tag{
      padding:.18rem .55rem;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.16);
      font-size:.8rem;
    }

    .dot{opacity:.6}

    .wrap{padding:26px 0 52px}

    .contentRail{
      max-width:1040px;
      margin:0 auto;
    }

    .article{
      max-width:none;
      margin:0;
    }

    .articleCard{
      padding:36px 42px 40px;
      border:1px solid var(--article-line);
      border-radius:30px;
      background:linear-gradient(180deg, var(--article-surface) 0%, #fbfdff 100%);
      box-shadow:var(--article-shadow);
    }

    .back{
      display:inline-flex;
      gap:.5rem;
      align-items:center;
      margin:0 0 16px;
      padding:.55rem .9rem;
      border:1px solid rgba(29,42,54,.10);
      border-radius:999px;
      background:#fff;
      color:#3957E9;
      font-weight:700;
      text-decoration:none;
      box-shadow:0 8px 20px rgba(17,31,67,.04);
    }

    .back:hover{
      border-color:rgba(57,87,233,.22);
      background:#f8fbff;
    }

    /* ===== Markdown Typography ===== */

    .content{
      color:#314156;
      font-size:1.06rem;
    }

    .content :global(h1){
      margin:0 0 1.1rem;
      color:#111F43;
      font-size:2rem;
      line-height:1.15;
      letter-spacing:-.03em;
    }

    .content :global(h2){
      margin:2.4rem 0 .85rem;
      padding-top:1.4rem;
      border-top:1px solid rgba(29,42,54,.12);
      color:#111F43;
      font-size:1.5rem;
      letter-spacing:-.25px;
      line-height:1.25;
      scroll-margin-top:90px;
    }

    .content :global(hr + h2){
      margin-top:0;
      padding-top:0;
      border-top:none;
    }

    .content :global(h3){
      margin:1.5rem 0 .6rem;
      color:#14274f;
      font-size:1.18rem;
      letter-spacing:-.15px;
      line-height:1.3;
    }

    .content :global(p){
      margin:1rem 0;
      line-height:1.9;
      color:#314156;
    }

    .content :global(ul),
    .content :global(ol){
      margin:1rem 0;
      padding-left:1.35rem;
      line-height:1.9;
      color:#314156;
    }

    .content :global(li){margin:.45rem 0}

    .content :global(strong){
      color:#111F43;
    }

    .content :global(a){
      color:#3957E9;
      text-decoration:underline;
      text-decoration-thickness:1.5px;
      text-underline-offset:3px;
    }

    .content :global(blockquote){
      margin:1.35rem 0;
      padding:1rem 1.15rem;
      border:1px solid rgba(57,87,233,.16);
      border-left:4px solid #3957E9;
      background:rgba(57,87,233,.05);
      border-radius:16px;
      color:#314156;
    }

    .content :global(hr){
      margin:2rem 0;
      border:none;
      border-top:1px solid rgba(29,42,54,.12);
    }

    .content :global(img){
      display:block;
      max-width:100%;
      margin:1.3rem auto;
      border-radius:18px;
      border:1px solid rgba(29,42,54,.08);
    }

    .content :global(table){
      width:100%;
      border-collapse:collapse;
      margin:1.2rem 0;
      overflow:hidden;
      border:1px solid rgba(29,42,54,.10);
      border-radius:16px;
      background:#fff;
    }

    .content :global(th),
    .content :global(td){
      padding:.8rem .9rem;
      border-bottom:1px solid rgba(29,42,54,.08);
      text-align:left;
      color:#314156;
    }

    .content :global(th){
      background:#f6f9fc;
      color:#111F43;
      font-weight:800;
    }

    .content :global(code){
      padding:.12rem .35rem;
      border-radius:8px;
      background:#f3f6fb;
      border:1px solid rgba(29,42,54,.10);
      color:#23408f;
      font-size:.92em;
    }

    .content :global(pre){
      padding:1rem;
      border-radius:18px;
      background:#f7f9fc;
      border:1px solid rgba(29,42,54,.10);
      overflow:auto;
    }

    .content :global(pre code){
      padding:0;
      border:none;
      background:transparent;
    }

    /* References block style */
    .content :global(h2 + ul){
      border:1px solid rgba(29,42,54,.10);
      background:#f8fbfd;
      border-radius:18px;
      padding:14px 18px;
    }

    .divider{
      max-width:none;
      margin:28px 0 0;
      border-top:1px solid rgba(29,42,54,.10);
    }

    .footerCta{
      max-width:none;
      margin:18px 0 0;
      padding:18px 20px;
      border-radius:24px;
      border:1px dashed rgba(57,87,233,.22);
      background:var(--article-surface);
      color:#314156;
      line-height:1.75;
      box-shadow:0 12px 30px rgba(17,31,67,.05);
    }

    .footerCta a{
      color:#3957E9;
      font-weight:800;
    }

    .relatedWrap{
      max-width:none;
      margin:22px 0 0;
      padding:24px;
      border:1px solid var(--article-line);
      border-radius:28px;
      background:linear-gradient(180deg, var(--article-surface) 0%, var(--article-surface-soft) 100%);
      box-shadow:var(--article-shadow);
    }

    .relatedTitle{
      margin:0 0 12px;
      color:#111F43;
      font-size:1.18rem;
      letter-spacing:-.2px;
    }

    .relatedGrid{
      display:grid;
      grid-template-columns:repeat(3, 1fr);
      gap:12px;
    }

    .relatedCard{
      display:block;
      padding:18px 18px 16px;
      border-radius:22px;
      border:1px solid rgba(29,42,54,.10);
      background:#fff;
      box-shadow:0 12px 28px rgba(17,31,67,.05);
      text-decoration:none;
      transition:transform .12s ease, background .12s ease, border-color .12s ease;
    }

    .relatedCard:hover{
      transform:translateY(-2px);
      background:#fff;
      border-color:rgba(57,87,233,.18);
    }

    .relatedMeta{
      display:flex;
      flex-wrap:wrap;
      gap:.45rem;
      align-items:center;
      font-size:.8rem;
      color:#6b7790;
      margin-bottom:10px;
    }

    .relatedCard h2{
      margin:0 0 8px;
      font-size:1.08rem;
      line-height:1.4;
      color:#3957E9;
    }

    .relatedCard p{
      margin:0;
      color:#5f6d86;
      line-height:1.65;
      font-size:.92rem;
    }

    :global(.footerWrap){
      background:transparent;
      border-top:1px solid var(--site-line);
      margin-top:0 !important;
    }

    :global(.footerTitle),
    :global(.footerNav strong){
      color:rgba(234,240,255,.94);
    }

    :global(.footer),
    :global(.footerNav span){
      color:var(--site-muted);
    }

    :global(.footerNav a){
      background:rgba(255,255,255,.03);
      border-color:var(--site-line);
    }

    @media (max-width:980px){
      .title{font-size:32px}
      .contentRail{max-width:92vw}
      .articleCard{padding:24px 22px 28px}
      .relatedWrap{padding:18px}
      .relatedGrid{grid-template-columns:1fr}
    }
  </style>

  <header class="hero">
    <div class="container">
      <p class="kicker">CertiSpares / Insights</p>
      <h1 class="title">{title}</h1>

      <div class="meta">
        <span class="tag">{tag}</span>
        <span class="dot">&middot;</span>
        <span>{date}</span>
        <span class="dot">&middot;</span>
        <span>{readTime}</span>
      </div>
    </div>
  </header>

  <section class="contentSection">
    <div class="container wrap">
      <div class="contentRail">
        <article class="article">
          <a class="back" href="/blog">&larr; Back to Insights</a>

          <div class="articleCard">
            <div class="content">
              <Content />
            </div>
          </div>
        </article>

        <div class="divider"></div>

        {relatedPosts.length > 0 && (
          <section class="relatedWrap" aria-labelledby="related-posts-title">
            <h2 class="relatedTitle" id="related-posts-title">Related insights</h2>
            <div class="relatedGrid">
              {relatedPosts.map((related) => (
                <a class="relatedCard" href={`/blog/${related.slug}`}>
                  <div class="relatedMeta">
                    <span class="tag">{related.data.tag || "Insights"}</span>
                    <span class="dot">&middot;</span>
                    <span>{related.data.date}</span>
                  </div>
                  <h2>{related.data.title}</h2>
                  <p>{related.data.excerpt || "Read the full article for sourcing, QC, and execution notes."}</p>
                </a>
              ))}
            </div>
          </section>
        )}

        <div class="footerCta">
          Need sourcing support for commercial vehicle parts?
          Send an RFQ via <a href="/contact">Contact</a> and we'll reply with a practical plan
          (lead time, packing, docs, shipping options).
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
