---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const supportedSystems = [
  "Brake system parts",
  "Suspension parts",
  "Air system parts",
  "Engine-related parts",
  "Electrical parts",
  "Cooling system parts",
];

const painPoints = [
  {
    title: "Same part name, different fitment",
    desc: "A broad part name is often not enough. Without OE number, VIN, or clear truck details, different suppliers may quote different items for the same request.",
  },
  {
    title: "Lowest price does not mean the right part",
    desc: "Some suppliers quote fast and cheap, but the part scope, quality level, or packing may not match what you actually need.",
  },
  {
    title: "Mixed orders become hard to compare",
    desc: "When brake parts, air system parts, and other items are quoted separately, it becomes harder to compare suppliers and plan one shipment.",
  },
];

const matchingInputs = [
  "OE number or part number",
  "VIN or truck model",
  "Part photos",
  "Part names and quantities",
  "Destination country or port",
  "Packing or label requirements if relevant",
];

const processSteps = [
  {
    title: "You send the inquiry",
    desc: "Share OE numbers, VIN, photos, part list, quantities, and destination details.",
  },
  {
    title: "We check the matching scope",
    desc: "We review the references first so the inquiry is clear before quotation starts.",
  },
  {
    title: "We compare workable suppliers",
    desc: "We compare quotes based on part scope, execution, and order practicality, not price alone.",
  },
  {
    title: "We move into inspection and shipping follow-up",
    desc: "After order confirmation, we continue with QC points, packing checks, documents, and shipment coordination.",
  },
];

const whyWorkWithUs = [
  {
    title: "We start from real inquiry details",
    desc: "We work from OE numbers, VIN, photos, and usable references instead of pushing buyers into a generic catalog.",
  },
  {
    title: "We compare suppliers on execution, not only price",
    desc: "Quotation is only one part. Matching accuracy, packing, QC, and shipment follow-up matter for repeat orders.",
  },
  {
    title: "We support mixed orders",
    desc: "Many Foton inquiries include different systems or items. We help organize them into one workable sourcing and shipment plan.",
  },
];

const faq = [
  {
    q: "Can you help if I don't have the OE number?",
    a: "Yes. You can start with VIN, truck model, photos, old supplier references, or a part list.",
  },
  {
    q: "Can you handle mixed Foton orders?",
    a: "Yes. We can support inquiries covering multiple part systems and organize them into one order.",
  },
  {
    q: "Do you support inspection and shipment follow-up?",
    a: "Yes. We support supplier comparison, QC checkpoints, packing checks, and shipment coordination.",
  },
];

const relatedPaths = [
  {
    title: "Engine parts",
    desc: "For overhaul demand, mixed engine orders, and model-led engine parts matching.",
    href: "/product/part/engine-parts/",
  },
  {
    title: "Cooling system parts",
    desc: "For radiators, water pumps, thermostats, hoses, and cooling-related RFQs.",
    href: "/product/part/cooling-system-parts/",
  },
  {
    title: "Electrical parts",
    desc: "For charging, starting, sensing, and vehicle-application electrical items.",
    href: "/product/part/electrical-parts/",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Foton Parts Sourcing from China",
    description:
      "Send a Foton parts inquiry with OE numbers, VIN, photos, or part lists and get clearer matching, quotation support, inspection follow-up, and shipment coordination.",
    url: "https://certispares.com/product/brand/foton/",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://certispares.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Product",
        item: "https://certispares.com/product/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Foton",
        item: "https://certispares.com/product/brand/foton/",
      },
    ],
  },
];
---

<BaseLayout
  title="Send Your Foton Parts Inquiry | Matching and Quotation Support"
  description="Send your Foton parts inquiry with OE numbers, VIN, photos, or part names. CertiSpares helps check matching scope, compare suppliers, and move the inquiry into quotation and shipment follow-up."
  keywords={[
  "Foton parts sourcing from China",
  "Foton truck parts RFQ",
  "Foton parts supplier China",
  "Foton parts inquiry",
  "OE number Foton parts",
]}
  canonical="/product/brand/foton/"
  ogImage="/images/brands/foton.png"
  jsonLd={jsonLd}
>
  <style>
    :root{
      --bg:#eef3f7;
      --text:#1d2a36;
      --muted:#5f6d86;
      --line:rgba(29,42,54,.10);
      --brand:#3957E9;
    }

    :global(main){ background:linear-gradient(180deg, #f5f8fc 0%, #eef3f7 100%); }
    :global(.topbar){
      background:#111F43 !important; background-color:#111F43 !important; opacity:1 !important;
      backdrop-filter:none !important; -webkit-backdrop-filter:none !important;
      border-bottom:1px solid #111F43 !important; box-shadow:none !important;
    }
    :global(.menu), :global(.menu a), :global(.menu a:hover){ color:#fff; }
    :global(.menu a.active), :global(.drawerNav a.active){
      color:#fff; background:rgba(57,87,233,.18); border-color:rgba(57,87,233,.32);
    }
    :global(.cta){ background:#3957E9; color:#fff; }

    .hero{
      position:relative; padding:46px 0 20px; border-bottom:1px solid var(--line);
      overflow:hidden; isolation:isolate; background:#0b1020;
    }
    .heroBg{
      position:absolute; inset:0; z-index:-2;
      background:url("/images/hero-04-logistics-truck.webp") center/cover no-repeat;
      filter:blur(2px) saturate(.95) contrast(.95) brightness(.88);
      transform:scale(1.03);
    }
    .overlay{
      position:absolute; inset:0; z-index:-1;
      background:
        linear-gradient(180deg, rgba(11,16,32,.28) 0%, rgba(11,16,32,.86) 72%, rgba(11,16,32,1) 100%),
        radial-gradient(900px 420px at 25% 20%, rgba(57,87,233,.22), transparent 60%);
    }
    .heroInner{
      position:relative; padding:2px 0 22px; display:grid;
      grid-template-columns:minmax(0, 1.1fr) minmax(320px, .9fr); gap:22px; align-items:end;
    }
    .eyebrow{
      margin:0 0 10px; font-size:12px; font-weight:900; letter-spacing:.14em; text-transform:uppercase;
      color:rgba(232,240,255,.76);
    }
    h1{ margin:0 0 14px; font-size:46px; line-height:1.04; letter-spacing:-.65px; color:#fff; max-width:740px; }
    .heroLead{ margin:0; max-width:740px; color:rgba(232,240,255,.84); line-height:1.8; }
    .heroActions{ display:flex; gap:10px; flex-wrap:wrap; margin-top:18px; }
    .heroActions .btn.primary, .ctaBlock .btn.primary{ color:#fff; }
    .heroPanel{
      padding:20px 22px; border-radius:26px; border:1px solid rgba(255,255,255,.12);
      background:linear-gradient(180deg, rgba(18,26,46,.72), rgba(18,26,46,.52));
      backdrop-filter:blur(8px); box-shadow:0 20px 60px rgba(6,11,26,.28);
    }
    .heroPanel b{ display:block; margin-bottom:12px; color:#fff; font-size:18px; }
    .heroList{ display:grid; gap:10px; }
    .heroListItem{ display:flex; gap:10px; align-items:flex-start; color:rgba(232,240,255,.82); line-height:1.7; }
    .heroDot{ width:10px; height:10px; border-radius:999px; background:#5b7cff; margin-top:8px; flex:0 0 auto; }
    .section{ padding:26px 0; }
    .sectionTitle{ margin:0 0 10px; font-size:28px; line-height:1.2; color:#1d2a36; }
    .sectionDesc{ margin:0 0 16px; color:var(--muted); line-height:1.75; max-width:860px; }
    .grid2{ display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:16px; }
    .grid3{ display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:16px; }
    .card{
      background:#fff; border:1px solid var(--line); border-radius:22px; padding:18px;
      box-shadow:0 16px 40px rgba(24,39,56,.05);
    }
    .card b{ display:block; margin-bottom:8px; color:#1d2a36; font-size:18px; line-height:1.35; }
    .card p{ margin:0; color:var(--muted); line-height:1.75; }
    .chipWrap{ display:flex; gap:10px; flex-wrap:wrap; }
    .chip{
      display:inline-flex; align-items:center; padding:10px 14px; border-radius:999px;
      background:#fff; border:1px solid rgba(29,42,54,.10); color:#1d2a36; font-weight:700;
    }
    .bulletList{ list-style:none; padding:0; margin:0; display:grid; gap:10px; }
    .bulletItem{ display:flex; gap:10px; align-items:flex-start; color:var(--muted); line-height:1.7; }
    .dot{ width:10px; height:10px; border-radius:999px; background:#5b7cff; margin-top:8px; flex:0 0 auto; }
    .faq{ display:grid; gap:12px; }
    .faqItem{
      background:#fff; border:1px solid var(--line); border-radius:20px; padding:16px 18px;
      box-shadow:0 16px 40px rgba(24,39,56,.04);
    }
    .faqItem strong{ display:block; margin-bottom:8px; color:#1d2a36; }
    .faqItem p{ margin:0; color:var(--muted); line-height:1.75; }
    .ctaBlock{
      border-radius:20px; padding:18px; background:linear-gradient(135deg, rgba(57,87,233,.10), rgba(255,255,255,.92));
      border:1px solid rgba(57,87,233,.16); display:flex; justify-content:space-between; align-items:center; gap:14px;
      box-shadow:0 16px 40px rgba(24,39,56,.05);
    }
    .ctaBlock .left b{ display:block; margin-bottom:6px; color:#1d2a36; }
    .ctaBlock .left p{ margin:0; color:var(--muted); line-height:1.75; max-width:760px; }
    :global(.footerWrap){ background:transparent; border-top:1px solid rgba(29,42,54,.10); }
    :global(.footerTitle), :global(.footerNav strong){ color:#1d2a36; }
    :global(.footer), :global(.footerNav span){ color:var(--muted); }
    :global(.footerNav a){ background:#fff; border-color:rgba(29,42,54,.10); }
    @media (max-width: 980px){
      .heroInner, .grid2, .grid3{ grid-template-columns:1fr; }
      h1{ font-size:38px; }
      .ctaBlock{ flex-direction:column; align-items:flex-start; }
    }
  </style>

  <section class="hero">
    <div class="heroBg" aria-hidden="true"></div>
    <div class="overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="heroInner">
        <div>
          <p class="eyebrow">CertiSpares / Brand Sourcing</p>
          <h1>Send your Foton parts inquiry and get clearer matching and quotation support</h1>
          <p class="heroLead">
            Send the OE number, VIN, photos, part names, or even an old supplier list.
            We help check the matching scope, compare workable suppliers, and move your inquiry into quotation, inspection, and shipment follow-up.
          </p>
          <div class="heroActions">
            <a class="btn primary" href="/contact">Send Foton Inquiry</a>
            <a class="btn" href="#what-to-send">See What to Send</a>
          </div>
        </div>

        <aside class="heroPanel">
          <b>What to send for a faster reply</b>
          <div class="heroList">
            {matchingInputs.slice(0, 5).map((item) => (
              <div class="heroListItem"><span class="heroDot"></span><span>{item}</span></div>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Have you run into these issues when sourcing Foton parts?</h2>
      <div class="grid3">
        {painPoints.map((item) => (
          <div class="card">
            <b>{item.title}</b>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Common Foton part systems we handle</h2>
      <p class="sectionDesc">Most Foton inquiries start from a part system, then move into OE-based or vehicle-based matching. Common systems include:</p>
      <div class="chipWrap" aria-label="Foton-supported systems">
        {supportedSystems.map((system) => (
          <span class="chip">{system}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="what-to-send">
    <div class="container">
      <h2 class="sectionTitle">What to send with your Foton inquiry</h2>
      <div class="grid2">
        <div class="card">
          <b>Best details to send</b>
          <ul class="bulletList">
            {matchingInputs.map((item) => (
              <li class="bulletItem"><span class="dot"></span><span>{item}</span></li>
            ))}
          </ul>
        </div>
        <div class="card">
          <b>This helps avoid wrong quotes</b>
          <p>
            The clearer the inquiry, the easier it is to confirm fitment, compare suppliers on the same scope, and reduce back-and-forth later.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">What happens after you send the inquiry</h2>
      <div class="grid2">
        {processSteps.map((step) => (
          <div class="card">
            <b>{step.title}</b>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Why buyers use us for Foton inquiries</h2>
      <div class="grid3">
        {whyWorkWithUs.map((item) => (
          <div class="card">
            <b>{item.title}</b>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">FAQ</h2>
      <div class="faq">
        {faq.map((item) => (
          <div class="faqItem">
            <strong>{item.q}</strong>
            <p>{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Need to start from the part category instead?</h2>
      <div class="grid3">
        {relatedPaths.map((item) => (
          <div class="card">
            <b><a href={item.href}>{item.title}</a></b>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="ctaBlock">
        <div class="left">
          <b>Ready to send your Foton inquiry?</b>
          <p>
            Send the OE number, VIN, photos, part list, or old supplier references you already have.
            We will review the inquiry, confirm the matching scope, and reply with the next workable step.
          </p>
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a class="btn primary" href="/contact">Send Foton Inquiry</a>
          <a class="btn" href="/contact">Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>