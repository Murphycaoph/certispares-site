---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const painPoints = [
  {
    title: "Same wheel-end name, different fitment",
    desc: "Hub, bearing, seal, and wheel-end items can share a broad name but differ by axle application, dimensions, or hardware layout.",
  },
  {
    title: "Wrong hub or bearing spec is costly",
    desc: "Without clear dimensions and axle references, suppliers may quote items that fit the label but not the assembly.",
  },
  {
    title: "Wheel-end RFQs get split too easily",
    desc: "Hubs, bearings, seals, and hardware often belong in one RFQ, but they are harder to compare when quoted separately.",
  },
];
const supportedParts = [
  "Wheel hubs",
  "Bearings",
  "Seals",
  "Hub caps",
  "Wheel bolts",
  "Axle shafts",
  "Repair kits",
  "Hardware",
];
const matchingInputs = [
  "OE number or part number",
  "Vehicle or axle application",
  "Hub, bearing, or seal dimensions",
  "Part photos",
  "Quantity list and destination",
];
const processSteps = [
  { title: "You send the details", desc: "Share what you have - OE numbers, model details, specs, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We review the technical details before asking for quotes to avoid mismatch." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on specs, quality level, and execution - not just price." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we follow up on QC, packing, documents, and shipment." },
];
const whyWorkWithUs = [
  {
    title: "We check fitment before quoting",
    desc: "Wheel-end parts depend on axle application, hub size, bearing spec, and seal dimensions. We confirm first, then quote.",
  },
  {
    title: "We align suppliers on the same scope",
    desc: "Quotes only help when they match the same fitment and execution basis.",
  },
  {
    title: "We handle mixed axle-category orders",
    desc: "We can organize hubs, bearings, seals, shafts, and hardware into one workable order.",
  },
];
const faq = [
  {
    q: "Can I start without OE numbers?",
    a: "Yes. Axle application, hub dimensions, bearing references, seal sizes, or photos can also work.",
  },
  {
    q: "Can you handle mixed wheel-end parts in one order?",
    a: "Yes. We can organize multiple axle and wheel-end items into one structured inquiry and shipment plan.",
  },
  {
    q: "Do you support inspection before shipment?",
    a: "Yes. We follow up on QC, packing checks, and shipment coordination.",
  },
];
const relatedPaths = [
  {
    title: "FAW parts sourcing",
    desc: "For axle-led RFQs tied to a known truck platform.",
    href: "/product/brand/faw/",
  },
  {
    title: "Volvo Truck parts sourcing",
    desc: "For wheel-end and axle-category demand under Volvo truck applications.",
    href: "/product/brand/volvo-truck/",
  },
  {
    title: "Steering parts",
    desc: "If the RFQ also includes steering joints, rods, or geometry-related items.",
    href: "/product/part/steering-parts/",
  },
];
const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Axle And Wheel-End Parts Sourcing from China", description: "Send your axle and wheel-end parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certispares.com/product/part/axle-and-wheel-end-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certispares.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certispares.com/product/" }, { "@type": "ListItem", position: 3, name: "Axle And Wheel-End Parts", item: "https://certispares.com/product/part/axle-and-wheel-end-parts/" } ] },
];
---

<BaseLayout
  title="Send Your Axle And Wheel-End Parts Inquiry | Clear Matching and Workable Quotes"
  description="Send your axle and wheel-end parts inquiry with OE numbers, specs, photos, or part lists. CertiSpares checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={[
  "axle and wheel-end parts sourcing from China",
  "wheel-end parts RFQ",
  "axle parts supplier China",
  "wheel-end quote support",
  "axle and wheel-end inquiry",
]}
  canonical="/product/part/axle-and-wheel-end-parts/"
  ogImage="/images/assemblies/assembly-axle.png"
  jsonLd={jsonLd}
>
  <style>@import "../../../styles/product-detail.css";</style>
  <section class="hero"><div class="heroBg" style={"background-image:url('/images/assemblies/assembly-axle.png')"} aria-hidden="true"></div><div class="overlay" aria-hidden="true"></div><div class="container"><div class="heroInner"><div><p class="eyebrow">CertiSpares / Parts Inquiry</p><h1>Send your axle and wheel-end parts inquiry and get clear matching and workable quotes</h1><p class="heroLead">Send OE numbers, axle application, hub and bearing references, seal sizes, photos, or your parts list. We check fitment first, then compare suppliers on the same scope, and move your inquiry into quotation, inspection, and shipment follow-up.</p><div class="heroActions"><a class="btn primary" href="/contact">Send Axle and Wheel-End Inquiry</a><a class="btn" href="#what-to-send">See What to Send</a></div></div><aside class="heroPanel"><b>What to send for a faster reply</b><div class="heroList">{matchingInputs.slice(0, 5).map((item) => (<div class="heroListItem"><span class="heroDot"></span><span>{item}</span></div>))}</div></aside></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Running into these issues when sourcing axle and wheel-end parts?</h2><div class="grid3">{painPoints.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Common axle and wheel-end parts we handle</h2><p class="sectionDesc">Most inquiries start with a part name, OE reference, or a mixed replenishment list. Typical items include:</p><div class="chipWrap" aria-label="Supported axle and wheel-end parts">{supportedParts.map((item) => (<span class="chip">{item}</span>))}</div></div></section>
  <section class="section" id="what-to-send"><div class="container"><h2 class="sectionTitle">What to send with your axle and wheel-end parts inquiry</h2><div class="grid2"><div class="card"><b>Best details to send</b><ul class="bulletList">{matchingInputs.map((item) => (<li class="bulletItem"><span class="dot"></span><span>{item}</span></li>))}</ul></div><div class="card"><b>This helps avoid wrong parts</b><p>Clear inputs make it easier to confirm wheel-end fitment, align suppliers on the same scope, and avoid rework later.</p></div></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">What happens after you send the inquiry</h2><div class="grid2">{processSteps.map((step) => (<div class="card"><b>{step.title}</b><p>{step.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Why buyers use us for axle and wheel-end parts inquiries</h2><div class="grid3">{whyWorkWithUs.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">FAQ</h2><div class="faq">{faq.map((item) => (<div class="faqItem"><strong>{item.q}</strong><p>{item.a}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Need to start from a truck brand instead?</h2><div class="grid3">{relatedPaths.map((item) => (<div class="card"><b><a href={item.href}>{item.title}</a></b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><div class="ctaBlock"><div class="left"><b>Ready to send your axle and wheel-end parts inquiry?</b><p>Send the details you already have - OE numbers, specs, photos, or your parts list. We will review it, confirm the scope, and reply with the next step.</p></div><div style="display:flex; gap:10px; flex-wrap:wrap;"><a class="btn primary" href="/contact">Send Axle and Wheel-End Inquiry</a><a class="btn" href="/contact">Contact Us</a></div></div></div></section>
</BaseLayout>