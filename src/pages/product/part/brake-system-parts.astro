---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const painPoints = [
  {
    title: "Same part name, different fitment",
    desc: "Brake drums, chambers, linings, and valves can share a broad name but differ by size, type, or application.",
  },
  {
    title: "Cheap quotes can hide the wrong scope",
    desc: "Without clear dimensions, chamber type, valve spec, or lining material, suppliers may quote different products under one request.",
  },
  {
    title: "Mixed brake items get split too easily",
    desc: "Chambers, valves, drums, linings, and hardware often belong in one RFQ, but they are hard to compare when suppliers quote them separately.",
  },
];
const supportedParts = [
  "Brake drums",
  "Brake chambers",
  "Linings",
  "Pads",
  "Valves",
  "Calipers",
  "Shoes",
  "Hardware",
];
const matchingInputs = [
  "OE number or part number",
  "Vehicle model or VIN",
  "Key dimensions, chamber type, or valve spec",
  "Part photos",
  "Quantity list and destination",
];
const processSteps = [
  { title: "You send the details", desc: "Share what you have - OE numbers, model details, specs, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We review the technical details before asking for quotes to avoid mismatch." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on specs, quality level, and execution - not just price." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we follow up on QC, packing, documents, and shipment." },
];
const whyWorkWithUs = [
  {
    title: "We check fitment before quoting",
    desc: "Brake parts depend on dimensions, chamber type, valve spec, lining material, and application. We confirm first, then quote.",
  },
  {
    title: "We line up suppliers on the same scope",
    desc: "Quotes only help when they cover the same fitment, quality level, and packing basis.",
  },
  {
    title: "We handle mixed brake RFQs",
    desc: "We can organize chambers, linings, drums, valves, and service items into one workable sourcing flow.",
  },
];
const faq = [
  {
    q: "Can I start without OE numbers?",
    a: "Yes. Vehicle model, chamber size, valve reference, dimensions, or photos can also work.",
  },
  {
    q: "Can you handle mixed brake items in one order?",
    a: "Yes. We can organize multiple brake lines into one RFQ and shipment plan.",
  },
  {
    q: "Do you support inspection before shipment?",
    a: "Yes. We follow up on QC, packing checks, and shipment coordination.",
  },
];
const relatedPaths = [
  {
    title: "HOWO parts sourcing",
    desc: "For inquiries tied to a specific truck platform.",
    href: "/product/brand/howo/",
  },
  {
    title: "Shacman parts sourcing",
    desc: "For platform-led brake RFQs tied to a known truck family.",
    href: "/product/brand/shacman/",
  },
  {
    title: "Air system parts",
    desc: "If the RFQ also includes valves, fittings, or other air-side items.",
    href: "/product/part/air-system-parts/",
  },
];
const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Brake System Parts Sourcing from China", description: "Send your brake system parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certispares.com/product/part/brake-system-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certispares.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certispares.com/product/" }, { "@type": "ListItem", position: 3, name: "Brake System Parts", item: "https://certispares.com/product/part/brake-system-parts/" } ] },
];
---

<BaseLayout
  title="Send Your Brake System Parts Inquiry | Clear Matching and Workable Quotes"
  description="Send your brake system parts inquiry with OE numbers, specs, photos, or part lists. CertiSpares checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={[
  "brake system parts sourcing from China",
  "brake system parts RFQ",
  "brake system parts supplier China",
  "brake parts quote support",
  "brake parts inquiry",
]}
  canonical="/product/part/brake-system-parts/"
  ogImage="/images/Brake-System.png"
  jsonLd={jsonLd}
>
  <style>@import "../../../styles/product-detail.css";</style>
  <section class="hero"><div class="heroBg" style={"background-image:url('/images/Brake-System.png')"} aria-hidden="true"></div><div class="overlay" aria-hidden="true"></div><div class="container"><div class="heroInner"><div><p class="eyebrow">CertiSpares / Parts Inquiry</p><h1>Send your brake system parts inquiry and get clear matching and workable quotes</h1><p class="heroLead">Send OE numbers, dimensions, chamber type, valve references, photos, or your parts list. We check fitment first, then compare suppliers on the same scope, and move your inquiry into quotation, inspection, and shipment follow-up.</p><div class="heroActions"><a class="btn primary" href="/contact">Send Brake Inquiry</a><a class="btn" href="#what-to-send">See What to Send</a></div></div><aside class="heroPanel"><b>What to send for a faster reply</b><div class="heroList">{matchingInputs.slice(0, 5).map((item) => (<div class="heroListItem"><span class="heroDot"></span><span>{item}</span></div>))}</div></aside></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Running into these issues when sourcing brake system parts?</h2><div class="grid3">{painPoints.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Common brake system parts we handle</h2><p class="sectionDesc">Most inquiries start with a part name, OE reference, or a mixed replenishment list. Typical items include:</p><div class="chipWrap" aria-label="Supported brake system parts">{supportedParts.map((item) => (<span class="chip">{item}</span>))}</div></div></section>
  <section class="section" id="what-to-send"><div class="container"><h2 class="sectionTitle">What to send with your brake system parts inquiry</h2><div class="grid2"><div class="card"><b>Best details to send</b><ul class="bulletList">{matchingInputs.map((item) => (<li class="bulletItem"><span class="dot"></span><span>{item}</span></li>))}</ul></div><div class="card"><b>This helps avoid wrong parts</b><p>Clear inputs make it easier to confirm fitment, line up supplier quotes on the same scope, and reduce mismatch later.</p></div></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">What happens after you send the inquiry</h2><div class="grid2">{processSteps.map((step) => (<div class="card"><b>{step.title}</b><p>{step.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Why buyers use us for brake system parts inquiries</h2><div class="grid3">{whyWorkWithUs.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">FAQ</h2><div class="faq">{faq.map((item) => (<div class="faqItem"><strong>{item.q}</strong><p>{item.a}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Need to start from a truck brand instead?</h2><div class="grid3">{relatedPaths.map((item) => (<div class="card"><b><a href={item.href}>{item.title}</a></b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><div class="ctaBlock"><div class="left"><b>Ready to send your brake system parts inquiry?</b><p>Send the details you already have - OE numbers, specs, photos, or your parts list. We will review it, confirm the scope, and reply with the next step.</p></div><div style="display:flex; gap:10px; flex-wrap:wrap;"><a class="btn primary" href="/contact">Send Brake Inquiry</a><a class="btn" href="/contact">Contact Us</a></div></div></div></section>
</BaseLayout>