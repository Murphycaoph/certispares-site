---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const painPoints = [
  {
    title: "Same part name, different chassis fitment",
    desc: "Bushings, torque rods, stabilizer bars, and springs can look similar but differ by size, load rating, or chassis application.",
  },
  {
    title: "Quotes can ignore load and size details",
    desc: "Without clear bushing size, load spec, or pin size, suppliers may quote parts that fit the name but not the vehicle.",
  },
  {
    title: "Mixed suspension RFQs are hard to compare",
    desc: "Torque rods, bushings, springs, and hardware are often quoted separately, which makes the order harder to review as one scope.",
  },
];
const supportedParts = [
  "Leaf springs",
  "Torque rods",
  "Stabilizer bars",
  "Bushings",
  "Pins",
  "U-bolts",
  "Shackle kits",
  "Mounts",
];
const matchingInputs = [
  "OE number or part number",
  "Chassis application or truck model",
  "Bushing size, load spec, or pin size",
  "Part photos",
  "Quantity list and destination",
];
const processSteps = [
  { title: "You send the details", desc: "Share what you have - OE numbers, model details, specs, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We review the technical details before asking for quotes to avoid mismatch." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on specs, quality level, and execution - not just price." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we follow up on QC, packing, documents, and shipment." },
];
const whyWorkWithUs = [
  {
    title: "We check application before quoting",
    desc: "Suspension parts depend on chassis application, bushing size, load spec, and pin dimensions. We confirm first, then quote.",
  },
  {
    title: "We align suppliers on the same scope",
    desc: "Quotes only help when they match the same fitment and quality basis.",
  },
  {
    title: "We handle mixed suspension orders",
    desc: "We can organize rods, bushings, springs, and hardware into one workable sourcing flow.",
  },
];
const faq = [
  {
    q: "Can I start without OE numbers?",
    a: "Yes. Truck model, chassis details, bushing size, load spec, or photos can also work.",
  },
  {
    q: "Can you handle mixed suspension parts in one order?",
    a: "Yes. We can organize multiple suspension items into one structured inquiry and shipment plan.",
  },
  {
    q: "Do you support inspection before shipment?",
    a: "Yes. We follow up on QC, packing checks, and shipment coordination.",
  },
];
const relatedPaths = [
  {
    title: "Shacman parts sourcing",
    desc: "For suspension RFQs tied to a known truck platform.",
    href: "/product/brand/shacman/",
  },
  {
    title: "Dongfeng parts sourcing",
    desc: "For chassis-led inquiries under a Dongfeng platform.",
    href: "/product/brand/dongfeng/",
  },
  {
    title: "Rubber and bushing parts",
    desc: "If the RFQ is mainly bushing-, mount-, or rubber-led.",
    href: "/product/part/rubber-and-bushing-parts/",
  },
];
const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Suspension Parts Sourcing from China", description: "Send your suspension parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certispares.com/product/part/suspension-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certispares.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certispares.com/product/" }, { "@type": "ListItem", position: 3, name: "Suspension Parts", item: "https://certispares.com/product/part/suspension-parts/" } ] },
];
---

<BaseLayout
  title="Send Your Suspension Parts Inquiry | Clear Matching and Workable Quotes"
  description="Send your suspension parts inquiry with OE numbers, specs, photos, or part lists. CertiSpares checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={[
  "suspension parts sourcing from China",
  "suspension parts RFQ",
  "suspension parts supplier China",
  "suspension quote support",
  "suspension parts inquiry",
]}
  canonical="/product/part/suspension-parts/"
  ogImage="/images/Suspension.png"
  jsonLd={jsonLd}
>
  <style>@import "../../../styles/product-detail.css";</style>
  <section class="hero"><div class="heroBg" style={"background-image:url('/images/Suspension.png')"} aria-hidden="true"></div><div class="overlay" aria-hidden="true"></div><div class="container"><div class="heroInner"><div><p class="eyebrow">CertiSpares / Parts Inquiry</p><h1>Send your suspension parts inquiry and get clear matching and workable quotes</h1><p class="heroLead">Send OE numbers, chassis application, bushing size, load spec, pin size, photos, or your parts list. We check fitment first, then compare suppliers on the same scope, and move your inquiry into quotation, inspection, and shipment follow-up.</p><div class="heroActions"><a class="btn primary" href="/contact">Send Suspension Inquiry</a><a class="btn" href="#what-to-send">See What to Send</a></div></div><aside class="heroPanel"><b>What to send for a faster reply</b><div class="heroList">{matchingInputs.slice(0, 5).map((item) => (<div class="heroListItem"><span class="heroDot"></span><span>{item}</span></div>))}</div></aside></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Running into these issues when sourcing suspension parts?</h2><div class="grid3">{painPoints.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Common suspension parts we handle</h2><p class="sectionDesc">Most inquiries start with a part name, OE reference, or a mixed replenishment list. Typical items include:</p><div class="chipWrap" aria-label="Supported suspension parts">{supportedParts.map((item) => (<span class="chip">{item}</span>))}</div></div></section>
  <section class="section" id="what-to-send"><div class="container"><h2 class="sectionTitle">What to send with your suspension parts inquiry</h2><div class="grid2"><div class="card"><b>Best details to send</b><ul class="bulletList">{matchingInputs.map((item) => (<li class="bulletItem"><span class="dot"></span><span>{item}</span></li>))}</ul></div><div class="card"><b>This helps avoid wrong parts</b><p>Clear inputs make it easier to confirm chassis fitment, line up supplier quotes on the same basis, and avoid mismatch later.</p></div></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">What happens after you send the inquiry</h2><div class="grid2">{processSteps.map((step) => (<div class="card"><b>{step.title}</b><p>{step.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Why buyers use us for suspension parts inquiries</h2><div class="grid3">{whyWorkWithUs.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">FAQ</h2><div class="faq">{faq.map((item) => (<div class="faqItem"><strong>{item.q}</strong><p>{item.a}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Need to start from a truck brand instead?</h2><div class="grid3">{relatedPaths.map((item) => (<div class="card"><b><a href={item.href}>{item.title}</a></b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><div class="ctaBlock"><div class="left"><b>Ready to send your suspension parts inquiry?</b><p>Send the details you already have - OE numbers, specs, photos, or your parts list. We will review it, confirm the scope, and reply with the next step.</p></div><div style="display:flex; gap:10px; flex-wrap:wrap;"><a class="btn primary" href="/contact">Send Suspension Inquiry</a><a class="btn" href="/contact">Contact Us</a></div></div></div></section>
</BaseLayout>