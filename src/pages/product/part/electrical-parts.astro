---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const painPoints = [
  {
    title: "Same electrical function, different connector",
    desc: "Sensors, switches, starters, and charging items can differ by voltage, connector type, or OE reference.",
  },
  {
    title: "Wrong electrical spec is easy to miss",
    desc: "Without clear voltage and application details, suppliers may quote parts that look similar but do not fit the vehicle.",
  },
  {
    title: "Mixed electrical RFQs are hard to align",
    desc: "Connectors, sensors, starters, alternators, and switches often come together, but quotes are harder to compare when the scope is unclear.",
  },
];
const supportedParts = [
  "Sensors",
  "Switches",
  "Starters",
  "Alternators",
  "Connectors",
  "Relays",
  "Lighting items",
  "Harness-related parts",
];
const matchingInputs = [
  "OE number or part number",
  "Vehicle application",
  "Voltage, connector type, or OE reference",
  "Part photos",
  "Quantity list and destination",
];
const processSteps = [
  { title: "You send the details", desc: "Share what you have - OE numbers, model details, specs, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We review the technical details before asking for quotes to avoid mismatch." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on specs, quality level, and execution - not just price." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we follow up on QC, packing, documents, and shipment." },
];
const whyWorkWithUs = [
  {
    title: "We check electrical specs before quoting",
    desc: "Electrical parts depend on voltage, connector type, OE reference, and vehicle application. We confirm first, then quote.",
  },
  {
    title: "We align suppliers on the same scope",
    desc: "Quotes only help when they match the same electrical requirement and execution basis.",
  },
  {
    title: "We handle mixed electrical RFQs",
    desc: "We can organize sensors, charging items, switches, and connector demand into one workable order.",
  },
];
const faq = [
  {
    q: "Can I start without OE numbers?",
    a: "Yes. Voltage details, connector type, application references, or photos can also work.",
  },
  {
    q: "Can you handle mixed electrical parts in one order?",
    a: "Yes. We can organize multiple electrical items into one structured inquiry and shipment plan.",
  },
  {
    q: "Do you support inspection before shipment?",
    a: "Yes. We follow up on QC, packing checks, and shipment coordination.",
  },
];
const relatedPaths = [
  {
    title: "MAN parts sourcing",
    desc: "For electrical RFQs tied to MAN vehicle applications.",
    href: "/product/brand/man/",
  },
  {
    title: "Mercedes-Benz Truck parts sourcing",
    desc: "For application-led electrical demand under Mercedes-Benz Truck platforms.",
    href: "/product/brand/mercedes-benz-truck/",
  },
  {
    title: "Cooling system parts",
    desc: "If the RFQ also includes temperature-control or cooling-side items.",
    href: "/product/part/cooling-system-parts/",
  },
];
const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Electrical Parts Sourcing from China", description: "Send your electrical parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certispares.com/product/part/electrical-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certispares.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certispares.com/product/" }, { "@type": "ListItem", position: 3, name: "Electrical Parts", item: "https://certispares.com/product/part/electrical-parts/" } ] },
];
---

<BaseLayout
  title="Send Your Electrical Parts Inquiry | Clear Matching and Workable Quotes"
  description="Send your electrical parts inquiry with OE numbers, specs, photos, or part lists. CertiSpares checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={[
  "electrical parts sourcing from China",
  "electrical parts RFQ",
  "electrical parts supplier China",
  "electrical quote support",
  "commercial vehicle electrical parts inquiry",
]}
  canonical="/product/part/electrical-parts/"
  ogImage="/images/kit/white background engine replacement parts flat lay, water pump, thermostat, sensors, injectors, hoses, commercial vehicle parts catalog style, no watermark, square composition.png"
  jsonLd={jsonLd}
>
  <style>@import "../../../styles/product-detail.css";</style>
  <section class="hero"><div class="heroBg" style={"background-image:url('/images/kit/white background engine replacement parts flat lay, water pump, thermostat, sensors, injectors, hoses, commercial vehicle parts catalog style, no watermark, square composition.png')"} aria-hidden="true"></div><div class="overlay" aria-hidden="true"></div><div class="container"><div class="heroInner"><div><p class="eyebrow">CertiSpares / Parts Inquiry</p><h1>Send your electrical parts inquiry and get clear matching and workable quotes</h1><p class="heroLead">Send OE numbers, voltage details, connector type, application references, photos, or your parts list. We check fitment first, then compare suppliers on the same scope, and move your inquiry into quotation, inspection, and shipment follow-up.</p><div class="heroActions"><a class="btn primary" href="/contact">Send Electrical Inquiry</a><a class="btn" href="#what-to-send">See What to Send</a></div></div><aside class="heroPanel"><b>What to send for a faster reply</b><div class="heroList">{matchingInputs.slice(0, 5).map((item) => (<div class="heroListItem"><span class="heroDot"></span><span>{item}</span></div>))}</div></aside></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Running into these issues when sourcing electrical parts?</h2><div class="grid3">{painPoints.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Common electrical parts we handle</h2><p class="sectionDesc">Most inquiries start with a part name, OE reference, or a mixed replenishment list. Typical items include:</p><div class="chipWrap" aria-label="Supported electrical parts">{supportedParts.map((item) => (<span class="chip">{item}</span>))}</div></div></section>
  <section class="section" id="what-to-send"><div class="container"><h2 class="sectionTitle">What to send with your electrical parts inquiry</h2><div class="grid2"><div class="card"><b>Best details to send</b><ul class="bulletList">{matchingInputs.map((item) => (<li class="bulletItem"><span class="dot"></span><span>{item}</span></li>))}</ul></div><div class="card"><b>This helps avoid wrong parts</b><p>Clear inputs make it easier to confirm the correct electrical spec, align suppliers on the same scope, and reduce wrong quotes later.</p></div></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">What happens after you send the inquiry</h2><div class="grid2">{processSteps.map((step) => (<div class="card"><b>{step.title}</b><p>{step.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Why buyers use us for electrical parts inquiries</h2><div class="grid3">{whyWorkWithUs.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">FAQ</h2><div class="faq">{faq.map((item) => (<div class="faqItem"><strong>{item.q}</strong><p>{item.a}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Need to start from a truck brand instead?</h2><div class="grid3">{relatedPaths.map((item) => (<div class="card"><b><a href={item.href}>{item.title}</a></b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><div class="ctaBlock"><div class="left"><b>Ready to send your electrical parts inquiry?</b><p>Send the details you already have - OE numbers, specs, photos, or your parts list. We will review it, confirm the scope, and reply with the next step.</p></div><div style="display:flex; gap:10px; flex-wrap:wrap;"><a class="btn primary" href="/contact">Send Electrical Inquiry</a><a class="btn" href="/contact">Contact Us</a></div></div></div></section>
</BaseLayout>