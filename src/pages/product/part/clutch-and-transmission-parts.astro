---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const painPoints = [
  {
    title: "Same clutch name, different spec",
    desc: "Clutch kits, discs, release bearings, and gearbox items can differ by size, spline, or transmission application.",
  },
  {
    title: "Wrong transmission scope breaks the order",
    desc: "Without clear application and spec details, suppliers may quote parts that fit the label but not the drivetrain setup.",
  },
  {
    title: "Mixed clutch and gearbox RFQs get fragmented",
    desc: "Discs, pressure plates, release items, and gearbox parts are often harder to compare when suppliers quote them separately.",
  },
];
const supportedParts = [
  "Clutch discs",
  "Pressure plates",
  "Release bearings",
  "Pilot bearings",
  "Clutch forks",
  "Synchronizers",
  "Gear sets",
  "Repair kits",
];
const matchingInputs = [
  "OE number or part number",
  "Vehicle model or gearbox application",
  "Clutch size, spline details, or gearbox references",
  "Part photos",
  "Quantity list and destination",
];
const processSteps = [
  { title: "You send the details", desc: "Share what you have - OE numbers, model details, specs, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We review the technical details before asking for quotes to avoid mismatch." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on specs, quality level, and execution - not just price." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we follow up on QC, packing, documents, and shipment." },
];
const whyWorkWithUs = [
  {
    title: "We check fitment before quoting",
    desc: "These parts depend on clutch size, spline details, gearbox references, and vehicle application. We confirm first, then quote.",
  },
  {
    title: "We align suppliers on the same scope",
    desc: "Quotes only help when they match the same drivetrain setup and execution basis.",
  },
  {
    title: "We handle mixed drivetrain RFQs",
    desc: "We can organize clutch, release, and transmission items into one workable sourcing flow.",
  },
];
const faq = [
  {
    q: "Can I start without OE numbers?",
    a: "Yes. Clutch size, spline details, gearbox references, or photos can also work.",
  },
  {
    q: "Can you handle mixed clutch and transmission parts in one order?",
    a: "Yes. We can organize multiple drivetrain items into one structured inquiry and shipment plan.",
  },
  {
    q: "Do you support inspection before shipment?",
    a: "Yes. We follow up on QC, packing checks, and shipment coordination.",
  },
];
const relatedPaths = [
  {
    title: "HOWO parts sourcing",
    desc: "For drivetrain RFQs tied to a specific truck platform.",
    href: "/product/brand/howo/",
  },
  {
    title: "Sinotruk parts sourcing",
    desc: "For platform-led clutch and gearbox demand.",
    href: "/product/brand/sinotruk/",
  },
  {
    title: "Engine parts",
    desc: "If the RFQ also includes overhaul items or engine-related spares.",
    href: "/product/part/engine-parts/",
  },
];
const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Clutch And Transmission Parts Sourcing from China", description: "Send your clutch and transmission parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certispares.com/product/part/clutch-and-transmission-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certispares.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certispares.com/product/" }, { "@type": "ListItem", position: 3, name: "Clutch And Transmission Parts", item: "https://certispares.com/product/part/clutch-and-transmission-parts/" } ] },
];
---

<BaseLayout
  title="Send Your Clutch And Transmission Parts Inquiry | Clear Matching and Workable Quotes"
  description="Send your clutch and transmission parts inquiry with OE numbers, specs, photos, or part lists. CertiSpares checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={[
  "clutch and transmission parts sourcing from China",
  "clutch parts RFQ",
  "transmission parts supplier China",
  "drivetrain quote support",
  "clutch and transmission inquiry",
]}
  canonical="/product/part/clutch-and-transmission-parts/"
  ogImage="/images/kit/white background clutch and release parts flat lay, clutch disc, pressure plate, release bearing, pilot bearing, clutch fork, clean truck drivetrain catalog photo, no watermark, square composit.png"
  jsonLd={jsonLd}
>
  <style>@import "../../../styles/product-detail.css";</style>
  <section class="hero"><div class="heroBg" style={"background-image:url('/images/kit/white background clutch and release parts flat lay, clutch disc, pressure plate, release bearing, pilot bearing, clutch fork, clean truck drivetrain catalog photo, no watermark, square composit.png')"} aria-hidden="true"></div><div class="overlay" aria-hidden="true"></div><div class="container"><div class="heroInner"><div><p class="eyebrow">CertiSpares / Parts Inquiry</p><h1>Send your clutch and transmission parts inquiry and get clear matching and workable quotes</h1><p class="heroLead">Send OE numbers, vehicle application, clutch size, spline details, gearbox references, photos, or your parts list. We check fitment first, then compare suppliers on the same scope, and move your inquiry into quotation, inspection, and shipment follow-up.</p><div class="heroActions"><a class="btn primary" href="/contact">Send Clutch and Transmission Inquiry</a><a class="btn" href="#what-to-send">See What to Send</a></div></div><aside class="heroPanel"><b>What to send for a faster reply</b><div class="heroList">{matchingInputs.slice(0, 5).map((item) => (<div class="heroListItem"><span class="heroDot"></span><span>{item}</span></div>))}</div></aside></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Running into these issues when sourcing clutch and transmission parts?</h2><div class="grid3">{painPoints.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Common clutch and transmission parts we handle</h2><p class="sectionDesc">Most inquiries start with a part name, OE reference, or a mixed replenishment list. Typical items include:</p><div class="chipWrap" aria-label="Supported clutch and transmission parts">{supportedParts.map((item) => (<span class="chip">{item}</span>))}</div></div></section>
  <section class="section" id="what-to-send"><div class="container"><h2 class="sectionTitle">What to send with your clutch and transmission parts inquiry</h2><div class="grid2"><div class="card"><b>Best details to send</b><ul class="bulletList">{matchingInputs.map((item) => (<li class="bulletItem"><span class="dot"></span><span>{item}</span></li>))}</ul></div><div class="card"><b>This helps avoid wrong parts</b><p>Clear inputs make it easier to confirm drivetrain fitment, line up supplier quotes on the same scope, and avoid mismatch later.</p></div></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">What happens after you send the inquiry</h2><div class="grid2">{processSteps.map((step) => (<div class="card"><b>{step.title}</b><p>{step.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Why buyers use us for clutch and transmission parts inquiries</h2><div class="grid3">{whyWorkWithUs.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">FAQ</h2><div class="faq">{faq.map((item) => (<div class="faqItem"><strong>{item.q}</strong><p>{item.a}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Need to start from a truck brand instead?</h2><div class="grid3">{relatedPaths.map((item) => (<div class="card"><b><a href={item.href}>{item.title}</a></b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><div class="ctaBlock"><div class="left"><b>Ready to send your clutch and transmission parts inquiry?</b><p>Send the details you already have - OE numbers, specs, photos, or your parts list. We will review it, confirm the scope, and reply with the next step.</p></div><div style="display:flex; gap:10px; flex-wrap:wrap;"><a class="btn primary" href="/contact">Send Clutch and Transmission Inquiry</a><a class="btn" href="/contact">Contact Us</a></div></div></div></section>
</BaseLayout>