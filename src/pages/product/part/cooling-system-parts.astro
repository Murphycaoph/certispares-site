---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const painPoints = [
  {
    title: "Same cooling item, different layout",
    desc: "Radiators, water pumps, thermostats, hoses, and tanks can differ by size, core thickness, hose position, or model compatibility.",
  },
  {
    title: "Wrong cooling spec is easy to overlook",
    desc: "Without clear dimensions and layout details, suppliers may quote parts that fit the name but not the vehicle setup.",
  },
  {
    title: "Cooling RFQs often mix several items",
    desc: "Radiators, pumps, thermostats, hoses, and service parts are easier to manage when they stay on one clear inquiry scope.",
  },
];
const supportedParts = [
  "Radiators",
  "Water pumps",
  "Thermostats",
  "Hoses",
  "Expansion tanks",
  "Fans",
  "Sensors",
  "Repair kits",
];
const matchingInputs = [
  "OE number or part number",
  "Vehicle model or application",
  "Radiator size, core thickness, hose position, or model compatibility",
  "Part photos",
  "Quantity list and destination",
];
const processSteps = [
  { title: "You send the details", desc: "Share what you have - OE numbers, model details, specs, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We review the technical details before asking for quotes to avoid mismatch." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on specs, quality level, and execution - not just price." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we follow up on QC, packing, documents, and shipment." },
];
const whyWorkWithUs = [
  {
    title: "We check layout before quoting",
    desc: "Cooling parts depend on radiator size, core thickness, hose position, and model compatibility. We confirm first, then quote.",
  },
  {
    title: "We align suppliers on the same scope",
    desc: "Quotes only help when they match the same fitment and execution basis.",
  },
  {
    title: "We handle mixed cooling RFQs",
    desc: "We can organize radiators, pumps, hoses, and service items into one workable order.",
  },
];
const faq = [
  {
    q: "Can I start without OE numbers?",
    a: "Yes. Radiator size, hose position, application details, or photos can also work.",
  },
  {
    q: "Can you handle mixed cooling parts in one order?",
    a: "Yes. We can organize multiple cooling items into one structured inquiry and shipment plan.",
  },
  {
    q: "Do you support inspection before shipment?",
    a: "Yes. We follow up on QC, packing checks, and shipment coordination.",
  },
];
const relatedPaths = [
  {
    title: "Volvo Truck parts sourcing",
    desc: "For cooling RFQs tied to Volvo applications.",
    href: "/product/brand/volvo-truck/",
  },
  {
    title: "Mercedes-Benz Truck parts sourcing",
    desc: "For application-led cooling demand under Mercedes-Benz Truck platforms.",
    href: "/product/brand/mercedes-benz-truck/",
  },
  {
    title: "Electrical parts",
    desc: "If the RFQ also includes sensors, connectors, or charging-related items.",
    href: "/product/part/electrical-parts/",
  },
];
const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Cooling System Parts Sourcing from China", description: "Send your cooling system parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certispares.com/product/part/cooling-system-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certispares.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certispares.com/product/" }, { "@type": "ListItem", position: 3, name: "Cooling System Parts", item: "https://certispares.com/product/part/cooling-system-parts/" } ] },
];
---

<BaseLayout
  title="Send Your Cooling System Parts Inquiry | Clear Matching and Workable Quotes"
  description="Send your cooling system parts inquiry with OE numbers, specs, photos, or part lists. CertiSpares checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={[
  "cooling system parts sourcing from China",
  "cooling system parts RFQ",
  "cooling parts supplier China",
  "cooling quote support",
  "cooling system inquiry",
]}
  canonical="/product/part/cooling-system-parts/"
  ogImage="/images/kit/white background engine replacement parts flat lay, water pump, thermostat, sensors, injectors, hoses, commercial vehicle parts catalog style, no watermark, square composition.png"
  jsonLd={jsonLd}
>
  <style>@import "../../../styles/product-detail.css";</style>
  <section class="hero"><div class="heroBg" style={"background-image:url('/images/kit/white background engine replacement parts flat lay, water pump, thermostat, sensors, injectors, hoses, commercial vehicle parts catalog style, no watermark, square composition.png')"} aria-hidden="true"></div><div class="overlay" aria-hidden="true"></div><div class="container"><div class="heroInner"><div><p class="eyebrow">CertiSpares / Parts Inquiry</p><h1>Send your cooling system parts inquiry and get clear matching and workable quotes</h1><p class="heroLead">Send OE numbers, radiator size, core thickness, hose position, model compatibility details, photos, or your parts list. We check fitment first, then compare suppliers on the same scope, and move your inquiry into quotation, inspection, and shipment follow-up.</p><div class="heroActions"><a class="btn primary" href="/contact">Send Cooling Inquiry</a><a class="btn" href="#what-to-send">See What to Send</a></div></div><aside class="heroPanel"><b>What to send for a faster reply</b><div class="heroList">{matchingInputs.slice(0, 5).map((item) => (<div class="heroListItem"><span class="heroDot"></span><span>{item}</span></div>))}</div></aside></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Running into these issues when sourcing cooling system parts?</h2><div class="grid3">{painPoints.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Common cooling system parts we handle</h2><p class="sectionDesc">Most inquiries start with a part name, OE reference, or a mixed replenishment list. Typical items include:</p><div class="chipWrap" aria-label="Supported cooling system parts">{supportedParts.map((item) => (<span class="chip">{item}</span>))}</div></div></section>
  <section class="section" id="what-to-send"><div class="container"><h2 class="sectionTitle">What to send with your cooling system parts inquiry</h2><div class="grid2"><div class="card"><b>Best details to send</b><ul class="bulletList">{matchingInputs.map((item) => (<li class="bulletItem"><span class="dot"></span><span>{item}</span></li>))}</ul></div><div class="card"><b>This helps avoid wrong parts</b><p>Clear inputs make it easier to confirm compatibility, align suppliers on the same scope, and reduce wrong quotes later.</p></div></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">What happens after you send the inquiry</h2><div class="grid2">{processSteps.map((step) => (<div class="card"><b>{step.title}</b><p>{step.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Why buyers use us for cooling system parts inquiries</h2><div class="grid3">{whyWorkWithUs.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">FAQ</h2><div class="faq">{faq.map((item) => (<div class="faqItem"><strong>{item.q}</strong><p>{item.a}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Need to start from a truck brand instead?</h2><div class="grid3">{relatedPaths.map((item) => (<div class="card"><b><a href={item.href}>{item.title}</a></b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><div class="ctaBlock"><div class="left"><b>Ready to send your cooling system parts inquiry?</b><p>Send the details you already have - OE numbers, specs, photos, or your parts list. We will review it, confirm the scope, and reply with the next step.</p></div><div style="display:flex; gap:10px; flex-wrap:wrap;"><a class="btn primary" href="/contact">Send Cooling Inquiry</a><a class="btn" href="/contact">Contact Us</a></div></div></div></section>
</BaseLayout>