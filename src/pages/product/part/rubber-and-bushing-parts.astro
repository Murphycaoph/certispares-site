---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const painPoints = [
  {
    title: "Same bushing name, different size",
    desc: "Bushings, sleeves, mounts, and shackle kits can differ by size, hardness, pin fitment, or chassis application.",
  },
  {
    title: "Material level changes the result",
    desc: "Without clear material or application details, suppliers may quote rubber parts that fit the name but not the working condition.",
  },
  {
    title: "Rubber-category RFQs get scattered",
    desc: "Bushings, mounts, sleeves, and hardware are easier to compare when the inquiry stays on one clear scope.",
  },
];
const supportedParts = [
  "Bushings",
  "Rubber mounts",
  "Shackle kits",
  "Sleeves",
  "Pins",
  "Grease fittings",
  "Repair kits",
  "Support hardware",
];
const matchingInputs = [
  "OE number or part number",
  "Chassis application or truck model",
  "Bushing size, pin size, or material details",
  "Part photos",
  "Quantity list and destination",
];
const processSteps = [
  { title: "You send the details", desc: "Share what you have - OE numbers, model details, specs, photos, or a parts list." },
  { title: "We check specs and fitment first", desc: "We review the technical details before asking for quotes to avoid mismatch." },
  { title: "We compare workable suppliers", desc: "We compare suppliers on specs, quality level, and execution - not just price." },
  { title: "We move into inspection and shipping", desc: "After confirmation, we follow up on QC, packing, documents, and shipment." },
];
const whyWorkWithUs = [
  {
    title: "We check size and application before quoting",
    desc: "These parts depend on bushing size, pin fitment, material level, and chassis application. We confirm first, then quote.",
  },
  {
    title: "We align suppliers on the same scope",
    desc: "Quotes only help when they match the same fitment and material basis.",
  },
  {
    title: "We handle mixed rubber-category RFQs",
    desc: "We can organize bushings, mounts, sleeves, and service items into one workable order.",
  },
];
const faq = [
  {
    q: "Can I start without OE numbers?",
    a: "Yes. Chassis application, bushing size, pin dimensions, material details, or photos can also work.",
  },
  {
    q: "Can you handle mixed rubber and bushing parts in one order?",
    a: "Yes. We can organize multiple rubber-category items into one structured inquiry and shipment plan.",
  },
  {
    q: "Do you support inspection before shipment?",
    a: "Yes. We follow up on QC, packing checks, and shipment coordination.",
  },
];
const relatedPaths = [
  {
    title: "Shacman parts sourcing",
    desc: "For chassis-led RFQs tied to a known truck platform.",
    href: "/product/brand/shacman/",
  },
  {
    title: "FAW parts sourcing",
    desc: "For rubber-category demand under FAW applications.",
    href: "/product/brand/faw/",
  },
  {
    title: "Suspension parts",
    desc: "If the RFQ also includes springs, torque rods, or wider suspension demand.",
    href: "/product/part/suspension-parts/",
  },
];
const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Rubber And Bushing Parts Sourcing from China", description: "Send your rubber and bushing parts inquiry with OE numbers, specs, photos, or part lists and get clearer matching, workable quotes, and shipment follow-up.", url: "https://certispares.com/product/part/rubber-and-bushing-parts/" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [ { "@type": "ListItem", position: 1, name: "Home", item: "https://certispares.com/" }, { "@type": "ListItem", position: 2, name: "Product", item: "https://certispares.com/product/" }, { "@type": "ListItem", position: 3, name: "Rubber And Bushing Parts", item: "https://certispares.com/product/part/rubber-and-bushing-parts/" } ] },
];
---

<BaseLayout
  title="Send Your Rubber And Bushing Parts Inquiry | Clear Matching and Workable Quotes"
  description="Send your rubber and bushing parts inquiry with OE numbers, specs, photos, or part lists. CertiSpares checks fitment first, compares workable suppliers, and follows through into inspection and shipment."
  keywords={[
  "rubber and bushing parts sourcing from China",
  "bushing parts RFQ",
  "rubber parts supplier China",
  "bushing quote support",
  "rubber and bushing inquiry",
]}
  canonical="/product/part/rubber-and-bushing-parts/"
  ogImage="/images/kit/white background shackle and bushing kit flat lay, shackle kits, bushings, pins, rubber sleeves, grease fittings, commercial vehicle suspension parts catalog photo, no watermark, square composition.png"
  jsonLd={jsonLd}
>
  <style>@import "../../../styles/product-detail.css";</style>
  <section class="hero"><div class="heroBg" style={"background-image:url('/images/kit/white background shackle and bushing kit flat lay, shackle kits, bushings, pins, rubber sleeves, grease fittings, commercial vehicle suspension parts catalog photo, no watermark, square composition.png')"} aria-hidden="true"></div><div class="overlay" aria-hidden="true"></div><div class="container"><div class="heroInner"><div><p class="eyebrow">CertiSpares / Parts Inquiry</p><h1>Send your rubber and bushing parts inquiry and get clear matching and workable quotes</h1><p class="heroLead">Send OE numbers, chassis application, bushing size, pin size, material details, photos, or your parts list. We check fitment first, then compare suppliers on the same scope, and move your inquiry into quotation, inspection, and shipment follow-up.</p><div class="heroActions"><a class="btn primary" href="/contact">Send Rubber and Bushing Inquiry</a><a class="btn" href="#what-to-send">See What to Send</a></div></div><aside class="heroPanel"><b>What to send for a faster reply</b><div class="heroList">{matchingInputs.slice(0, 5).map((item) => (<div class="heroListItem"><span class="heroDot"></span><span>{item}</span></div>))}</div></aside></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Running into these issues when sourcing rubber and bushing parts?</h2><div class="grid3">{painPoints.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Common rubber and bushing parts we handle</h2><p class="sectionDesc">Most inquiries start with a part name, OE reference, or a mixed replenishment list. Typical items include:</p><div class="chipWrap" aria-label="Supported rubber and bushing parts">{supportedParts.map((item) => (<span class="chip">{item}</span>))}</div></div></section>
  <section class="section" id="what-to-send"><div class="container"><h2 class="sectionTitle">What to send with your rubber and bushing parts inquiry</h2><div class="grid2"><div class="card"><b>Best details to send</b><ul class="bulletList">{matchingInputs.map((item) => (<li class="bulletItem"><span class="dot"></span><span>{item}</span></li>))}</ul></div><div class="card"><b>This helps avoid wrong parts</b><p>Clear inputs make it easier to confirm the right size and application, align suppliers on the same scope, and reduce mismatch later.</p></div></div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">What happens after you send the inquiry</h2><div class="grid2">{processSteps.map((step) => (<div class="card"><b>{step.title}</b><p>{step.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Why buyers use us for rubber and bushing parts inquiries</h2><div class="grid3">{whyWorkWithUs.map((item) => (<div class="card"><b>{item.title}</b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">FAQ</h2><div class="faq">{faq.map((item) => (<div class="faqItem"><strong>{item.q}</strong><p>{item.a}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><h2 class="sectionTitle">Need to start from a truck brand instead?</h2><div class="grid3">{relatedPaths.map((item) => (<div class="card"><b><a href={item.href}>{item.title}</a></b><p>{item.desc}</p></div>))}</div></div></section>
  <section class="section"><div class="container"><div class="ctaBlock"><div class="left"><b>Ready to send your rubber and bushing parts inquiry?</b><p>Send the details you already have - OE numbers, specs, photos, or your parts list. We will review it, confirm the scope, and reply with the next step.</p></div><div style="display:flex; gap:10px; flex-wrap:wrap;"><a class="btn primary" href="/contact">Send Rubber and Bushing Inquiry</a><a class="btn" href="/contact">Contact Us</a></div></div></div></section>
</BaseLayout>