      border-top:1px solid rgba(24,36,51,.08);
    }

    .footerWrap{
      background:var(--site-bg) !important;
      border-top:1px solid var(--site-line) !important;
    }

    .footerWrap .container,
    .footerWrap .footer{
      background:var(--site-bg) !important;
    }

    .footerWrap .footerTitle,
    .footerWrap .footerNav strong{
      color:rgba(234,240,255,.94) !important;
    }

    .footerWrap .footer,
    .footerWrap .footerNav span,
    .footerWrap .footerMeta{
      color:var(--site-muted) !important;
    }

    .footerWrap .footerNav a{
      background:rgba(255,255,255,.03) !important;
      border-color:var(--site-line) !important;
    }

    @media (max-width: 1120px){
      .catalogGrid{
        grid-template-columns: 120px 140px 280px minmax(0, 1fr);
      }
    }

    @media (max-width: 980px){
      .heroInner,
      .catalogGrid,
      .tipGrid{
        grid-template-columns:1fr;
      }

      h1{
        font-size:38px;
      }

      .column,
      .partsStage{
        min-height:auto;
      }

      .catalogGrid{
        min-height:0;
      }

      .brandBtn:hover,
      .brandBtn.is-active,
      .assemblyBtn:hover,
      .assemblyBtn.is-active,
      .modelBtn:hover,
      .modelBtn.is-active{
        transform:none;
      }

      .brandList{
        grid-template-columns:repeat(auto-fit, minmax(110px, 1fr));
      }

      .assemblyList{
        grid-template-columns:repeat(auto-fit, minmax(120px, 1fr));
      }
    }
  </style>

  <section class="hero">
    <div class="heroBg"></div>
    <div class="overlay"></div>
    <div class="container">
      <div class="heroInner">
        <div>
          <p class="eyebrow">CertiSpares / Product</p>
          <h1>Find matching service parts by brand, assembly, and platform.</h1>
          <p class="heroLead">
            This page helps international buyers identify the right platform faster, reduce mismatch risk, and move from
            platform confirmation to parts inquiry with better sourcing efficiency.
          </p>
        </div>

        <aside class="heroPanel">
          <b>Buyer Value</b>
          <div class="heroList">
            <div class="heroListItem"><span class="heroDot"></span><span>Structured by brand, major assembly, and platform for faster part identification.</span></div>
            <div class="heroListItem"><span class="heroDot"></span><span>Matching parts categories are grouped under each platform to help reduce sourcing mistakes.</span></div>
            <div class="heroListItem"><span class="heroDot"></span><span>Built for inquiry-based trade when buyers send part names, OEM numbers, or reference photos.</span></div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <div class="contentSurface">
    <section class="section">
      <div class="container">
        <h2 class="sectionTitle">Platform-Based Parts Coverage</h2>
        <p class="sectionLead">
          This directory groups each platform with the corresponding service parts and repair categories, making it easier
          for buyers in Africa, Southeast Asia, and South Asia to confirm application range before sending an RFQ.
        </p>
        <p class="sectionLead" style="margin-top:-4px;">
          If the required part is not listed in this catalog, send us your RFQ or contact our team directly. We will reply
          within 24 hours with application checking and sourcing support.
        </p>

        <div class="catalogShell">
          <div class="catalogGrid">
            <section class="column">
              <h3 class="columnTitle">Brand</h3>
              <div class="brandList" id="brandList">
                {groupedBrands.map((brand, index) => (
                  <button
                    class={`brandBtn ${index === 0 ? "is-active" : ""}`}
                    type="button"
                    data-brand-id={brand.id}
                  >
                    <span class="brandMark">
                      <img src={brand.logoImage} alt={brand.logoAlt} loading="lazy" decoding="async" />
                    </span>
                    <span class="brandName">{brand.name}</span>
                  </button>
                ))}
              </div>
            </section>

            <section class="column">
              <h3 class="columnTitle">Assembly</h3>
              <div class="assemblyList" id="assemblyList">
                {initialBrand?.assemblies.map((assembly, index) => (
                  <button
                    class={`assemblyBtn ${index === 0 ? "is-active" : ""}`}
                    type="button"
                    data-assembly-key={assembly.key}
                  >
                    <span class="assemblyIcon">
                      <img src={assembly.icon} alt={assembly.label} loading="lazy" decoding="async" />
                    </span>
                    <span class="assemblyText">
                      <b>{assembly.label}</b>
                      <span>{assembly.models.length} platform{assembly.models.length === 1 ? "" : "s"}</span>
                    </span>
                  </button>
                ))}
              </div>
            </section>

            <section class="column">
              <h3 class="columnTitle">Platform</h3>
              <div class="modelList" id="modelList">
                {initialAssembly?.models.map((model, index) => (
                  <button
                    class={`modelBtn ${index === 0 ? "is-active" : ""}`}
                    type="button"
                    data-model-id={model.id}
                    style={`animation-delay:${index * 0.05}s;`}
                  >
                    <span class="modelThumb">
                      <img src={model.image} alt={model.title} loading="lazy" decoding="async" />
                    </span>
                    <span class="modelMeta">
                      <b>{model.title}</b>
                      <span>{model.subtitle}</span>
                    </span>
                  </button>
                ))}
              </div>
            </section>

            <section class="partsStage" id="partsStage">
              {initialModel ? (
                <>
                  <div class="partsBreadcrumb">{initialBrand?.logoText} / {initialAssembly?.label} / {initialModel.title}</div>
                  <div class="stageHead">
                    <div class="stageThumb">
                      <img src={initialModel.image} alt={initialModel.title} loading="lazy" decoding="async" />
                    </div>
                    <div class="stageMeta">
                      <small>Parts Support</small>
                      <h3>Supported Parts for {initialModel.title}</h3>
                      <p>{initialModel.subtitle} | {initialModel.band}</p>
                      <div class="stageSupport">We support selected repair and service parts for this platform.</div>
                    </div>
                  </div>

                  <div class="partsSectionTitle">Available Parts Categories</div>
                  <div class="partsRow">
                    {initialModel.parts.map((part) => (
                      <div class="partGroup">
                        <div class="partCard">
                          <div class="partThumb">
                            <img src={part.image} alt={part.name} loading="lazy" decoding="async" />
                          </div>
                            <div class="partMeta">
                              <div class="partMetaTop">
                                <div>
                                  <b>{part.name}</b>
                                  <span>{part.note}</span>
                                </div>
                                <span class="partChevron" aria-hidden="true">⌄</span>
                              </div>
                            </div>
                          </div>
                        <div class="partDetails">
                          <div class="detailList">
                            {part.details.map((detail) => (
                              <div class="detailItem">{detail}</div>
                            ))}
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div class="rfqPrompt">
                    <strong>Looking for parts under this platform?</strong>
                    <p>Send us your part name, OEM number, or photos for checking.</p>
                    <a class="btn primary" href="/contact">Send RFQ for This Platform</a>
                  </div>
                </>
              ) : (
                <div class="emptyHint">Select a model to preview the matching part scope.</div>
              )}
            </section>
          </div>
        </div>
      </div>
    </section>

    <section class="section proofSection">
      <div class="container">
        <h2 class="sectionTitle">Why This Structure Works for Buyers</h2>
        <div class="tipGrid">
          <div class="tipCard">
            <b>Platform-based matching is easier to review.</b>
            <p>Buyers can confirm the relevant platform first and then review the available parts categories under that system.</p>
          </div>
          <div class="tipCard">
            <b>It helps reduce mismatch risk before quotation.</b>
            <p>Brand, assembly, and platform are narrowed down before inquiry, which supports more accurate parts checking.</p>
          </div>
          <div class="tipCard">
            <b>It supports more efficient RFQ communication.</b>
            <p>Buyers can send part names, OEM numbers, or photos against a selected platform, making follow-up faster for both sides.</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ catalogData }}>
    (() => {
      const data = JSON.parse(catalogData);
      const brandList = document.getElementById("brandList");
      const assemblyList = document.getElementById("assemblyList");
      const modelList = document.getElementById("modelList");
      const partsStage = document.getElementById("partsStage");
      if (!brandList || !assemblyList || !modelList || !partsStage || !Array.isArray(data) || data.length === 0) return;

      let activeBrand = data[0];
      let activeAssembly = activeBrand.assemblies[0];
      let activeModel = activeAssembly?.models[0];

      const renderAssemblies = () => {
        assemblyList.innerHTML = activeBrand.assemblies.map((assembly, index) => `
          <button class="assemblyBtn ${index === 0 ? "is-active" : ""}" type="button" data-assembly-key="${assembly.key}">
            <span class="assemblyIcon"><img src="${assembly.icon}" alt="${assembly.label}" loading="lazy" decoding="async" /></span>
            <span class="assemblyText">
              <b>${assembly.label}</b>
              <span>${assembly.models.length} platform${assembly.models.length === 1 ? "" : "s"}</span>
            </span>
          </button>
        `).join("");

        activeAssembly = activeBrand.assemblies[0];
        activeModel = activeAssembly?.models[0];
      };

      const renderModels = () => {
        if (!activeAssembly) {
          modelList.innerHTML = "";
          return;
        }

        modelList.innerHTML = activeAssembly.models.map((model, index) => `
          <button class="modelBtn ${index === 0 ? "is-active" : ""}" type="button" data-model-id="${model.id}" style="animation-delay:${index * 0.05}s;">
            <span class="modelThumb">
              <img src="${model.image}" alt="${model.title}" loading="lazy" decoding="async" />
            </span>
            <span class="modelMeta">
              <b>${model.title}</b>
              <span>${model.subtitle}</span>
            </span>
          </button>
        `).join("");

        activeModel = activeAssembly.models[0];
      };

      const renderParts = () => {
        if (!activeModel) {
          partsStage.innerHTML = '<div class="emptyHint">Select a model to preview the matching part scope.</div>';
          return;
        }

        partsStage.classList.add("is-switching");

        partsStage.innerHTML = `
          <div class="partsBreadcrumb">${activeBrand.logoText} / ${activeAssembly.label} / ${activeModel.title}</div>
          <div class="stageHead">
            <div class="stageThumb">
              <img src="${activeModel.image}" alt="${activeModel.title}" loading="lazy" decoding="async" />
            </div>
            <div class="stageMeta">
              <small>Parts Support</small>
              <h3>Supported Parts for ${activeModel.title}</h3>
              <p>${activeModel.subtitle} | ${activeModel.band}</p>
              <div class="stageSupport">We support selected repair and service parts for this platform.</div>
            </div>
          </div>
          <div class="partsSectionTitle">Available Parts Categories</div>
          <div class="partsRow">
            ${activeModel.parts.map((part) => `
              <div class="partGroup">
                <div class="partCard">
                  <div class="partThumb">
                    <img src="${part.image}" alt="${part.name}" loading="lazy" decoding="async" />
                  </div>
                  <div class="partMeta">
                    <div class="partMetaTop">
                      <div>
                        <b>${part.name}</b>
                        <span>${part.note}</span>
                      </div>
                      <span class="partChevron" aria-hidden="true">⌄</span>
                    </div>
                  </div>
                </div>
                <div class="partDetails">
                  <div class="detailList">
                    ${part.details.map((detail) => `<div class="detailItem">${detail}</div>`).join("")}
                  </div>
                </div>
              </div>
            `).join("")}
          </div>
          <div class="rfqPrompt">
            <strong>Looking for parts under this platform?</strong>
            <p>Send us your part name, OEM number, or photos for checking.</p>
            <a class="btn primary" href="/contact">Send RFQ for This Platform</a>
          </div>
        `;

        requestAnimationFrame(() => {
          partsStage.classList.remove("is-switching");
        });
      };

      const setBrandActive = (brandId) => {
        if (activeBrand?.id === brandId) return;

        const nextBrand = data.find((item) => item.id === brandId);
        if (!nextBrand) return;
        activeBrand = nextBrand;

        Array.from(brandList.querySelectorAll(".brandBtn")).forEach((button) => {
          button.classList.toggle("is-active", button.dataset.brandId === brandId);
        });

        renderAssemblies();
        renderModels();
        renderParts();
      };

      const setAssemblyActive = (assemblyKey) => {
        if (activeAssembly?.key === assemblyKey) return;

        const nextAssembly = activeBrand.assemblies.find((item) => item.key === assemblyKey);
        if (!nextAssembly) return;
        activeAssembly = nextAssembly;

        Array.from(assemblyList.querySelectorAll(".assemblyBtn")).forEach((button) => {
          button.classList.toggle("is-active", button.dataset.assemblyKey === assemblyKey);
        });

        renderModels();
        renderParts();
      };

      const setModelActive = (modelId) => {
        if (activeModel?.id === modelId) return;

        const nextModel = activeAssembly?.models.find((item) => item.id === modelId);
        if (!nextModel) return;
        activeModel = nextModel;

        Array.from(modelList.querySelectorAll(".modelBtn")).forEach((button) => {
          button.classList.toggle("is-active", button.dataset.modelId === modelId);
        });

        renderParts();
      };

      partsStage.addEventListener("click", (event) => {
        const group = event.target.closest(".partGroup");
        if (!group) return;

        const nextOpen = !group.classList.contains("is-open");

        Array.from(partsStage.querySelectorAll(".partGroup")).forEach((item) => {
          item.classList.remove("is-open");
        });

        if (nextOpen) {
          group.classList.add("is-open");
        }
      });

      const bindAssemblyEvents = () => {
        assemblyList.addEventListener("mouseover", (event) => {
          const button = event.target.closest(".assemblyBtn");
          if (!button) return;
          setAssemblyActive(button.dataset.assemblyKey);
        });

        assemblyList.addEventListener("click", (event) => {
          const button = event.target.closest(".assemblyBtn");
          if (!button) return;
          setAssemblyActive(button.dataset.assemblyKey);
        });
      };

      const bindModelEvents = () => {
        modelList.addEventListener("mouseover", (event) => {
          const button = event.target.closest(".modelBtn");
          if (!button) return;
          setModelActive(button.dataset.modelId);
        });

        modelList.addEventListener("click", (event) => {
          const button = event.target.closest(".modelBtn");
          if (!button) return;
          setModelActive(button.dataset.modelId);
        });
      };

      brandList.addEventListener("mouseover", (event) => {
        const button = event.target.closest(".brandBtn");
        if (!button) return;
        setBrandActive(button.dataset.brandId);
      });

      brandList.addEventListener("click", (event) => {
        const button = event.target.closest(".brandBtn");
        if (!button) return;
        setBrandActive(button.dataset.brandId);
      });

      bindAssemblyEvents();
      bindModelEvents();
      renderParts();
    })();
  </script>
</BaseLayout>
