const partSystems = [
  {
    label: "Engine parts",
    href: "/product/part/engine-parts/",
    image: "/images/Engine-Parts.png",
    alt: "Engine parts",
  },
  {
    label: "Brake system parts",
    href: "/product/part/brake-system-parts/",
    image: "/images/Brake-System.png",
    alt: "Brake system parts",
  },
  {
    label: "Suspension parts",
    href: "/product/part/suspension-parts/",
    image: "/images/Suspension.png",
    alt: "Suspension parts",
  },
  {
    label: "Steering parts",
    href: "/product/part/steering-parts/",
    image: "/images/assemblies/assembly-suspension.png",
    alt: "Steering parts",
  },
  {
    label: "Axle and wheel-end parts",
    href: "/product/part/axle-and-wheel-end-parts/",
    image: "/images/assemblies/assembly-axle.png",
    alt: "Axle and wheel-end parts",
  },
  {
    label: "Clutch and transmission parts",
    href: "/product/part/clutch-and-transmission-parts/",
    image: "/images/kit/white background clutch and release parts flat lay, clutch disc, pressure plate, release bearing, pilot bearing, clutch fork, clean truck drivetrain catalog photo, no watermark, square composit.png",
    alt: "Clutch and transmission parts",
  },
  {
    label: "Air system parts",
    href: "/product/part/air-system-parts/",
    image: "/images/kit/white background brake chamber and actuation parts flat lay, brake chamber, slack adjuster, push rod, clevis, repair diaphragm, air brake system parts catalog photo, no watermark, square composition.png",
    alt: "Air system parts",
  },
  {
    label: "Electrical parts",
    href: "/product/part/electrical-parts/",
    image: "/images/kit/white background engine replacement parts flat lay, water pump, thermostat, sensors, injectors, hoses, commercial vehicle parts catalog style, no watermark, square composition.png",
    alt: "Electrical parts",
  },
  {
    label: "Cooling system parts",
    href: "/product/part/cooling-system-parts/",
    image: "/images/kit/white background engine replacement parts flat lay, water pump, thermostat, sensors, injectors, hoses, commercial vehicle parts catalog style, no watermark, square composition.png",
    alt: "Cooling system parts",
  },
  {
    label: "Rubber and bushing parts",
    href: "/product/part/rubber-and-bushing-parts/",
    image: "/images/kit/white background shackle and bushing kit flat lay, shackle kits, bushings, pins, rubber sleeves, grease fittings, commercial vehicle suspension parts catalog photo, no watermark, square composition.png",
    alt: "Rubber and bushing parts",
  },
];

const entryCards = [
  {
    title: "Browse by brand",
    desc: "Use this path when the buyer already knows the truck platform, brand family, or reference vehicle.",
    bullets: [
      "Better for platform-led RFQs",
      "Useful when the RFQ starts from VIN, truck model, or an old supplier reference",
      "Helps organize matching before quotation starts",
    ],
    href: "#brand-entry",
    cta: "See brand entry",
  },
  {
    title: "Browse by part system",
    desc: "Use this path when the inquiry starts from the category itself, especially for mixed-brand replenishment or category-led RFQs.",
    bullets: [
      "Better for category-led replenishment",
      "Useful when one RFQ covers multiple brands under the same system",
      "Helps align suppliers on the same scope before quotation",
    ],
    href: "#part-entry",
    cta: "See part systems",
  },
];

const processSteps = [
  {
    title: "Send the references you have",
    desc: "Start with OE numbers, VIN, photos, part names, specs, or the parts list already in hand.",
  },
  {
    title: "We confirm matching scope",
    desc: "We review the RFQ first, then clarify fitment, application, and scope before quotations move out.",
  },
  {
    title: "We compare workable suppliers",
    desc: "We compare suppliers on the same scope so quotes are easier to review and easier to act on.",
  },
  {
    title: "We follow up on QC, packing, documents, and shipment",
    desc: "After confirmation, we keep the order moving through inspection points, packing checks, documents, and shipping coordination.",
  },
];

const whyThisStructureWorks = [
  {
    title: "It matches how RFQs actually start",
    desc: "Some buyers start from the truck platform. Others start from the part category. This structure fits both.",
  },
  {
    title: "It helps buyers send clearer inquiry inputs",
    desc: "The clearer the input, the easier it is to confirm fitment, align suppliers, and move the RFQ forward.",
  },
  {
    title: "It supports inquiry-based sourcing instead of catalog-style search",
    desc: "Buyers can start from real RFQ references instead of trying to force every inquiry through a catalog path.",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Truck Parts Sourcing Entry by Brand or Part System",
    description:
      "A structured entry page for buyers who want to source truck parts from China by brand or by part category, using OE numbers, VIN, photos, and RFQ details.",
    url: "https://certispares.com/product/",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://certispares.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Product",
        item: "https://certispares.com/product/",
      },
    ],
  },
];
---

<BaseLayout
  title="Truck Parts Sourcing by Brand and Part System | CertiSpares"
  description="Browse truck parts sourcing support by brand or by part system. CertiSpares handles RFQs through OE numbers, VIN, photos, and vehicle details."
  keywords={["truck parts catalog by brand", "truck parts by part system", "OE number sourcing", "VIN-based truck parts sourcing", "commercial vehicle parts sourcing China"]}
  canonical="/product/"
  ogImage="/images/Brake-System.png"
  jsonLd={jsonLd}
>
  <style>
    :root{
      --bg:#eef3f7;
      --text:#1d2a36;
      --muted:#5f6d86;
      --line:rgba(29,42,54,.10);
      --brand:#3957E9;
    }

    :global(main){
      background:linear-gradient(180deg, #f5f8fc 0%, #eef3f7 100%);
    }

    :global(.topbar){
      background:#111F43 !important;
      background-color:#111F43 !important;
      opacity:1 !important;
      backdrop-filter:none !important;
      -webkit-backdrop-filter:none !important;
      border-bottom:1px solid #111F43 !important;
      box-shadow:none !important;
    }

    :global(.menu),
    :global(.menu a),
    :global(.menu a:hover){
      color:#fff;
    }

    :global(.menu a.active),
    :global(.drawerNav a.active){
      color:#fff;
      background:rgba(57,87,233,.18);
      border-color:rgba(57,87,233,.32);
    }

    :global(.cta){
      background:#3957E9;
      color:#fff;
    }

    .hero{
      position:relative;
      padding:46px 0 20px;
      border-bottom:1px solid var(--line);
      overflow:hidden;
      isolation:isolate;
      background:#0b1020;
    }

    .heroBg{
      position:absolute;
      inset:0;
      z-index:-2;
      background:url("/images/Brake-System.png") center/cover no-repeat;
      filter:blur(2px) saturate(.95) contrast(.95) brightness(.9);
      transform:scale(1.03);
    }

    .overlay{
      position:absolute;
      inset:0;
      z-index:-1;
      background:
        linear-gradient(180deg, rgba(11,16,32,.28) 0%, rgba(11,16,32,.86) 72%, rgba(11,16,32,1) 100%),
        radial-gradient(900px 420px at 25% 20%, rgba(57,87,233,.22), transparent 60%);
    }

    .heroInner{
      position:relative;
      padding:2px 0 22px;
      display:grid;
      grid-template-columns:minmax(0, 1.15fr) minmax(320px, .85fr);
      gap:22px;
      align-items:end;
    }

    .eyebrow{
      margin:0 0 10px;
      font-size:12px;
      font-weight:900;
      letter-spacing:.14em;
      text-transform:uppercase;
      color:rgba(232,240,255,.76);
    }

    h1{
      margin:0 0 14px;
      font-size:46px;
      line-height:1.04;
      letter-spacing:-.65px;
      color:#fff;
      max-width:760px;
    }

    .heroLead{
      margin:0;
      max-width:740px;
      color:rgba(232,240,255,.84);
      line-height:1.8;
    }

    .heroPanel{
      padding:20px;
      border-radius:24px;
      background:rgba(255,255,255,.08);
      border:1px solid rgba(255,255,255,.12);
      box-shadow:0 18px 50px rgba(0,0,0,.18);
      backdrop-filter:blur(10px);
    }

    .heroPanel b{
      display:block;
      margin-bottom:10px;
      color:#fff;
      font-size:16px;
    }

    .heroList{
      display:grid;
      gap:10px;
    }

    .heroListItem{
      display:flex;
      gap:10px;
      align-items:flex-start;
      color:rgba(255,255,255,.9);
      line-height:1.6;
      font-size:14px;
    }

    .heroDot{
      width:10px;
      height:10px;
      border-radius:999px;
      margin-top:7px;
      background:#4d79ff;
      flex:0 0 10px;
    }

    .sectionTitle{
      font-size:28px;
      margin:0 0 12px;
      letter-spacing:-.2px;
      color:#1d2a36;
    }

    .sectionDesc{
      margin:0 0 18px;
      color:var(--muted);
      line-height:1.75;
      max-width:980px;
    }

    .grid2{
      display:grid;
      grid-template-columns:repeat(2, 1fr);
      gap:14px;
    }

    .grid4{
      display:grid;
      grid-template-columns:repeat(4, 1fr);
      gap:12px;
    }

    .card{
      background:#fff;
      border:1px solid rgba(29,42,54,.10);
      border-radius:20px;
      padding:18px;
      box-shadow:0 14px 32px rgba(24,39,56,.05);
    }

    .card b{
      display:block;
      margin-bottom:8px;
      color:#1d2a36;
    }

    .card p{
      margin:0;
      color:var(--muted);
      line-height:1.7;
    }

    .bulletList{
      margin:14px 0 0;
      padding:0;
      list-style:none;
      display:grid;
      gap:10px;
    }

    .bulletItem{
      display:flex;
      gap:10px;
      align-items:flex-start;
      color:var(--muted);
      line-height:1.6;
    }

    .dot{
      width:10px;
      height:10px;
      border-radius:999px;
      margin-top:7px;
      background:#4A5462;
      flex:0 0 10px;
    }

    .entryActions{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:16px;
    }

    .entryActions .btn.primary{
      color:#fff;
      background:#3957E9;
    }

    .entryActions .btn:not(.primary){
      color:#fff;
      background:#3957E9;
      border-color:#3957E9;
    }

    .chipWrap{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }

    .entryTileGrid{
      display:grid;
      grid-auto-flow:column;
      grid-auto-columns:96px;
      gap:12px;
      overflow-x:auto;
      padding:2px 2px 8px;
      scrollbar-width:thin;
      scroll-snap-type:x proximity;
    }

    .entryTileGrid::-webkit-scrollbar{
      height:8px;
    }

    .entryTileGrid::-webkit-scrollbar-thumb{
      background:rgba(57,87,233,.18);
      border-radius:999px;
    }

    .entryTileGrid::-webkit-scrollbar-track{
      background:rgba(29,42,54,.05);
      border-radius:999px;
    }

    .entryTile{
      display:flex;
      flex-direction:column;
      gap:8px;
      min-height:100%;
      min-width:96px;
      padding:10px 10px 12px;
      border-radius:18px;
      background:#fff;
      border:1px solid rgba(29,42,54,.10);
      box-shadow:0 10px 24px rgba(24,39,56,.05);
      color:inherit;
      text-decoration:none;
      transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;
      scroll-snap-align:start;
    }

    .entryTile:hover{
      transform:translateY(-2px);
      box-shadow:0 14px 32px rgba(24,39,56,.08);
      border-color:rgba(57,87,233,.22);
    }

    .entryMedia{
      position:relative;
      display:flex;
      align-items:center;
      justify-content:center;
      aspect-ratio:1 / 1;
      min-height:auto;
      border-radius:18px;
      overflow:hidden;
      background:linear-gradient(180deg, #ffffff 0%, #f4f8fc 100%);
      border:1px solid rgba(29,42,54,.08);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.7);
    }

    .entryMedia::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(120deg, transparent 0%, rgba(57,87,233,.06) 34%, transparent 66%),
        radial-gradient(180px 80px at 50% -10%, rgba(57,87,233,.10), transparent 70%);
      pointer-events:none;
    }

    .brandEntry .entryMedia{
      padding:10px;
    }

    .brandEntry img{
      position:relative;
      z-index:1;
      max-width:74px;
      max-height:28px;
      width:auto;
      height:auto;
      object-fit:contain;
      display:block;
      filter:saturate(.95) contrast(1.02);
    }

    .partEntry .entryMedia{
      align-items:stretch;
    }

    .partEntry img{
      width:100%;
      height:100%;
      object-fit:cover;
      object-position:center;
      display:block;
    }

    .entryBody{
      display:grid;
      gap:2px;
    }

    .entryBody b{
      display:block;
      color:#1d2a36;
      font-size:12px;
      line-height:1.3;
      text-align:center;
      word-break:break-word;
      letter-spacing:-.08px;
    }

    .entryBody p{
      margin:0;
      color:var(--muted);
      font-size:13px;
      line-height:1.65;
      text-align:center;
    }

    .brandEntry .entryBody,
    .partEntry .entryBody{
      justify-items:center;
    }

    .chip{
      display:inline-flex;
      align-items:center;
      padding:9px 12px;
      border-radius:999px;
      background:#fff;
      border:1px solid rgba(29,42,54,.10);
      color:#415066;
      font-size:13px;
      font-weight:800;
      box-shadow:0 8px 18px rgba(24,39,56,.04);
    }

    a.chip{
      color:#3957E9;
      border-color:rgba(57,87,233,.18);
    }

    a.chip:hover{
      transform:translateY(-1px);
      box-shadow:0 12px 24px rgba(24,39,56,.08);
    }

    .processGrid{
      display:grid;
      grid-template-columns:repeat(4, 1fr);
      gap:14px;
    }

    .stepNo{
      display:inline-flex;
      width:34px;
      height:34px;
      border-radius:12px;
      align-items:center;
      justify-content:center;
      margin-bottom:12px;
      background:rgba(74,84,98,.08);
      border:1px solid rgba(74,84,98,.18);
      color:#4A5462;
      font-weight:950;
    }

    .ctaBlock{
      margin-top:14px;
      border-radius:20px;
      padding:18px;
      background:linear-gradient(135deg, rgba(57,87,233,.10), rgba(255,255,255,.92));
      border:1px solid rgba(57,87,233,.16);
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:14px;
      box-shadow:0 16px 40px rgba(24,39,56,.05);
    }

    .ctaBlock .left b{
      display:block;
      margin-bottom:6px;
      color:#1d2a36;
    }

    .ctaBlock .left p{
      margin:0;
      color:var(--muted);
      line-height:1.75;
      max-width:760px;
    }

    .ctaBlock .btn.primary{
      color:#fff;
      background:#3957E9;
    }

    .ctaBlock .btn:not(.primary){
      color:#fff;
      background:#3957E9;
      border-color:#3957E9;
    }

    :global(.footerWrap){
      background:transparent;
      border-top:1px solid rgba(29,42,54,.10);
    }

    :global(.footerTitle),
    :global(.footerNav strong){
      color:#1d2a36;
    }

    :global(.footer),
    :global(.footerNav span){
      color:var(--muted);
    }

    :global(.footerNav a){
      background:#fff;
      border-color:rgba(29,42,54,.10);
    }

    @media (max-width: 980px){
      .heroInner{ grid-template-columns:1fr; }
      h1{ font-size:38px; }
      .grid2,
      .grid4,
      .processGrid{
        grid-template-columns:1fr;
      }
      .ctaBlock{
        flex-direction:column;
        align-items:flex-start;
      }
    }
  </style>

  <section class="hero">
    <div class="heroBg" aria-hidden="true"></div>
    <div class="overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="heroInner">
        <div>
          <p class="eyebrow">CertiSpares / Product Entry</p>
          <h1>Find the right truck parts from China — even without exact part numbers.</h1>
          <p class="heroLead">
            Start from the truck brand or the part system.
            Send OE numbers, VIN, photos, part names, specs, or your parts list.
            We review the matching scope first, then move the RFQ into quotation, inspection, and shipping follow-up.
          </p>
        </div>

        <aside class="heroPanel">
          <b>Choose the entry path that fits your RFQ</b>
          <div class="heroList">
            <div class="heroListItem"><span class="heroDot"></span><span>Use the brand path when the RFQ starts from a known vehicle platform or brand reference.</span></div>
            <div class="heroListItem"><span class="heroDot"></span><span>Use the part-system path when the inquiry starts from the category itself, especially for mixed-brand replenishment.</span></div>
            <div class="heroListItem"><span class="heroDot"></span><span>Then send the references you already have so matching and quotation can move forward on a clearer scope.</span></div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Choose Your Entry Path</h2>
      <p class="sectionDesc">
        Some RFQs start from a truck brand. Others start from the part category. Both paths lead into the same matching,
        quotation, inspection, and shipping workflow.
      </p>

      <div class="grid2">
        {entryCards.map((card) => (
          <div class="card">
            <b>{card.title}</b>
            <p>{card.desc}</p>
            <ul class="bulletList">
              {card.bullets.map((bullet) => (
                <li class="bulletItem"><span class="dot"></span><span>{bullet}</span></li>
              ))}
            </ul>
            <div class="entryActions">
              <a class="btn primary" href={card.href}>{card.cta}</a>
              <a class="btn" href="/contact">Send RFQ</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="brand-entry">
      <div class="container">
        <h2 class="sectionTitle">Brand Entry</h2>
        <p class="sectionDesc">
          Start here when the inquiry already begins with the truck brand, platform family, or reference vehicle.
        </p>
        <div class="entryTileGrid" aria-label="Brand entry options">
          {brandGroups.map((brand) => (
            <a class="entryTile brandEntry" href={brand.href}>
              <div class="entryMedia">
                <img src={brand.image} alt={brand.alt} loading="lazy" decoding="async" />
              </div>
              <div class="entryBody">
                <b>{brand.label}</b>
              </div>
            </a>
          ))}
        </div>
        <div class="ctaBlock">
          <div class="left">
            <b>Start from the platform your buyer already knows</b>
            <p>
              Each brand page shows the systems we can usually help with and what to send before quotation starts.
            </p>
          </div>
          <div>
          <a class="btn primary" href="/contact">Send Brand RFQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="part-entry">
      <div class="container">
        <h2 class="sectionTitle">Part-System Entry</h2>
        <p class="sectionDesc">
          Start here when the RFQ begins with the category itself, especially for mixed-brand replenishment or system-led buying.
        </p>
        <div class="entryTileGrid" aria-label="Part system entry options">
          {partSystems.map((system) => (
            <a class="entryTile partEntry" href={system.href}>
              <div class="entryMedia">
                <img src={system.image} alt={system.alt} loading="lazy" decoding="async" />
              </div>
              <div class="entryBody">
                <b>{system.label}</b>
              </div>
            </a>
          ))}
        </div>
        <div class="ctaBlock">
          <div class="left">
            <b>Start from the part system when the RFQ is category-led</b>
            <p>
              Each part-system page shows the common parts we handle, what to send, and how the inquiry moves forward after matching starts.
            </p>
          </div>
        <div>
          <a class="btn primary" href="/contact">Send Parts RFQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">What to send before matching starts</h2>
      <p class="sectionDesc">
        The clearer the input, the easier it is to confirm fitment, align suppliers, and move the RFQ forward.
      </p>
      <div class="grid4">
        <div class="card"><b>OE number or part number</b><p>Best starting point when the buyer already has reference numbers.</p></div>
        <div class="card"><b>VIN or vehicle details</b><p>Useful when fitment needs to be checked from vehicle information first.</p></div>
        <div class="card"><b>Photos or old samples</b><p>Helpful when numbers are incomplete, unclear, or missing.</p></div>
        <div class="card"><b>Specs or dimensions where needed</b><p>Important for system-led RFQs where fitment depends on size, thread, or application details.</p></div>
        <div class="card"><b>Quantity and destination</b><p>Needed to line up quotation, consolidation, and shipment planning.</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">What happens after you send the inquiry</h2>
      <div class="processGrid">
        {processSteps.map((step, index) => (
          <div class="card">
            <div class="stepNo">{index + 1}</div>
            <b>{step.title}</b>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
      <div class="ctaBlock">
        <div class="left">
          <b>Need the full workflow?</b>
          <p>
            Review <a href="/how-it-works">how the process works</a>, our <a href="/sourcing">truck parts sourcing service</a>,
            and <a href="/capabilities">quality control and sourcing support</a> for the broader commercial and operational view.
          </p>
        </div>
        <div>
          <a class="btn primary" href="/how-it-works">See Workflow</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Why buyers use this entry structure</h2>
      <div class="grid2">
        {whyThisStructureWorks.map((item) => (
          <div class="card">
            <b>{item.title}</b>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="ctaBlock">
        <div class="left">
          <b>Ready to send the inquiry?</b>
          <p>
            Send the references you already have. We will review the inquiry and reply with the next workable sourcing step.
          </p>
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a class="btn primary" href="/contact">Send RFQ</a>
          <a class="btn" href="/contact">See Contact Options</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
