const engineMakerMap: Array<{ pattern: RegExp; maker: string }> = [
  { pattern: /^(ISF|ISG|X13)/i, maker: "Cummins" },
  { pattern: /^F3\.8/i, maker: "Foton Cummins" },
  { pattern: /^4J28/i, maker: "Quanchai" },
  { pattern: /^DAM/i, maker: "DAM" },
  { pattern: /^(4W|LJ|Liuzhou Wuling)/i, maker: "Liuji" },
];

const gearboxMakerMap: Array<{ pattern: RegExp; maker: string }> = [
  { pattern: /^ZF/i, maker: "ZF" },
  { pattern: /^12JSD/i, maker: "FAST" },
  { pattern: /^8JS/i, maker: "FAST" },
  { pattern: /^WLY/i, maker: "WLY" },
  { pattern: /^(MR|DAT|5G|5MT|6S|5S)/i, maker: "Gearbox" },
];

const getMakerLabel = (value: string, kind: AssemblyKey) => {
  if (kind === "axle") return "Axle";
  if (kind === "brake") return "Brake";
  const source = kind === "engine" ? engineMakerMap : gearboxMakerMap;
  const match = source.find((item) => item.pattern.test(value));
  return match?.maker || (kind === "engine" ? "Engine" : "Gearbox");
};

const makeDisplayTitle = (value: string, kind: AssemblyKey) => {
  const maker = getMakerLabel(value, kind);
  const normalizedValue = kind === "engine"
    ? value.trim().replace(/^Liuzhou Wuling\b/i, "Liuji")
    : value.trim();
  if (!normalizedValue) return maker;

  if (kind === "engine" && normalizedValue.toLowerCase().startsWith("liuji ")) {
    return `Engine ${normalizedValue}`.trim();
  }

  return normalizedValue.toLowerCase().startsWith(maker.toLowerCase())
    ? normalizedValue
    : `${maker} ${normalizedValue}`.trim();
};

