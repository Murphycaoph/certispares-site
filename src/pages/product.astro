---
import BaseLayout from "../layouts/BaseLayout.astro";
import { productCards } from "../lib/productCatalog";
import { readdirSync } from "node:fs";
import { basename, extname } from "node:path";
import { fileURLToPath } from "node:url";

type AssemblyKey = "engine" | "gearbox" | "axle" | "brake" | "suspension";
type ProductBand = "light_truck" | "medium_truck" | "heavy_truck" | "mini_truck";
type BandBucket = "light" | "medium" | "heavy";

type PartItem = {
  name: string;
  image: string;
  note: string;
  details: string[];
  prompt: string;
};

type ModelItem = {
  id: string;
  title: string;
  subtitle: string;
  brandCluster: string;
  submodelCode: string;
  image: string;
  band: string;
  parts: PartItem[];
};

type AssemblyItem = {
  key: AssemblyKey;
  label: string;
  icon: string;
  note: string;
  models: ModelItem[];
};

type BrandItem = {
  id: string;
  name: string;
  shortName: string;
  logoText: string;
  logoImage: string;
  logoAlt: string;
  assemblies: AssemblyItem[];
};

