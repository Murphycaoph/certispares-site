type PlatformImageAsset = {
  assembly: AssemblyKey | null;
  productBand: ProductBand | null;
  baseName: string;
  normalizedBaseName: string;
  url: string;
  isFallback: boolean;
};

const assemblyDefaultImages: Record<AssemblyKey, string> = {
  engine: "/images/Engine-Parts.png",
  gearbox: "/images/Engine-Parts.png",
  axle: "/images/Suspension.png",
  brake: "/images/Brake-System.png",
  suspension: "/images/Suspension.png",
};

const platformLibraryRoot = fileURLToPath(new URL("../../public/images/platform-library", import.meta.url));
const kitImageRoot = fileURLToPath(new URL("../../public/images/kit", import.meta.url));
const supportedImageExtensions = new Set([".png", ".jpg", ".jpeg", ".webp", ".avif"]);

const normalizeImageKey = (value: string) =>
  value
    .toLowerCase()
    .replace(/\.[^.]+$/, "")
    .replace(/[^a-z0-9]+/g, " ")
    .trim()
    .replace(/\s+/g, " ");

const makeLooseImageKey = (value: string) =>
  normalizeImageKey(value)
    .replace(/\b(family|product|closeup|longshot|features|graphic|with|intarder|bus)\b/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const compactImageKey = (value: string) => makeLooseImageKey(value).replace(/\s+/g, "");

const engineIdentityTokens = [
  "cummins",
  "foton cummins",
  "quanchai",
  "yuchai",
  "yunnei",
  "weichai",
  "sinotruk",
  "jmc",
  "jac",
  "dfsk",
  "sgmw",
  "dongan",
  "faw",
  "liuji",
  "liuzhou wuling",
  "beinei",
] as const;

const getEngineIdentityKey = (value: string) => {
  const looseKey = makeLooseImageKey(value);
  return engineIdentityTokens.find((token) => looseKey.includes(token)) ?? null;
};

const isCompatibleEngineIdentity = (candidateValues: string[], assetValue: string) => {
  const candidateIdentities = dedupeStrings(
    candidateValues
      .map((candidate) => getEngineIdentityKey(candidate) ?? "")
      .filter(Boolean),
  );

  if (candidateIdentities.length === 0) return true;

  const assetIdentity = getEngineIdentityKey(assetValue);
  if (!assetIdentity) return false;

  return candidateIdentities.includes(assetIdentity);
};

const detectAssemblyFromFileName = (value: string): AssemblyKey | null => {
  const normalizedValue = normalizeImageKey(value);
  if (normalizedValue.startsWith("engine ")) return "engine";
  if (normalizedValue.startsWith("gearbox ")) return "gearbox";
  if (normalizedValue.startsWith("axle ")) return "axle";
  if (normalizedValue.startsWith("brake ")) return "brake";
  if (normalizedValue.startsWith("suspension ")) return "suspension";
  return null;
};

const detectAssemblyFromPublicPath = (value: string): AssemblyKey | null => {
  const pathKey = normalizeImageKey(value.replace(/\//g, " "));
  if (pathKey.includes("platform library engine")) return "engine";
  if (pathKey.includes("platform library gearbox")) return "gearbox";
  if (pathKey.includes("platform library axle")) return "axle";
  if (pathKey.includes("platform library brake")) return "brake";
  if (pathKey.includes("platform library suspension")) return "suspension";
  return null;
};

const getBandBucket = (productBand: ProductBand): BandBucket => {
  if (productBand === "heavy_truck") return "heavy";
  if (productBand === "medium_truck") return "medium";
  return "light";
};

const detectProductBandFromFileName = (value: string): ProductBand | null => {
  const normalizedValue = normalizeImageKey(value);
  if (normalizedValue.includes("heavy truck") || normalizedValue.includes("heavy duty")) return "heavy_truck";
  if (normalizedValue.includes("medium truck")) return "medium_truck";
  if (normalizedValue.includes("mini truck")) return "mini_truck";
  if (normalizedValue.includes("light truck")) return "light_truck";
  return null;
};

const listPlatformImageAssets = (dirPath: string, baseUrl: string): PlatformImageAsset[] => {
  const entries = readdirSync(dirPath, { withFileTypes: true });

  return entries.flatMap((entry) => {
    const absolutePath = `${dirPath}/${entry.name}`.replace(/\\/g, "/");
    const publicPath = `${baseUrl}/${entry.name}`.replace(/\\/g, "/");

    if (entry.isDirectory()) {
      return listPlatformImageAssets(absolutePath, publicPath);
    }

    const extension = extname(entry.name).toLowerCase();
    if (!supportedImageExtensions.has(extension)) return [];

    const baseName = basename(entry.name, extension);
    return [
      {
        assembly: detectAssemblyFromPublicPath(publicPath) ?? detectAssemblyFromFileName(baseName),
        productBand: detectProductBandFromFileName(baseName),
        baseName,
        normalizedBaseName: normalizeImageKey(baseName),
        url: publicPath,
        isFallback: publicPath.includes("/fallback/"),
      },
    ];
  });
};

const platformLibraryAssets = listPlatformImageAssets(platformLibraryRoot, "/images/platform-library");
const platformImageAssets = platformLibraryAssets.filter((asset) => !asset.isFallback);
const platformFallbackAssets = platformLibraryAssets.filter((asset) => asset.isFallback);
const kitImageAssets = listPlatformImageAssets(kitImageRoot, "/images/kit");

const dedupeStrings = (values: string[]) => [...new Set(values.map((value) => value.trim()).filter(Boolean))];

const hashSeed = (value: string) =>
  [...value].reduce((total, char) => ((total * 31) + char.charCodeAt(0)) >>> 0, 7);

const getExactPlatformImage = (assembly: AssemblyKey, candidates: string[]) => {
  const candidateKeys = dedupeStrings(candidates).map((candidate) => normalizeImageKey(candidate));
  const looseCandidateKeys = dedupeStrings(candidates).map((candidate) => makeLooseImageKey(candidate));
  const compactCandidateKeys = dedupeStrings(candidates).map((candidate) => compactImageKey(candidate));
  const assemblyAssets = platformImageAssets.filter((asset) => asset.assembly === assembly);
  const compatibleAssemblyAssets = assembly === "engine"
    ? assemblyAssets.filter((asset) => isCompatibleEngineIdentity(candidates, asset.baseName))
    : assemblyAssets;

  const exactMatch = assemblyAssets.find((asset) => candidateKeys.includes(asset.normalizedBaseName));
  if (exactMatch) return exactMatch.url;

  const familyMatch = compatibleAssemblyAssets.find((asset) =>
    looseCandidateKeys.some((candidateKey) => {
      const assetLooseKey = makeLooseImageKey(asset.baseName);
      const assetCompactKey = compactImageKey(asset.baseName);
      return (
        candidateKey.startsWith(assetLooseKey) ||
        assetLooseKey.startsWith(candidateKey) ||
        compactCandidateKeys.some(
          (compactCandidateKey) =>
            compactCandidateKey.startsWith(assetCompactKey) || assetCompactKey.startsWith(compactCandidateKey),
        )
      );
    }),
  );

  const tokenOverlapMatch = compatibleAssemblyAssets.find((asset) =>
    looseCandidateKeys.some((candidateKey) => {
      const candidateTokens = candidateKey.split(" ").filter(Boolean);
      const assetTokens = makeLooseImageKey(asset.baseName).split(" ").filter(Boolean);
      const sharedTokens = candidateTokens.filter((token) => assetTokens.includes(token));
      return sharedTokens.length >= Math.min(3, candidateTokens.length, assetTokens.length);
    }),
  );

  const sameIdentityFallbackMatch = assembly === "engine" && compatibleAssemblyAssets.length > 0
    ? compatibleAssemblyAssets[
        hashSeed(
          dedupeStrings(candidates)
            .map((candidate) => getEngineIdentityKey(candidate) || makeLooseImageKey(candidate))
            .find(Boolean) ?? assembly,
        ) % compatibleAssemblyAssets.length
      ]
    : undefined;

  return familyMatch?.url ?? tokenOverlapMatch?.url ?? sameIdentityFallbackMatch?.url;
};

const getBandAwareFallbackPool = (assembly: AssemblyKey, productBand: ProductBand) => {
  const assemblyPool = platformFallbackAssets.filter((asset) => asset.assembly === assembly);
  if (assemblyPool.length === 0) return [];

  const targetBucket = getBandBucket(productBand);
  const explicitlyTaggedPool = assemblyPool.filter(
    (asset) => asset.productBand && getBandBucket(asset.productBand) === targetBucket,
  );
  if (explicitlyTaggedPool.length > 0) return explicitlyTaggedPool;

  const genericPool = assemblyPool.filter((asset) => !asset.productBand);
  if (genericPool.length > 0) return genericPool;

  return assemblyPool;
};

const getFallbackIdentityKey = (assembly: AssemblyKey, candidates: string[]) => {
  const candidateKeys = dedupeStrings(candidates)
    .map((candidate) => makeLooseImageKey(candidate))
    .filter(Boolean)
    .sort((left, right) => right.length - left.length);

  const prefixedKey = candidateKeys.find((candidate) => candidate.startsWith(`${assembly} `));
  return prefixedKey ?? candidateKeys[0] ?? assembly;
};

const getFallbackPlatformImage = (
  assembly: AssemblyKey,
  productBand: ProductBand,
  candidates: string[],
  distributionKey: string,
) => {
  const assemblyPool = getBandAwareFallbackPool(assembly, productBand);
  if (assemblyPool.length === 0) return assemblyDefaultImages[assembly];
  const fallbackIdentityKey = getFallbackIdentityKey(assembly, candidates);
  const seed = hashSeed(`${assembly}:${getBandBucket(productBand)}:${fallbackIdentityKey}:${distributionKey}`);
  return assemblyPool[seed % assemblyPool.length]?.url ?? assemblyDefaultImages[assembly];
};

const resolvePlatformImage = (
  assembly: AssemblyKey,
  productBand: ProductBand,
  candidates: string[],
  distributionKey: string,
) => getExactPlatformImage(assembly, candidates) ?? getFallbackPlatformImage(assembly, productBand, candidates, distributionKey);

