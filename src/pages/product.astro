const partsCategoryImageFallbackMap: Record<AssemblyKey, string[]> = {
  engine: ["/images/Engine-Parts.png", "/images/Engine-Parts.png", "/images/Engine-Parts.png"],
  gearbox: [
    "/images/platform-downloads/official-batch/Gearbox ZF Ecolite.png",
