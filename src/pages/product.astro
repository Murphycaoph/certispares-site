const isPromptMatch = (assetKey: string, promptKey: string) =>
  assetKey === promptKey ||
  assetKey.startsWith(promptKey) ||
  promptKey.startsWith(assetKey) ||
  assetKey.includes(promptKey) ||
  promptKey.includes(assetKey);

const getPartCategoryImage = (assembly: AssemblyKey, prompt: string, fallbackIndex: number) => {
  const promptKey = normalizeImageKey(prompt);
  const matchedImage = kitImageAssets.find((asset) => isPromptMatch(asset.normalizedBaseName, promptKey))?.url;
  return matchedImage ?? partsCategoryImageFallbackMap[assembly][fallbackIndex % partsCategoryImageFallbackMap[assembly].length];
};

const makeParts = (
  kind: AssemblyKey,
  productBand: ProductBand,
  seedKey: string,
): PartItem[] =>
  partLabelPool[kind].map((part, index) => ({
    name: part.name,
    note: part.note,
    details: part.details,
    prompt: part.prompt,
    image: getPartCategoryImage(kind, part.prompt, index),
  }));

const uniqueBy = <T,>(items: T[], getKey: (item: T) => string) => {
  const seen = new Set<string>();
  return items.filter((item) => {
    const key = getKey(item);
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
};

const groupedBrands = [...new Set(productCards.map((item) => item.brand))]
  .map((brandName) => {
  const brandRows = productCards.filter((item) => item.brand === brandName);
  const brandLogo = brandLogoMap[brandName] ?? {
    image: "/images/brands/default-brand.svg",
    alt: `${brandName} logo`,
    text: brandName.toUpperCase(),
  };
  const engineRows = brandRows.filter((item) => item.cardType === "engine_family" && item.engineModel);
  const gearboxRows = brandRows.filter((item) => item.gearboxModel && (item.cardType === "gearbox_family" || item.cardType === "engine_family"));
  const axleRows = brandRows.filter((item) => item.cardType === "axle_family");
  const brakeRows = brandRows.filter((item) => item.cardType === "brake_system");
  const suspensionRows = brandRows.filter((item) => item.cardType === "suspension_family");

  const engineModels: ModelItem[] = engineRows.map((item, index) => {
    const displayTitle = makeDisplayTitle(item.engineModel, "engine");

    return {
      id: `engine-${item.submodelCode}`,
      title: displayTitle,
      subtitle: item.brandCluster,
      brandCluster: item.brandCluster,
      submodelCode: item.submodelCode,
      image: resolvePlatformImage(
        "engine",
        item.productBand,
        [
          `Engine ${brandName} ${item.heroTitle}`,
          `Engine ${item.engineModel}`,
          displayTitle,
          `Engine ${item.heroTitle}`,
          item.engineModel,
          item.heroTitle,
        ],
        `${brandName}-${index}`,
      ),
      band: item.productBand.replace("_", " "),
      parts: makeParts("engine", item.productBand, `engine-${brandName}-${item.submodelCode}`),
    };
  });

  const gearboxModels: ModelItem[] = gearboxRows
    .map((item, index) => {
      const displayTitle = makeDisplayTitle(item.gearboxModel, "gearbox");

      return {
        id: `gearbox-${item.submodelCode}`,
        title: displayTitle,
        subtitle: item.brandCluster,
        brandCluster: item.brandCluster,
        submodelCode: item.submodelCode,
        image: resolvePlatformImage(
          "gearbox",
          item.productBand,
          [
            `Gearbox ${brandName} ${item.gearboxModel}`,
            `Gearbox ${displayTitle}`,
            `Gearbox ${item.gearboxModel}`,
            displayTitle,
            item.gearboxModel,
          ],
          `${brandName}-${index}`,
        ),
        band: item.productBand.replace("_", " "),
        parts: makeParts("gearbox", item.productBand, `gearbox-${brandName}-${item.submodelCode}`),
      };
    });

  const axleSource = axleRows.length > 0 ? axleRows : uniqueBy(brandRows, (item) => `${item.brandCluster}-${item.productBand}`);
  const axleModels: ModelItem[] = axleSource.map((item, index) => ({
    id: `axle-${item.brandCluster}-${item.productBand}`.toLowerCase().replace(/\s+/g, "-"),
    title: `${item.brandCluster} Axle`,
    subtitle: item.brandCluster,
    brandCluster: item.brandCluster,
    submodelCode: item.submodelCode,
    image: resolvePlatformImage(
      "axle",
      item.productBand,
      [
        `Axle ${brandName} ${item.brandCluster} ${item.productBand.replace("_", " ")}`,
        `Axle ${item.brandCluster} ${item.productBand.replace("_", " ")}`,
        `Axle ${brandName} ${item.brandCluster}`,
        `Axle ${item.brandCluster}`,
        `${item.brandCluster} Axle`,
      ],
      `${brandName}-${index}`,
    ),
    band: item.productBand.replace("_", " "),
    parts: makeParts("axle", item.productBand, `axle-${brandName}-${item.brandCluster}-${item.productBand}`),
  }));

  const brakeSource = brakeRows.length > 0 ? brakeRows : uniqueBy(brandRows, (item) => `${item.brandCluster}-${item.productBand}`);
  const brakeModels: ModelItem[] = brakeSource.map((item, index) => ({
    id: `brake-${item.brandCluster}-${item.productBand}`.toLowerCase().replace(/\s+/g, "-"),
    title: `${item.brandCluster} Brake System`,
    subtitle: item.brandCluster,
    brandCluster: item.brandCluster,
    submodelCode: item.submodelCode,
    image: resolvePlatformImage(
      "brake",
      item.productBand,
      [
        `Brake ${brandName} ${item.brandCluster} ${item.productBand.replace("_", " ")}`,
        `Brake ${item.brandCluster} ${item.productBand.replace("_", " ")}`,
        `Brake ${brandName} ${item.brandCluster}`,
        `Brake ${item.brandCluster}`,
        `${item.brandCluster} Brake System`,
      ],
      `${brandName}-${index}`,
    ),
    band: item.productBand.replace("_", " "),
    parts: makeParts("brake", item.productBand, `brake-${brandName}-${item.brandCluster}-${item.productBand}`),
  }));

  const suspensionSource = suspensionRows.length > 0 ? suspensionRows : uniqueBy(brandRows, (item) => `${item.brandCluster}-${item.productBand}`);
  const suspensionModels: ModelItem[] = suspensionSource.map((item, index) => ({
    id: `suspension-${item.brandCluster}-${item.productBand}`.toLowerCase().replace(/\s+/g, "-"),
    title: `${item.brandCluster} Suspension`,
    subtitle: item.brandCluster,
    brandCluster: item.brandCluster,
    submodelCode: item.submodelCode,
    image: resolvePlatformImage(
      "suspension",
      item.productBand,
      [
        `Suspension ${brandName} ${item.brandCluster} ${item.productBand.replace("_", " ")}`,
        `Suspension ${item.brandCluster} ${item.productBand.replace("_", " ")}`,
        `Suspension ${brandName} ${item.brandCluster}`,
        `Suspension ${item.brandCluster}`,
        `${item.brandCluster} Suspension`,
      ],
      `${brandName}-${index}`,
    ),
    band: item.productBand.replace("_", " "),
    parts: makeParts(
      "suspension",
      item.productBand,
      `suspension-${brandName}-${item.brandCluster}-${item.productBand}`,
    ),
  }));

  const assemblies: AssemblyItem[] = [
    {
      key: "engine",
      ...assemblyMeta.engine,
      models: engineModels,
    },
    {
      key: "gearbox",
      ...assemblyMeta.gearbox,
      models: gearboxModels,
    },
    {
      key: "axle",
      ...assemblyMeta.axle,
      models: axleModels,
    },
    {
      key: "brake",
      ...assemblyMeta.brake,
      models: brakeModels,
    },
    {
      key: "suspension",
      ...assemblyMeta.suspension,
      models: suspensionModels,
    },
  ].filter((item) => item.models.length > 0);

  return {
    id: brandName.toLowerCase(),
    name: brandName,
    shortName: brandName.slice(0, 2).toUpperCase(),
    logoText: brandLogo.text,
    logoImage: brandLogo.image,
    logoAlt: brandLogo.alt,
    assemblies,
  } satisfies BrandItem;
  })
  .sort((leftBrand, rightBrand) => {
    const leftEngineCount = leftBrand.assemblies.find((assembly) => assembly.key === "engine")?.models.length ?? 0;
    const rightEngineCount = rightBrand.assemblies.find((assembly) => assembly.key === "engine")?.models.length ?? 0;

    if (rightEngineCount !== leftEngineCount) return rightEngineCount - leftEngineCount;
    return leftBrand.name.localeCompare(rightBrand.name);
  });

const initialBrand = groupedBrands[0];
const initialAssembly = initialBrand?.assemblies[0];
const initialModel = initialAssembly?.models[0];

const catalogData = JSON.stringify(groupedBrands);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Interactive Product Platform Catalog",
    description:
      "Interactive multi-column catalog for commercial vehicle brands, assemblies, engine models, gearbox models, and matching service parts.",
    url: "https://certispares.com/product/",
  },
];
---

<BaseLayout
