---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const rawPosts = await getCollection("blog");

rawPosts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));

const insights = rawPosts.slice(0, 3).map((p) => ({
  title: p.data.title,
  tag: p.data.tag ?? "Insights",
  excerpt: p.data.excerpt ?? "",
  href: `/blog/${p.slug}`,
}));

const heroImages = [
  "/images/hero.webp",
  "/images/hero-02-commercial-fleet.webp",
  "/images/hero-03-container-port.webp",
  "/images/hero-04-logistics-truck.webp",
];

const searchThemes = [
  {
    title: "Heavy duty truck parts",
    desc: "Heavy-duty truck parts remain the core RFQ category, supported by structured supplier comparison for B2B aftermarket buyers.",
  },
  {
    title: "Light-, medium-, and heavy-duty coverage",
    desc: "We handle RFQ sourcing across light-, medium-, and heavy-duty truck platforms for the commercial vehicle aftermarket.",
  },
  {
    title: "Brand-based RFQs",
    desc: "Common RFQs include Sinotruk HOWO, SHACMAN, Foton, Dongfeng, FAW, JAC, and OEM or part-number-based inquiries.",
  },
];

const popularQueries = [
  "heavy duty truck parts",
  "truck spare parts",
  "aftermarket truck parts",
  "Sinotruk HOWO parts",
  "Shacman parts",
  "Foton truck parts",
];
---

<BaseLayout
  title="Homepage Draft | CertiSpares"
  description="Draft review page for the current CertiSpares homepage."
  robots="noindex,nofollow"
>
  <style>
  :root{
    --bg:#eef3f7;
    --text:#1d2a36;
    --muted:#5f6d86;
    --line:rgba(29,42,54,.10);
    --brand:#3957E9;
    --brand2:#3957E9;
  }

  :global(main){
    background:
      linear-gradient(180deg, #f5f8fc 0%, #eef3f7 100%);
  }

  :global(.topbar){
    background:#111F43 !important;
    background-color:#111F43 !important;
    opacity:1 !important;
    backdrop-filter:none !important;
    -webkit-backdrop-filter:none !important;
    border-bottom:1px solid #111F43 !important;
    box-shadow:none !important;
  }

  :global(.menu){
    color:#fff;
  }

  :global(.menu a){
    color:#fff;
  }

  :global(.menu a:hover){
    color:#fff;
  }

  :global(.menu a.active){
    background:rgba(57,87,233,.18);
    border-color:rgba(57,87,233,.32);
    color:#fff;
  }

  :global(.drawerNav a.active){
    background:rgba(57,87,233,.18);
    border-color:rgba(57,87,233,.32);
    color:#fff;
  }

  :global(.cta){
    background:#3957E9;
    color:#fff;
  }

  .hero{
    position:relative;
    border-bottom:1px solid var(--line);
    overflow:hidden;
  }

  .heroBg{
    position:absolute; inset:0;
    background:
      linear-gradient(180deg, rgba(11,16,32,.45) 0%, rgba(11,16,32,.86) 70%, rgba(11,16,32,1) 100%),
      radial-gradient(900px 420px at 25% 15%, rgba(57,87,233,.35), transparent 60%);
    overflow:hidden;
  }

  .heroSlider{
    position:absolute; inset:0;
  }

  .heroSlide{
    position:absolute; inset:0;
    background: var(--bg) center/cover no-repeat;
    filter:saturate(1.05);
    opacity:0;
    transform:scale(1.02);
    transition: opacity .55s ease, transform .9s ease;
    will-change: opacity, transform;
  }

  .heroSlide.is-active{
    opacity:1;
    transform:scale(1);
  }

  .heroSlide::after{
    content:"";
    position:absolute; inset:0;
    background:
      radial-gradient(1100px 520px at 28% 18%, rgba(255,255,255,.06), transparent 60%),
      radial-gradient(1400px 760px at 50% 50%, transparent 55%, rgba(11,16,32,.55) 100%),
      linear-gradient(
        180deg,
        rgba(11,16,32,.18) 0%,
        rgba(11,16,32,.72) 70%,
        rgba(11,16,32,.92) 100%
      );
  }

  .heroNav{
    position:absolute;
    top:50%;
    transform:translateY(-50%);
    width:42px; height:42px;
    border-radius:14px;
    border:1px solid var(--line);
    background:rgba(17,26,51,.45);
    color:rgba(234,240,255,.92);
    font-size:26px;
    display:grid; place-items:center;
    cursor:pointer;
    z-index:2;
    backdrop-filter: blur(10px);
    user-select:none;
  }

  .heroNav:hover{ background:rgba(17,26,51,.65); }
  .heroNav.prev{ left:16px; }
  .heroNav.next{ right:16px; }

  .contentWrap{
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .heroInner{
    position:relative;
    padding:78px 0 56px;
    display:grid;
    grid-template-columns: 1.15fr .85fr;
    gap:18px;
    align-items:center;
  }

  h1{
    margin:0 0 14px;
    font-size:52px;
    line-height:1.03;
    letter-spacing:-.6px;
    color:#fff;
  }

  .sub{
    margin:0 0 18px;
    color:rgba(234,240,255,.86);
    line-height:1.75;
    max-width:640px;
  }

  .heroBtns{ display:flex; gap:12px; flex-wrap:wrap; margin-top:16px; }

  .heroBtns .btn:not(.primary){
    color:#fff;
  }

  .heroCard{
    background:rgba(17,26,51,.62);
    border:1px solid var(--line);
    border-radius:18px;
    padding:18px;
    box-shadow: 0 18px 60px rgba(0,0,0,.35);
  }

  .heroCard h3{ margin:0 0 10px; font-size:16px; letter-spacing:.2px; color:#fff; }
  .list{ margin:0; padding:0; list-style:none; display:grid; gap:10px; }
  .li{ display:flex; gap:10px; align-items:flex-start; color:rgba(255,255,255,.92); line-height:1.5; }

  .dot{
    width:10px;
    height:10px;
    border-radius:999px;
    margin-top:6px;
    background:linear-gradient(135deg, var(--brand), var(--brand2));
    flex:0 0 10px;
  }

  .more{ display:inline-block; margin-top:10px; font-weight:900; color:rgba(234,240,255,.92); }
  .more:hover{ color:var(--brand2); }

  .grid3{ display:grid; grid-template-columns: repeat(3, 1fr); gap:14px; }
  .grid2{ display:grid; grid-template-columns: repeat(2, 1fr); gap:14px; }

  .sectionTitle{ font-size:28px; margin:0 0 12px; letter-spacing:-.2px; }
  .sectionDesc{ margin:0 0 18px; color:var(--muted); line-height:1.7; max-width:820px; }
  .chipRow{ display:flex; gap:10px; flex-wrap:wrap; margin:10px 0 0; }

  .chip{
    padding:8px 12px;
    border-radius:999px;
    border:1px solid rgba(29,42,54,.10);
    background:#fff;
    font-size:12px;
    font-weight:800;
    color:#415066;
  }

  .strip{
    margin-top:18px;
    display:grid;
    grid-template-columns: repeat(4,1fr);
    gap:12px;
  }

  .kpi{
    background:rgba(255,255,255,.03);
    border:1px solid var(--line);
    border-radius:16px;
    padding:14px;
  }

  .kpi .n{ font-weight:950; font-size:18px; color:#fff; }
  .kpi .t{ color:rgba(255,255,255,.88); font-size:12px; margin-top:6px; line-height:1.4; }

  .insightsHead{
    display:flex; align-items:flex-end; justify-content:space-between; gap:12px;
    margin-bottom:12px;
  }

  .viewAll{
    font-weight:900;
    color:#1d2a36;
    padding:8px 10px;
    border-radius:10px;
    border:1px solid rgba(29,42,54,.10);
    background:#fff;
    white-space:nowrap;
  }

  .viewAll:hover{ background:#f3f6fa; color:#1d2a36; }

  .postCard b{ margin-bottom:8px; font-size:16px; line-height:1.35; }

  .postMeta{
    display:flex; gap:10px; flex-wrap:wrap; align-items:center;
    font-size:12px; color:#6d7b91;
    margin-bottom:10px;
  }

  .postTag{
    padding:.18rem .55rem;
    border-radius:999px;
    border:1px solid rgba(74,84,98,.16);
    background:rgba(74,84,98,.08);
    font-weight:800;
    color:#4A5462;
  }

  .postMore{
    display:inline-flex; gap:6px; align-items:center;
    margin-top:10px; font-weight:900;
    color:#4A5462;
  }

  .btn.primary{
    color:#fff;
  }

  .card{
    background:#fff;
    border:1px solid rgba(29,42,54,.10);
    box-shadow:0 14px 32px rgba(24,39,56,.05);
  }

  .card b{
    color:#1d2a36;
  }

  .card p{
    color:#5f6d86;
  }

  :global(.footerWrap){
    background:transparent;
    border-top:1px solid rgba(29,42,54,.10);
  }

  :global(.footerTitle),
  :global(.footerNav strong){
    color:#1d2a36;
  }

  :global(.footer),
  :global(.footerNav span){
    color:#5f6d86;
  }

  :global(.footerNav a){
    background:#fff;
    border-color:rgba(29,42,54,.10);
  }

  .postMore:hover{ color:var(--brand2); }

  @media (max-width: 980px){
    .heroInner{ grid-template-columns:1fr; padding:60px 0 46px; }
    h1{ font-size:40px; }
    .grid3{ grid-template-columns:1fr; }
    .grid2{ grid-template-columns:1fr; }
    .strip{ grid-template-columns:1fr 1fr; }
    .insightsHead{ align-items:flex-start; }
    .heroNav{ width:38px; height:38px; border-radius:12px; }
    .heroNav.prev{ left:10px; }
    .heroNav.next{ right:10px; }
  }

  @media (prefers-reduced-motion: reduce){
    .heroSlide{ transition:none; }
  }
  </style>

  <header class="hero">
    <div class="heroBg">
      <div class="heroSlider" id="heroSlider" aria-label="Hero images">
        {heroImages.map((src, idx) => (
          <div
            class={`heroSlide ${idx === 0 ? "is-active" : ""}`}
            style={`--bg:url('${src}')`}
            aria-hidden={idx === 0 ? "false" : "true"}
          ></div>
        ))}

        <button class="heroNav prev" type="button" aria-label="Previous image">&larr;</button>
        <button class="heroNav next" type="button" aria-label="Next image">&rarr;</button>
      </div>
    </div>

    <div class="container">
      <div class="heroInner">
        <div>
          <h1>Heavy-Duty Truck Parts Sourcing for Commercial Vehicle Aftermarket Buyers</h1>
          <p class="sub">
            CertiSpares supports RFQ sourcing for heavy-duty truck parts while also covering light-, medium-, and heavy-duty
            truck platforms through supplier comparison, QC checkpoints, consolidation, and shipping coordination.
          </p>

          <div class="heroBtns">
            <a class="btn primary" href="/contact">Send RFQ</a>
            <a class="btn" href="/capabilities">View Capabilities</a>
          </div>

          <div class="strip">
            <div class="kpi"><div class="n">QC</div><div class="t">Sampling &middot; Packing check &middot; Loading supervision</div></div>
            <div class="kpi"><div class="n">Docs</div><div class="t">PI/CI/PL &middot; HS code assist &middot; Export documents</div></div>
            <div class="kpi"><div class="n">Speed</div><div class="t">Fast RFQ &middot; Multi-region supplier pool</div></div>
            <div class="kpi"><div class="n">Risk</div><div class="t">Audit-style vendor verification & traceability</div></div>
          </div>
        </div>

        <aside class="heroCard">
          <h3>How It Works (Overview)</h3>
          <ul class="list">
            <li class="li"><span class="dot"></span><span>Send your RFQ with OEM/brand/model or photos.</span></li>
            <li class="li"><span class="dot"></span><span>We source & compare suppliers, then submit options with lead time.</span></li>
            <li class="li"><span class="dot"></span><span>QC checkpoints + packing & labeling confirmation before shipment.</span></li>
            <li class="li"><span class="dot"></span><span>Export execution with clean documentation and tracking.</span></li>
          </ul>
          <a class="more" href="/how-it-works">Learn more &rarr;</a>
        </aside>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">What overseas buyers usually search for</h2>
      <p class="sectionDesc">
        Most commercial-intent searches in this segment are not broad phrases alone. Buyers often search by truck part type,
        by brand, or by OEM and part-number-led RFQ language.
      </p>
      <div class="grid3">
        {searchThemes.map((item) => (
          <div class="card"><b>{item.title}</b><p>{item.desc}</p></div>
        ))}
      </div>
      <div class="chipRow" aria-label="Popular search phrases">
        {popularQueries.map((query) => (
          <span class="chip">{query}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Why Choose Us</h2>
      <p class="sectionDesc">
        From supplier comparison to QC checkpoints and export coordination, we make commercial vehicle aftermarket sourcing
        more structured for importers, distributors, wholesalers, and fleet maintenance buyers.
      </p>
      <div class="grid3">
        <div class="card"><b>RFQ sourcing</b><p>Multiple supplier options with price, lead time, and sourcing risk comparison.</p><a class="more" href="/capabilities">Learn more &rarr;</a></div>
        <div class="card"><b>Quality control</b><p>Sampling, packaging verification, loading supervision, and photo or video checkpoints.</p><a class="more" href="/capabilities">Learn more &rarr;</a></div>
        <div class="card"><b>Consolidation and shipping</b><p>PI/CI/PL review, HS-code support, consolidation planning, and export document follow-up.</p><a class="more" href="/capabilities">Learn more &rarr;</a></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">How It Works</h2>
      <p class="sectionDesc">
        Our workflow is built for B2B truck parts sourcing, from RFQ intake to supplier comparison, QC checkpoints,
        and shipment coordination for repeat aftermarket orders.
      </p>
      <div class="grid2">
        <div class="card"><b>Step 1-2</b><p>Share the RFQ, then receive supplier comparison across the right truck platform and part scope.</p><a class="more" href="/how-it-works">Learn more &rarr;</a></div>
        <div class="card"><b>Step 3-4</b><p>Confirm the order with QC checkpoints, then move into consolidation, documents, and shipping.</p><a class="more" href="/how-it-works">Learn more &rarr;</a></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="insightsHead">
        <div>
          <h2 class="sectionTitle">Latest Insights</h2>
          <p class="sectionDesc">
            Short reads on QC, risk control, trade terms, and sourcing execution.
          </p>
        </div>
        <a class="viewAll" href="/blog">View all &rarr;</a>
      </div>

      <div class="grid3">
        {insights.map((p) => (
          <a class="card postCard" href={p.href}>
            <div class="postMeta">
              <span class="postTag">{p.tag}</span>
            </div>
            <b>{p.title}</b>
            <p>{p.excerpt}</p>
            <span class="postMore">Read &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">Send Your RFQ</h2>
      <p class="sectionDesc">
        Tell us the parts you need with OEM numbers, part numbers, vehicle brand and model, or photos.
        We will reply with supplier comparison, lead time, and sourcing suggestions for your truck parts order.
      </p>
      <div class="grid3">
        <div class="card"><b>Email</b><p>murphy@certispares.com</p><a class="more" href="/contact">Learn more &rarr;</a></div>
        <div class="card"><b>WhatsApp</b><p>+86 156 3302 2618</p><a class="more" href="/contact">Learn more &rarr;</a></div>
        <div class="card"><b>Location</b><p>Beijing / Hebei, China</p><a class="more" href="/contact">Learn more &rarr;</a></div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const root = document.getElementById("heroSlider");
      if (!root) return;

      const slides = Array.from(root.querySelectorAll(".heroSlide"));
      const prev = root.querySelector(".heroNav.prev");
      const next = root.querySelector(".heroNav.next");
      if (slides.length <= 1) return;

      let i = 0;

      const set = (n) => {
        slides[i].classList.remove("is-active");
        slides[i].setAttribute("aria-hidden", "true");

        i = (n + slides.length) % slides.length;

        slides[i].classList.add("is-active");
        slides[i].setAttribute("aria-hidden", "false");
      };

      const goPrev = () => set(i - 1);
      const goNext = () => set(i + 1);

      prev && prev.addEventListener("click", goPrev);
      next && next.addEventListener("click", goNext);

      let timer = setInterval(goNext, 6000);

      root.addEventListener("mouseenter", () => { clearInterval(timer); });
      root.addEventListener("mouseleave", () => { timer = setInterval(goNext, 6000); });

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          clearInterval(timer);
        } else {
          clearInterval(timer);
          timer = setInterval(goNext, 6000);
        }
      });
    })();
  </script>
</BaseLayout>
