---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Thank You | RFQ Received | CertiSpares"
  description="RFQ received. We will reply within 24-48 hours."
  robots="noindex, nofollow"
>
  <section class="section">
    <div class="container">
      <h1>Thank you</h1>
      <p class="lead">
        Your RFQ has been received. We usually reply within <b>24-48 hours</b>.
      </p>

      <div class="card">
        <b>Next</b>
        <p>
          If you have additional photos/spec sheets, you can email them to
          <a href="mailto:murphy@certispares.com">murphy@certispares.com</a>.
        </p>
      </div>

      <div style="margin-top:16px;">
        <a class="btn primary" href="/capabilities">Back to Capabilities</a>
        <a class="btn" href="/">Home</a>
      </div>
    </div>
  </section>
</BaseLayout>
